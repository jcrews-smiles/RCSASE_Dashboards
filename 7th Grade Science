  const domCards=Object.entries(s.d).map(([domName,d])=>{const b2=d.b2!=null?Math.round(d.b2):null;const b1=d.b1!=null?Math.round(d.b1):null;const borderColor=b2==null?'var(--slate)':b2>=65?'var(--green)':b2>=50?'var(--sky)':b2>=35?'var(--amber)':'var(--rose)';return `<div class="domain-pcard" style="border-color:${borderColor}"><div class="dp-title">${domName}</div><div class="dp-placement" style="color:${borderColor}">${b2!=null?b2+'%':'—'}</div><div class="dp-score">B1: ${b1!=null?b1+'%':'—'} · ${d.n} standards</div></div>`;}).join('');
  const stdRows=studentStandards(s);
  const stdsHtml=`<div class="std-row-header"><div>Standard</div><div>Description</div><div>B1</div><div>B2</div><div>Δ</div></div>${[...stdRows].sort((a,b)=>(a.b2==null?-1:a.b2)-(b.b2==null?-1:b.b2)).map(st=>{const b2=st.b2!=null?Math.round(st.b2):null;const b1=st.b1!=null?Math.round(st.b1):null;const dlt=st.delta!=null?Math.round(st.delta):null;const b2Cls=scorePillClass(b2,st.b2!=null);const b1Cls=b1!=null?scorePillClass(b1,true):'sp-pend';const dCls=dlt!=null?(dlt>0?'delta-pos':dlt<0?'delta-neg':'delta-zero'):'delta-zero';return `<div class="std-row"><span class="std-code">${st.c}</span><div style="font-size:.72rem">${st.desc}</div><span class="score-mini ${b1Cls}">${b1!=null?b1:'—'}</span><span class="score-mini ${b2Cls}">${b2!=null?b2:'—'}</span><span class="${dCls}" style="font-weight:700">${dlt!=null?(dlt>=0?'+':'')+dlt:'NEW'}</span></div>`;}).join('')}`;
  let projection;
  if(t===1)projection='<strong>On track</strong> — strong mastery of 7th grade NGSSS standards; well-prepared for 8th grade science';
  else if(t===2)projection='Borderline — <strong>focus on weakest standards</strong> in remaining instructional time';
  else if(t===3)projection='<strong>At risk</strong> — strategic intervention needed on multiple standards';
  else if(t===4)projection='<strong>High risk</strong> — intensive intervention required on foundational science concepts';
  else projection='Did not complete B2 — administer makeup if possible';
  const html=`<div style="background:#fff;border-radius:16px;padding:28px;box-shadow:var(--card-shadow)"><div class="profile-header"><div class="profile-avatar" style="background:${color}">${getInitials(s.n)}</div><div style="flex:1"><div class="profile-name">${s.n}${s.a?'<span class="adv-chip">ADVANCED</span>':''}</div><div class="profile-meta">Period: ${s.p} · Teacher: ${s.t} · 7th Grade Science · Student ID: ${s.sid}</div><div class="profile-chips"><span class="profile-chip" style="background:${tc}22;color:${tc}">${tLabel}</span>${s.b2!=null?`<span class="profile-chip" style="background:#f0f9ff;color:#0369a1">B2: ${Math.round(s.b2)}%</span>`:'<span class="profile-chip" style="background:#fef3c7;color:#854d0e">⚠ No B2</span>'}<span class="profile-chip" style="background:#f5f3ff;color:#6d28d9">${s.wc} weak / ${s.sc} strong</span></div></div></div>
  <div class="profile-grid">
    <div class="profile-metric"><div class="pm-label">B1 Score</div><div class="pm-value" style="color:var(--slate)">${s.b1!=null?Math.round(s.b1)+'%':'—'}</div><div class="pm-sub">September 2025</div></div>
    <div class="profile-metric"><div class="pm-label">B2 Score</div><div class="pm-value" style="color:${tc}">${s.b2!=null?Math.round(s.b2)+'%':'—'}</div><div class="pm-sub">April 2026</div></div>
    <div class="profile-metric"><div class="pm-label">B1 → B2 Gain</div><div class="pm-value" style="color:${gainColor}">${gain!=null?(gain>=0?'+':'')+gain:'—'}</div><div class="pm-sub">% growth</div></div>
    <div class="profile-metric"><div class="pm-label">Standards Tested</div><div class="pm-value" style="color:var(--slate);font-size:1.4rem">30</div><div class="pm-sub">NGSSS strands</div></div>
    <div class="profile-metric"><div class="pm-label">Standards ≥ 70%</div><div class="pm-value" style="color:var(--green)">${s.sc}</div><div class="pm-sub">Mastered (B2)</div></div>
    <div class="profile-metric"><div class="pm-label">Standards &lt; 50%</div><div class="pm-value" style="color:var(--rose)">${s.wc}</div><div class="pm-sub">Need work (B2)</div></div>
  </div>
  <div class="card-title" style="margin-bottom:12px"><div class="icon" style="background:#dbeafe">📊</div> Domain Performance (B2)</div><div class="domain-profile">${domCards}</div>
  <div style="margin-top:14px;padding:10px 12px;background:${t<=2?'#f0fdf4':t<=3?'#fef3c7':'#fef2f2'};border-radius:8px;border-left:4px solid ${tc};font-size:.74rem;line-height:1.5;margin-bottom:20px"><strong>State Test Projection:</strong> ${projection}.</div>
  <div class="card-title" style="margin-bottom:10px"><div class="icon" style="background:#fef3c7">📋</div> Per-Standard Mastery (sorted by B2 ascending — weakest first)</div>
  <div style="max-height:600px;overflow-y:auto;padding:0 4px">${stdsHtml}</div></div>`;
  document.getElementById('student-profile-wrap').innerHTML=html;
}

// TIERS
function renderTiers(){
  const t1=STUDENTS.filter(s=>getTier(s)===1);const t2=STUDENTS.filter(s=>getTier(s)===2);const t3=STUDENTS.filter(s=>getTier(s)===3);const t4=STUDENTS.filter(s=>getTier(s)===4);
  function rl(stu){return stu.map(s=>{const c=hashColor(s.n);return `<li class="tier-student" onclick="openStudent('${s.n.replace(/'/g,"&#39;")}')"><div class="tier-avatar" style="background:${c}">${getInitials(s.n)}</div><div class="tier-info"><div class="tier-sname">${s.n}${s.a?' ⭐':''}</div><div class="tier-room">B2 ${s.b2!=null?Math.round(s.b2)+'%':'—'} · ${s.p}${s.g!=null?' · Δ '+(s.g>=0?'+':'')+Math.round(s.g):''}</div></div></li>`;}).join('');}
  document.getElementById('tier-grid').innerHTML=`<div class="tier-card t1"><div class="tier-head"><div class="tier-num">1</div><div><div class="tier-title">At/Above Benchmark</div><div class="tier-count">${t1.length} students · B2 ≥ 65%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t1)}</ul></div><div class="tier-card t2"><div class="tier-head"><div class="tier-num">2</div><div><div class="tier-title">Approaching</div><div class="tier-count">${t2.length} students · B2 50–64%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t2)}</ul></div><div class="tier-card t3"><div class="tier-head"><div class="tier-num">3</div><div><div class="tier-title">On Watch</div><div class="tier-count">${t3.length} students · B2 35–49%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t3)}</ul></div><div class="tier-card t4"><div class="tier-head"><div class="tier-num">4</div><div><div class="tier-title">Intervention</div><div class="tier-count">${t4.length} students · B2 &lt; 35%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t4)}</ul></div>`;
}

// ACTION PLAN
function renderActionPlan(){
  const t1=STUDENTS.filter(s=>getTier(s)===1);const t2=STUDENTS.filter(s=>getTier(s)===2);const t3=STUDENTS.filter(s=>getTier(s)===3);const t4=STUDENTS.filter(s=>getTier(s)===4);
  const plans=[
    {tier:4,title:'Tier 4 — Intensive Intervention',students:t4,
      focus:['SC.7.E.6.1 — Earth\'s Layers (cohort regression: 45% → 28% — TOP PRIORITY)','SC.7.L.17.1 — Food Webs and Energy Transfer (B2: 39%)','SC.7.P.10.3 — Wave Speed in Different Materials (B2: 44%)','SC.7.N.3.1 — Theories and Laws (B2: 49%)','SC.7.L.15.2 — Natural Selection (B2: 49%)','SC.7.L.15.1 — Fossil Evidence and Evolution (B2: 51%)'],
      strategies:['Daily 30-min small group (3–4 students) with classroom teacher during WIN/flex','Earth\'s Layers reteach: cross-section diagrams, mnemonic for layers (Crust-Mantle-Outer-Inner), edible models (boiled egg or stacked dough)','Food Web modeling with arrows showing energy direction; trophic level practice with cards','Wave speed comparisons: hands-on demonstrations (slinky, water tanks), Reflection/Refraction lab','Theory vs Law card sort with examples (e.g., theory of evolution vs law of gravity)','Natural selection simulations (PhET, bird-beak activity, peppered moth)','Vocabulary cards (Frayer model) for high-leverage terms: "lithosphere," "trophic level," "natural selection," "biotic factors"','Daily exit ticket: 2 questions on focus standard with immediate feedback','Test-taking strategies: process of elimination, tag/untag method on Progress Learning'],
      resources:['Mystery Science 7th grade','PhET simulations (plate tectonics, natural selection, waves)','BrainPOP NGSSS-aligned videos','Stemscopes Florida 7th Grade','Progress Learning targeted reteach assignments','Florida NGSSS item specs','CER scaffolding templates']},
    {tier:3,title:'Tier 3 — Strategic Support',students:t3,
      focus:['SC.7.E.6.1 — Earth\'s Layers (priority — cohort regression)','SC.7.E.6.3 — Measuring the Age of Earth (regressed 78% → 59%)','SC.7.L.17.2 — Relationships Among Organisms (B2: 51%)','SC.7.N.1.4 — Experimental Variables (B2: 54%)','SC.7.E.6.5 — Plate Tectonics','SC.7.L.15.2 — Natural Selection','SC.7.L.16.2 — Punnett Squares and Pedigrees (B1 only — 26% on B1)'],
      strategies:['Small group (4–6) 3x/week pull-out during flex','Re-administer SC.7.E.6.1 questions in low-stakes practice setting — diagnose what changed since B1','Earth\'s Layers reteach with cross-section diagram and density-of-layers ranking','Geologic time scale practice (Measuring Age of Earth) with relative vs absolute dating examples','Plate Tectonics: convergent/divergent/transform boundary card sorts','Punnett Square practice — bring back from B1 since it\'s part of the 7th grade course curriculum but not on B2','Symbiosis card sort: mutualism/commensalism/parasitism with examples','Error-analysis: students explain why distractor answers are wrong'],
      resources:['Stemscopes Florida 7th','PhET simulations','BrainPOP','Mystery Science 7th','Progress Learning skill practice','Khan Academy 7th science modules','Foldables / interactive notebooks']},
    {tier:2,title:'Tier 2 — Targeted Review',students:t2,
      focus:['Refine weakest 3–5 standards per student (use Individual tab)','SC.7.E.6.1 — Earth\'s Layers (cohort priority)','SC.7.L.17.1 — Food Webs (still under 40%)','SC.7.P.10.3 — Wave Speed','SC.7.N.3.1 — Theories and Laws','Review of B1-only standards: SC.7.E.6.6, SC.7.L.16.2 (Punnett Squares), SC.7.L.16.4 (Biotechnology) — still part of 7th grade course curriculum','Test-format familiarity on Progress Learning interface'],
      strategies:['Push-in support during Tier 1 instruction — pull 4–6 students for targeted reteach','Spiral review warm-ups: 5 mixed questions covering weakest standards rotating through the week','Structured error analysis: students explain reasoning verbally and in writing','Peer tutoring: pair Tier 2 with Tier 1 partners for collaborative problem-solving','Spaced retrieval: weekly cumulative quiz on B1-only standards (Punnett Squares, Biotechnology, etc.) since they\'re part of the 7th grade course curriculum and prerequisites for 8th grade','Lab connections: real-world demos for plate tectonics, natural selection, energy transformations'],
      resources:['Progress Learning released items','Stemscopes Florida 7th','BrainPOP review videos','Khan Academy targeted skills','Mystery Science 7th','Florida NGSSS test prep workbook']},
    {tier:1,title:'Tier 1 — Maintenance + Stretch',students:t1,
      focus:['Maintain mastery on standards already at 70%+','Push toward 90%+ on 1–2 weakest individual standards','Stretch: cross-domain connections (plate tectonics → rock cycle → fossil evidence)','For Advanced sections: 8th grade preview — chemistry, atomic structure, periodic table','Build science-test stamina with full-length mixed-standards practice'],
      strategies:['Whole-class rigorous Tier 1 instruction with rich phenomena-based prompts','Science discourse: "How do you know?" with evidence-based reasoning','Full-length B2-style practice 1x in final weeks — review missed items','3-Act science tasks and open-ended phenomenon investigations','Peer tutoring leadership — pair with Tier 2 partners','Stretch tasks: research projects, science fair extensions, cross-curricular STEAM','Self-assessment: students identify their own 1–2 weakest standards and design a study plan'],
      resources:['Mystery Science 7th extension','PhET simulations (advanced)','Florida 8th grade preview standards','Khan Academy science','OpenSciEd middle school units','3-Act science tasks (Janelle Bence)','Argument-Driven Inquiry (ADI)']}
  ];
  document.getElementById('action-plan').innerHTML=plans.map(p=>{const tc={1:'var(--green)',2:'var(--sky)',3:'var(--amber)',4:'var(--rose)'}[p.tier];return `<div class="action-card t${p.tier}"><div class="action-header"><span class="action-tier-badge">Tier ${p.tier}</span><div class="action-title">${p.title}</div></div><div style="margin-bottom:14px"><div class="action-section-title">📌 Priority Students (${p.students.length})</div><div class="action-students">${p.students.map(s=>`<span class="student-chip" style="background:${hashColor(s.n)};cursor:pointer" onclick="openStudent('${s.n.replace(/'/g,"&#39;")}')">${s.n}</span>`).join('')}</div></div><div class="action-body"><div><div class="action-section-title">🎯 Priority Standards Focus</div><ul class="action-list">${p.focus.map(f=>`<li>${f}</li>`).join('')}</ul></div><div><div class="action-section-title">🛠 Intervention Strategies</div><ul class="action-list">${p.strategies.map(s=>`<li>${s}</li>`).join('')}</ul></div></div><div style="margin-top:14px;padding-top:12px;border-top:1px solid ${tc}33"><div class="action-section-title">📚 Recommended Resources</div><div style="display:flex;flex-wrap:wrap;gap:6px">${p.resources.map(r=>`<span style="background:${tc}15;color:${tc};padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:600">${r}</span>`).join('')}</div></div></div>`;}).join('');
}

renderOverview();renderClassView();renderDomainView();renderStandards();filterStudentList();renderTiers();renderActionPlan();
</script>
