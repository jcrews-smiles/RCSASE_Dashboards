// HELPERS
const avg=(a,k)=>{const v=a.map(x=>x[k]).filter(x=>x!=null&&!isNaN(x));return v.length?Math.round(v.reduce((a,b)=>a+b,0)/v.length):0;};
const pct=(n,d)=>d===0?0:Math.round(n/d*100);
const getInitials=n=>n.replace('#','').split(' ').map(w=>w[0]).filter(Boolean).join('').slice(0,2).toUpperCase();
const PALETTE=['#0d9488','#7c3aed','#0369a1','#b45309','#be123c','#065f46','#1d4ed8','#6b21a8'];
function hashColor(s){let h=0;for(let c of s)h=(h*31+c.charCodeAt(0))%PALETTE.length;return PALETTE[h];}
function getTier(s){if(s.b2==null)return 'P';if(s.b2>=65)return 1;if(s.b2>=50)return 2;if(s.b2>=35)return 3;return 4;}
function tierLabel(t){return{1:'Tier 1 – At/Above Benchmark',2:'Tier 2 – Approaching',3:'Tier 3 – On Watch',4:'Tier 4 – Intervention','P':'No B2'}[t];}
function tierColor(t){return{1:'var(--green)',2:'var(--sky)',3:'var(--amber)',4:'var(--rose)','P':'var(--slate)'}[t];}
function scorePillClass(score,has){if(!has||score==null)return 'sp-pend';if(score>=65)return 'sp-bench';if(score>=50)return 'sp-approach';if(score>=35)return 'sp-watch';return 'sp-int';}
function placementBar(label,p,c){return `<div class="placement-bar-wrap"><div class="placement-label"><span>${label}</span><span style="color:${c};font-weight:700">${p}%</span></div><div class="placement-bar-bg"><div class="placement-bar-fill" style="width:${p}%;background:${c}"></div></div></div>`;}
function studentStandards(stu){return STANDARDS.map((std,i)=>({c:std.c,desc:std.d,domain:std.dom,b1:stu.s[i][0],b2:stu.s[i][1],delta:(stu.s[i][1]!=null&&stu.s[i][0]!=null)?stu.s[i][1]-stu.s[i][0]:null}));}

