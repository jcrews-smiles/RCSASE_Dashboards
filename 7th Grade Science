    <div class="stat-card" style="--accent:var(--green)"><div class="stat-label">At/Above (T1)</div><div class="stat-value" style="color:var(--green)">${tier1}</div><div class="stat-detail">${pct(tier1,stu.length)}% of class</div></div>
    <div class="stat-card" style="--accent:var(--rose)"><div class="stat-label">Intervention (T4)</div><div class="stat-value" style="color:var(--rose)">${tier4}</div><div class="stat-detail">B2 below 35%</div></div>
