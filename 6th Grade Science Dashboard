function showClass(p,btn){document.querySelectorAll('#class-tabs .dom-tab').forEach(b=>b.classList.remove('active'));if(btn)btn.classList.add('active');showClassData(p);}
function showClassData(period){
  const stu=STUDENTS.filter(s=>s.p===period);
  const withB2=stu.filter(s=>s.b2!=null);const withBoth=stu.filter(s=>s.b1!=null&&s.b2!=null);
  const b1A=avg(stu,'b1');const b2A=avg(withB2,'b2');const gain=b2A-b1A;
  const tier1=stu.filter(s=>getTier(s)===1).length;
  const tier4=stu.filter(s=>getTier(s)===4).length;
  const adv=stu[0]&&stu[0].a;
  const teacher=stu[0]?stu[0].t:'';
  
  // Per-domain class averages
  const domains=[...new Set(STANDARDS.map(x=>x.dom))];
  const domainRows=domains.map(d=>{
    const stds=STANDARDS.map((s,i)=>({...s,idx:i})).filter(x=>x.dom===d);
    const b1Vals=stu.flatMap(st=>stds.map(s=>st.s[s.idx][0]).filter(v=>v!=null));
    const b2Vals=stu.flatMap(st=>stds.map(s=>st.s[s.idx][1]).filter(v=>v!=null));
    const b1Avg=b1Vals.length?Math.round(b1Vals.reduce((a,b)=>a+b,0)/b1Vals.length):0;
    const b2Avg=b2Vals.length?Math.round(b2Vals.reduce((a,b)=>a+b,0)/b2Vals.length):0;
    const c=b2Avg>=70?'var(--green)':b2Avg>=55?'var(--sky)':b2Avg>=40?'var(--amber)':'var(--rose)';
    return `<div><div class="domain-name"><span>${d}</span><span style="font-weight:700;color:${c}">B1 ${b1Avg}% → B2 ${b2Avg}%</span></div><div class="domain-bar-bg"><div class="domain-bar-fill" style="width:${b2Avg}%;background:${c}">${b2Avg}%</div><div class="domain-bar-benchmark" style="left:65%"></div></div></div>`;
  }).join('');
  
