function renderTiers() {
  const el = document.getElementById('tab-tiers');
  const tier3 = S.filter(s => getTier(s) === 3).sort((a,b) => (a.v3_score || 0) - (b.v3_score || 0));
  const tier2 = S.filter(s => getTier(s) === 2).sort((a,b) => (a.v3_score || 0) - (b.v3_score || 0));
  const tier1 = S.filter(s => getTier(s) === 1).sort((a,b) => (b.v3_score || 0) - (a.v3_score || 0));

  function gaps(s) {
    const g = [];
    DOMAINS.forEach(d => {
      const v3 = s.dom_v3[d.key];
      if (v3 !== null && v3 < 60) g.push(d.short);
    });
    if (s.gain !== null && s.gain <= -10) g.push('Major Regression');
    if (s.v3_score !== null && s.v3_score < 50) g.push('Far Below');
    return g;
  }

  function stuList(arr) {
    return arr.map(s => `<li class="t-student">
      <div class="t-av" style="background:${hColor(s.name)}">${getInits(s.name)}</div>
      <div class="t-info">
        <div class="t-sname">${s.name}</div>
        <div class="t-room">${CLASS_LABELS[s.classp] || s.classp} · V3: ${s.v3_score !== null ? s.v3_score : '–'} · ${masteryLabel(masteryLevel(s.v3_score))}</div>
        ${gaps(s).length ? `<div class="t-gaps">${gaps(s).map(g => `<span class="gtag" style="background:#fee2e2;color:#9f1239">${g}</span>`).join('')}</div>` : ''}
      </div>
      <div style="text-align:right;flex-shrink:0">
        <div style="font-weight:900;font-size:.73rem;color:${gainColor(s.gain)}">${s.gain === null ? '–' : (s.gain > 0 ? '+' : '') + s.gain}</div>
        <div style="font-size:.6rem;color:#64748b">pts</div>
      </div>
    </li>`).join('');
  }

  el.innerHTML = `
  <div class="sec-title">Tiered Support Placement</div>
  <div class="sec-sub">Students grouped by intervention need based on V3 mastery and V1→V3 growth · ${S.length} students total</div>
  <div class="leg-row">
    <div class="leg-item"><div class="leg-dot" style="background:#15803d"></div><strong>Tier 1</strong> – V3 ≥ 70% with stable/positive growth (on track for EOC)</div>
    <div class="leg-item"><div class="leg-dot" style="background:#d97706"></div><strong>Tier 2</strong> – V3 60–69% (approaching) or mild regression</div>
    <div class="leg-item"><div class="leg-dot" style="background:#be123c"></div><strong>Tier 3</strong> – V3 &lt; 60% or significant regression (≥10 pts loss)</div>
  </div>
  <div class="tier-grid">
    <div class="tcard t3"><div class="t-hd"><div class="t-num">3</div><div><div class="t-title">Intensive Support</div><div class="t-count">${tier3.length} students · V3 &lt; 60% or major regression</div></div></div>
      <ul class="t-slist">${stuList(tier3)}</ul></div>
    <div class="tcard t2"><div class="t-hd"><div class="t-num">2</div><div><div class="t-title">Strategic Support</div><div class="t-count">${tier2.length} students · Approaching proficiency</div></div></div>
      <ul class="t-slist">${stuList(tier2)}</ul></div>
    <div class="tcard t1"><div class="t-hd"><div class="t-num">1</div><div><div class="t-title">On Track / Enrichment</div><div class="t-count">${tier1.length} students · Meeting/exceeding EOC target</div></div></div>
      <ul class="t-slist">${stuList(tier1)}</ul></div>
  </div>
  <div class="card"><div class="card-title"><div class="cicon" style="background:#f0fdf4">📊</div>Tier Summary by Class Period</div>
    <table class="stbl2"><thead><tr><th>Class</th><th>Total</th><th>Tier 1</th><th>Tier 2</th><th>Tier 3</th><th>V3 Avg</th><th>Avg Gain</th><th>% Passing (≥70)</th></tr></thead>
    <tbody>${CLASSES.map(r => {
