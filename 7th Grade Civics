  </div>

  <div class="card" style="margin-bottom:18px">
    <div class="card-title"><div class="cicon" style="background:#fee2e2">🚨</div>Class-Wide Priority Standards (V3 mastery &lt; 60%)</div>
    <div style="font-size:.78rem;color:#475569;margin-bottom:12px">These ${classGaps.length} standards need whole-class re-teach before EOC. Sorted by lowest mastery first.</div>
    <div class="stbl-wrap"><table class="stbl">
      <thead><tr><th>Standard</th><th>Topic</th><th>V1 Avg</th><th>V3 Avg</th><th>Change</th><th>Priority Move</th></tr></thead>
      <tbody>${classGaps.map(s => {
        let move = 'Re-teach via direct instruction';
        if (s.gain !== null && s.gain <= -15) move = '⚠️ URGENT: Major regression — re-teach with retrieval practice';
        else if (s.v3_avg < 50) move = '⚠️ Far below — small group instruction needed';
        return `<tr>
          <td><span class="scode">${s.code}</span></td>
          <td style="font-weight:700">${s.name}</td>
          <td>${s.v1_avg !== null ? s.v1_avg + '%' : '–'}</td>
          <td style="font-weight:800;color:${scoreColor(s.v3_avg)}">${s.v3_avg !== null ? s.v3_avg + '%' : '–'}</td>
          <td class="${s.gain === null ? 'gain-zero' : s.gain > 0 ? 'gain-pos' : s.gain < 0 ? 'gain-neg' : 'gain-zero'}">${s.gain === null ? '–' : (s.gain > 0 ? '+' : '') + s.gain}</td>
          <td style="font-size:.7rem">${move}</td>
        </tr>`;
      }).join('')}</tbody>
    </table></div>
  </div>

  ${plans.map(p => `<div class="acard t${p.tier}">
    <div class="a-hd"><span class="a-badge">Tier ${p.tier}</span><div class="a-title">${p.title}</div></div>
    <div style="margin-bottom:12px">
      <div class="a-sec">📌 Students in This Tier (${p.students.length})</div>
      <div class="a-students">${p.students.map(s => `<span class="schip" style="background:${hColor(s.name)}">${s.name}</span>`).join('')}</div>
    </div>
    <div class="a-body">
      <div><div class="a-sec">🎯 Priority SS.7.CG Standards Focus</div><ul class="a-list">${p.focus.map(f => `<li>${f}</li>`).join('')}</ul></div>
      <div><div class="a-sec">🛠 Intervention Strategies</div><ul class="a-list">${p.strategies.map(s => `<li>${s}</li>`).join('')}</ul></div>
    </div>
    <div style="margin-top:12px;padding-top:10px;border-top:1px solid ${tcol(p.tier)}33">
      <div class="a-sec">📚 Recommended Resources</div>
      <div style="display:flex;flex-wrap:wrap;gap:5px">${p.resources.map(r => `<span style="background:${tcol(p.tier)}15;color:${tcol(p.tier)};padding:3px 9px;border-radius:20px;font-size:.68rem;font-weight:700">${r}</span>`).join('')}</div>
    </div>
  </div>`).join('')}`;
}

// ════════════════════════════════════════
// RENDER MAP
// ════════════════════════════════════════
const renders = {
  overview: renderOverview,
  class: renderClass,
  standards: renderStandards,
  individual: renderIndividual,
  tiers: renderTiers,
  action: renderAction
};
renderOverview();
document.getElementById('tab-overview').dataset.rendered = '1';
</script>
</body>
</html>
