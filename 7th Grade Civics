      const passing = withV3.filter(x => x.v3_score >= 70).length;
      return `<tr>
        <td style="font-weight:800"><span style="display:inline-block;width:11px;height:11px;border-radius:50%;background:${CCOL[r]};margin-right:5px;vertical-align:middle"></span>${CLASS_LABELS[r] || r}</td>
