function filterStu() {
  const q = (document.getElementById('ssearch') || {}).value?.toLowerCase() || '';
  const room = (document.getElementById('sroom') || {}).value || '';
  const tier = parseInt((document.getElementById('stier') || {}).value) || 0;
  filtStu = S.filter(s => {
    const mq = s.name.toLowerCase().includes(q) || s.first.toLowerCase().includes(q);
    const mr = !room || s.classp === room;
    const mt = !tier || getTier(s) === tier;
    return mq && mr && mt;
  }).sort((a,b) => a.name.localeCompare(b.name));
  renderStuList();
}

