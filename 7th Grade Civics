<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>7th Grade Civics EOC Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1625;
    --ink2: #2d2540;
    --plum: #6d28d9;
    --plum-lt: #ede9fe;
    --amber: #d97706;
    --amber-lt: #fef3c7;
    --rose: #be123c;
    --rose-lt: #ffe4e6;
    --teal: #0f766e;
    --teal-lt: #ccfbf1;
    --sky: #0284c7;
    --sky-lt: #e0f2fe;
    --green: #15803d;
    --green-lt: #dcfce7;
    --slate: #64748b;
    --paper: #faf9f7;
    --white: #ffffff;
    --card-shadow: 0 2px 16px rgba(26,22,37,0.10);
    --t1: #15803d; --t2: #d97706; --t3: #be123c;
    /* Civics domain colors */
    --d-origins: #b45309;
    --d-roles: #6d28d9;
    --d-organization: #0f766e;
    --d-policies: #0284c7;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Source Sans 3',sans-serif; background:var(--paper); color:var(--ink); min-height:100vh; }

  /* HEADER */
  header { background:var(--ink); color:#fff; position:sticky; top:0; z-index:100; box-shadow:0 3px 20px rgba(0,0,0,.4); }
  .header-inner { display:flex; align-items:center; justify-content:space-between; padding:12px 32px; gap:20px; flex-wrap:wrap; }
  .htitle h1 { font-family:'Playfair Display',serif; font-size:1.4rem; letter-spacing:.2px; }
  .htitle span { font-size:.72rem; color:#a78bfa; font-weight:600; letter-spacing:.9px; text-transform:uppercase; display:block; margin-top:2px; }
  .cdown { display:flex; align-items:center; gap:14px; background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.1); border-radius:10px; padding:10px 18px; }
  .cdown-lbl { font-size:.68rem; text-transform:uppercase; letter-spacing:1px; color:#a78bfa; font-weight:700; }
  .cdown-num { font-family:'Playfair Display',serif; font-size:2.2rem; line-height:1; color:#fbbf24; }
  .cdown-sub { font-size:.62rem; color:#94a3b8; margin-top:1px; }
  .cdown-date { font-size:.73rem; color:#fde68a; font-weight:600; }
  .tab-nav { display:flex; background:var(--ink2); padding:0 32px; border-bottom:2px solid rgba(255,255,255,.06); overflow-x:auto; }
  .tab-btn { background:none; border:none; color:#94a3b8; padding:10px 20px; font-family:'Source Sans 3',sans-serif; font-size:.8rem; font-weight:700; cursor:pointer; border-bottom:3px solid transparent; transition:all .2s; white-space:nowrap; letter-spacing:.5px; text-transform:uppercase; }
  .tab-btn:hover { color:#fff; }
  .tab-btn.active { color:#c4b5fd; border-bottom-color:#7c3aed; }

  /* MAIN */
  main { padding:26px 32px; max-width:1600px; margin:0 auto; }
  .tab-pane { display:none; animation:fadeUp .3s ease; }
  .tab-pane.active { display:block; }
  @keyframes fadeUp { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }

  .sec-title { font-family:'Playfair Display',serif; font-size:1.45rem; margin-bottom:5px; }
  .sec-sub { font-size:.82rem; color:var(--slate); margin-bottom:22px; }

  /* STAT CARDS */
  .stat-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:14px; margin-bottom:26px; }
  .stat-card { background:#fff; border-radius:12px; padding:16px 18px; box-shadow:var(--card-shadow); border-top:4px solid var(--acc,#7c3aed); }
  .stat-lbl { font-size:.68rem; text-transform:uppercase; letter-spacing:.8px; color:var(--slate); font-weight:700; margin-bottom:7px; }
  .stat-val { font-family:'Playfair Display',serif; font-size:1.9rem; line-height:1; color:var(--acc,#7c3aed); margin-bottom:3px; }
  .stat-det { font-size:.72rem; color:var(--slate); }

  /* LAYOUTS */
  .two-col { display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-bottom:18px; }
  .three-col { display:grid; grid-template-columns:1fr 1fr 1fr; gap:18px; margin-bottom:18px; }
  @media(max-width:900px){.two-col,.three-col{grid-template-columns:1fr}}

  /* CARD */
  .card { background:#fff; border-radius:14px; padding:20px 22px; box-shadow:var(--card-shadow); }
  .card-title { font-family:'Playfair Display',serif; font-size:1rem; margin-bottom:14px; display:flex; align-items:center; gap:9px; }
  .cicon { width:26px; height:26px; border-radius:6px; display:flex; align-items:center; justify-content:center; font-size:.8rem; flex-shrink:0; }

  /* BARS */
  .pbar-wrap { margin-bottom:9px; }
  .pbar-top { font-size:.73rem; font-weight:700; display:flex; justify-content:space-between; margin-bottom:3px; }
  .pbar-bg { background:#e2e8f0; border-radius:5px; height:9px; overflow:hidden; }
  .pbar-fill { height:100%; border-radius:5px; transition:width .8s ease; }
  .dbar-wrap { display:flex; flex-direction:column; gap:9px; }
  .dbar-row {}
  .dbar-name { font-size:.72rem; font-weight:700; color:var(--slate); margin-bottom:2px; display:flex; justify-content:space-between; }
  .dbar-bg { background:#e2e8f0; border-radius:5px; height:20px; position:relative; overflow:hidden; }
  .dbar-fill { height:100%; border-radius:5px; display:flex; align-items:center; justify-content:flex-end; padding-right:7px; font-size:.63rem; color:#fff; font-weight:800; }
  .dbar-bench { position:absolute; top:0; bottom:0; width:2px; background:#be123c; }

  /* STANDARDS TABLE */
  .stbl { width:100%; border-collapse:collapse; font-size:.76rem; }
  .stbl th { background:var(--ink); color:#fff; padding:8px 11px; text-align:left; font-size:.68rem; font-weight:700; letter-spacing:.5px; text-transform:uppercase; }
  .stbl td { padding:7px 11px; border-bottom:1px solid #f1f5f9; vertical-align:top; }
  .stbl tr:hover td { background:#fafaf9; }
  .scode { font-family:monospace; font-size:.68rem; background:#e0f2fe; color:#0369a1; padding:2px 6px; border-radius:4px; white-space:nowrap; font-weight:700; }
  .gpill { display:inline-block; padding:2px 7px; border-radius:20px; font-size:.63rem; font-weight:800; }
  .ghi { background:#ffe4e6; color:#9f1239; }
  .gmd { background:#fef3c7; color:#92400e; }
  .glo { background:#bbf7d0; color:#14532d; }

  /* STUDENT TABLE */
  .stbl-wrap { overflow-x:auto; }
  .stbl2 { width:100%; border-collapse:collapse; font-size:.75rem; }
  .stbl2 th { background:var(--ink); color:#fff; padding:8px 10px; text-align:left; font-size:.67rem; text-transform:uppercase; font-weight:700; letter-spacing:.4px; white-space:nowrap; cursor:pointer; }
  .stbl2 th:hover { background:#2d2540; }
  .stbl2 td { padding:7px 10px; border-bottom:1px solid #f1f5f9; white-space:nowrap; }
  .stbl2 tr:hover td { background:#f8f9fa; }
  /* score pills */
  .ptag { display:inline-block; padding:2px 8px; border-radius:20px; font-size:.64rem; font-weight:800; }
  .p-mast { background:#bbf7d0; color:#14532d; }       /* 80-100 */
  .p-prof { background:#d1fae5; color:#065f46; }        /* 70-79 */
  .p-app  { background:#fef9c3; color:#713f12; }        /* 60-69 */
  .p-bel  { background:#ffe4e6; color:#881337; }        /* 50-59 */
  .p-far  { background:#fce7f3; color:#701a75; }        /* <50 */
  .p-na   { background:#f1f5f9; color:#64748b; }

  /* CLASS TABS */
  .hr-tabs { display:flex; gap:0; border-bottom:2px solid #e2e8f0; margin-bottom:20px; flex-wrap:wrap; }
  .hr-tab { padding:8px 18px; background:none; border:none; font-family:'Source Sans 3',sans-serif; font-size:.78rem; font-weight:700; cursor:pointer; color:var(--slate); border-bottom:3px solid transparent; margin-bottom:-2px; transition:all .2s; }
  .hr-tab.active { color:var(--plum); border-bottom-color:var(--plum); }
  .hr-tab:hover { color:var(--ink); }

  /* INDIVIDUAL */
  .srch-bar { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:18px; }
  .sinput { flex:1; min-width:200px; border:2px solid #e2e8f0; border-radius:10px; padding:9px 14px; font-family:'Source Sans 3',sans-serif; font-size:.86rem; outline:none; transition:border .2s; }
  .sinput:focus { border-color:var(--plum); }
  .sselect { border:2px solid #e2e8f0; border-radius:10px; padding:9px 12px; font-family:'Source Sans 3',sans-serif; font-size:.82rem; outline:none; background:#fff; cursor:pointer; }
  .slist-item { padding:8px 11px; border-radius:7px; cursor:pointer; border:1px solid #e2e8f0; display:flex; align-items:center; gap:7px; transition:background .15s; background:#fff; }
  .slist-item:hover { background:#f5f3ff; }
  .no-sel { text-align:center; padding:60px 20px; color:var(--slate); }
  .no-sel .big { font-size:2.5rem; margin-bottom:10px; }

  .profile-wrap { background:#fff; border-radius:16px; padding:26px; box-shadow:var(--card-shadow); display:none; }
  .prof-hd { display:flex; align-items:center; gap:18px; margin-bottom:22px; padding-bottom:18px; border-bottom:2px solid #f1f5f9; flex-wrap:wrap; }
  .prof-av { width:60px; height:60px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Playfair Display',serif; font-size:1.5rem; color:#fff; flex-shrink:0; }
  .prof-name { font-family:'Playfair Display',serif; font-size:1.4rem; }
  .prof-meta { font-size:.78rem; color:var(--slate); margin-top:3px; }
  .prof-chips { display:flex; gap:7px; flex-wrap:wrap; margin-top:7px; }
  .pchip { padding:3px 11px; border-radius:20px; font-size:.7rem; font-weight:700; }
  .pmet-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(130px,1fr)); gap:12px; margin-bottom:18px; }
  .pmet { background:#f8f9fa; border-radius:9px; padding:12px; text-align:center; }
  .pm-lbl { font-size:.63rem; text-transform:uppercase; letter-spacing:.7px; color:var(--slate); font-weight:700; margin-bottom:5px; }
  .pm-val { font-family:'Playfair Display',serif; font-size:1.5rem; line-height:1; }
  .pm-sub { font-size:.65rem; color:var(--slate); margin-top:2px; }
  .dom-grid { display:grid; grid-template-columns:1fr 1fr; gap:11px; margin-bottom:18px; }
  .dcard { background:#f8f9fa; border-radius:9px; padding:12px 14px; border-left:4px solid; }
  .dc-title { font-size:.68rem; font-weight:800; text-transform:uppercase; letter-spacing:.6px; color:var(--slate); margin-bottom:5px; }
  .dc-place { font-weight:700; font-size:.85rem; margin-bottom:3px; }
  .dc-score { font-size:.72rem; color:var(--slate); }
  .std-match-item { font-size:.68rem; padding:3px 0; border-top:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center; gap:6px; }
  .gbr-row { display:flex; align-items:center; gap:11px; margin-bottom:9px; }
  .gbr-lbl { font-size:.7rem; font-weight:700; width:160px; flex-shrink:0; color:var(--slate); }
  .gbr-bg { flex:1; background:#e2e8f0; border-radius:5px; height:16px; position:relative; overflow:hidden; }
  .gbr-fill { height:100%; border-radius:5px; display:flex; align-items:center; justify-content:flex-end; padding-right:5px; font-size:.6rem; color:#fff; font-weight:800; }

  /* TIERS */
  .tier-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; margin-bottom:22px; }
  @media(max-width:880px){.tier-grid{grid-template-columns:1fr}}
  .tcard { border-radius:13px; padding:18px 20px; box-shadow:var(--card-shadow); border-top:5px solid; }
  .tcard.t1 { background:#f0fdf4; border-color:var(--green); }
  .tcard.t2 { background:#fffbeb; border-color:var(--amber); }
  .tcard.t3 { background:#fff1f2; border-color:var(--rose); }
  .t-hd { display:flex; align-items:center; gap:9px; margin-bottom:12px; }
  .t-num { width:34px; height:34px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:900; font-size:.95rem; color:#fff; flex-shrink:0; }
  .tcard.t1 .t-num { background:var(--green); }
  .tcard.t2 .t-num { background:var(--amber); }
  .tcard.t3 .t-num { background:var(--rose); }
  .t-title { font-family:'Playfair Display',serif; font-size:.95rem; }
  .t-count { font-size:.75rem; color:var(--slate); margin-top:1px; }
  .t-slist { list-style:none; display:flex; flex-direction:column; gap:7px; max-height:560px; overflow-y:auto; }
  .t-student { background:#fff; border-radius:7px; padding:9px 12px; display:flex; align-items:flex-start; gap:8px; box-shadow:0 1px 4px rgba(0,0,0,.05); }
  .t-av { width:30px; height:30px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:800; font-size:.68rem; color:#fff; flex-shrink:0; }
  .t-info { flex:1; min-width:0; }
  .t-sname { font-weight:800; font-size:.77rem; }
  .t-room { font-size:.65rem; color:var(--slate); }
  .t-gaps { margin-top:3px; display:flex; flex-wrap:wrap; gap:3px; }
  .gtag { font-size:.6rem; padding:1px 5px; border-radius:3px; font-weight:700; }

  /* ACTION PLAN */
  .acard { background:#fff; border-radius:13px; padding:20px 22px; box-shadow:var(--card-shadow); margin-bottom:16px; border-left:5px solid; }
  .acard.t3 { border-color:var(--rose); }
  .acard.t2 { border-color:var(--amber); }
  .acard.t1 { border-color:var(--green); }
  .a-hd { display:flex; align-items:center; gap:11px; margin-bottom:12px; }
  .a-badge { padding:3px 11px; border-radius:20px; font-size:.7rem; font-weight:900; text-transform:uppercase; letter-spacing:.4px; }
  .t3 .a-badge { background:var(--rose); color:#fff; }
  .t2 .a-badge { background:var(--amber); color:#fff; }
  .t1 .a-badge { background:var(--green); color:#fff; }
  .a-title { font-family:'Playfair Display',serif; font-size:1.03rem; }
  .a-body { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  @media(max-width:760px){.a-body{grid-template-columns:1fr}}
  .a-sec { font-size:.68rem; text-transform:uppercase; letter-spacing:.7px; font-weight:800; color:var(--slate); margin-bottom:7px; }
  .a-list { list-style:none; display:flex; flex-direction:column; gap:5px; }
  .a-list li { font-size:.76rem; display:flex; gap:7px; line-height:1.45; }
  .a-list li::before { content:'▸'; color:var(--plum); flex-shrink:0; margin-top:1px; }
  .a-students { display:flex; flex-wrap:wrap; gap:5px; margin-top:9px; }
  .schip { background:var(--ink); color:#fff; border-radius:20px; padding:3px 10px; font-size:.68rem; font-weight:700; }

  /* DAYS BEFORE TEST PLAN */
  .timeline { display:flex; flex-direction:column; gap:13px; }
  .tl-row { background:#fff; border-radius:11px; padding:14px 18px; box-shadow:var(--card-shadow); border-left:4px solid; display:grid; grid-template-columns:90px 1fr; gap:14px; align-items:flex-start; }
  .tl-time { font-family:'Playfair Display',serif; font-size:1rem; color:var(--ink); font-weight:700; }
  .tl-time-sub { font-size:.65rem; color:var(--slate); text-transform:uppercase; font-weight:700; letter-spacing:.5px; margin-top:2px; }
  .tl-body { font-size:.78rem; }
  .tl-headline { font-weight:800; margin-bottom:5px; font-size:.85rem; }
  .tl-list { list-style:none; display:flex; flex-direction:column; gap:3px; padding-left:0; }
  .tl-list li { font-size:.74rem; display:flex; gap:6px; line-height:1.4; color:#334155; }
  .tl-list li::before { content:'•'; color:inherit; flex-shrink:0; }

  .leg-row { display:flex; gap:14px; flex-wrap:wrap; margin-bottom:18px; }
  .leg-item { display:flex; align-items:center; gap:5px; font-size:.7rem; color:var(--slate); }
  .leg-dot { width:9px; height:9px; border-radius:50%; flex-shrink:0; }
  ::-webkit-scrollbar { width:5px; height:5px; }
  ::-webkit-scrollbar-track { background:#f1f5f9; }
  ::-webkit-scrollbar-thumb { background:#94a3b8; border-radius:3px; }

  /* Score cell coloring */
  .scell { font-weight:800; }
  .sc-h { color:#15803d; }
  .sc-m { color:#0284c7; }
  .sc-l { color:#d97706; }
  .sc-vl { color:#be123c; }
  .gain-pos { color:#15803d; font-weight:800; }
  .gain-neg { color:#be123c; font-weight:800; }
  .gain-zero { color:#64748b; font-weight:800; }
</style>
</head>
<body>

<header>
  <div class="header-inner">
    <div class="htitle">
      <h1>7th Grade Civics EOC Dashboard</h1>
      <span>Civics EOC (NGSSS) Practice · Progress Learning · Barnes · SS.7.CG Standards</span>
    </div>
    <div class="cdown">
      <div>
        <div class="cdown-lbl">Civics EOC Countdown</div>
        <div class="cdown-date">May 15, 2026</div>
      </div>
      <div style="display:flex;gap:9px;align-items:flex-end">
        <div style="text-align:center">
          <div class="cdown-num" id="cd-days">--</div>
          <div class="cdown-sub">days</div>
        </div>
        <div style="text-align:center;opacity:.75">
          <div style="font-family:'Playfair Display',serif;font-size:1.5rem;color:#fbbf24;line-height:1" id="cd-hrs">--</div>
          <div class="cdown-sub">hrs</div>
        </div>
        <div style="text-align:center;opacity:.75">
          <div style="font-family:'Playfair Display',serif;font-size:1.5rem;color:#fbbf24;line-height:1" id="cd-min">--</div>
          <div class="cdown-sub">min</div>
        </div>
        <div style="text-align:center;opacity:.6">
          <div style="font-family:'Playfair Display',serif;font-size:1.5rem;color:#fbbf24;line-height:1" id="cd-sec">--</div>
          <div class="cdown-sub">sec</div>
        </div>
      </div>
    </div>
  </div>
  <nav class="tab-nav">
    <button class="tab-btn active" onclick="showTab('overview',this)">📊 Overview</button>
    <button class="tab-btn" onclick="showTab('class',this)">🏫 Class View</button>
    <button class="tab-btn" onclick="showTab('standards',this)">📋 Standards &amp; Gaps</button>
    <button class="tab-btn" onclick="showTab('individual',this)">👤 Individual</button>
    <button class="tab-btn" onclick="showTab('tiers',this)">🎯 Tier Placement</button>
    <button class="tab-btn" onclick="showTab('action',this)">📝 Action Plan</button>
  </nav>
</header>

<main>
<div id="tab-overview" class="tab-pane active"></div>
<div id="tab-class" class="tab-pane"></div>
<div id="tab-standards" class="tab-pane"></div>
<div id="tab-individual" class="tab-pane"></div>
<div id="tab-tiers" class="tab-pane"></div>
<div id="tab-action" class="tab-pane"></div>
</main>

