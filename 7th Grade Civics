function priorityLevel(stdRow) {
  if (!stdRow.v3_avg) return 'High';
  // High priority: V3 mastery <60% OR significant regression OR critical EOC content
  if (stdRow.v3_avg < 60) return 'High';
  if (stdRow.gain !== null && stdRow.gain <= -10) return 'High';
  if (stdRow.v3_avg < 70) return 'Med';
  return 'Low';
}

