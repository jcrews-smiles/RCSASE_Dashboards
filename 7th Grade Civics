  }));

  const highPri = enriched.filter(s => s.priority === 'High').sort((a,b) => (a.v3_avg||0) - (b.v3_avg||0));
  const lowPri = enriched.filter(s => s.priority === 'Low').sort((a,b) => (b.v3_avg||0) - (a.v3_avg||0));

