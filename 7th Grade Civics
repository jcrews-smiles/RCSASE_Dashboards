    }).join('')}</div>
  </div>

  <div class="stbl-wrap">
    <table class="stbl2">
      <thead><tr><th>Student</th><th>V1 Score</th><th>V3 Score</th><th>Gain</th><th>Origins</th><th>Roles</th><th>Organization</th><th>Policies</th><th>Tier</th></tr></thead>
      <tbody>${rs.map(s => {
        const t = getTier(s);
        const tc2 = tcol(t);
        const fmt = (v) => v === null ? '–' : v;
        const pillFor = (v) => v === null ? '<span class="ptag p-na">–</span>' : `<span class="ptag p-${masteryLevel(v)}">${Math.round(v)}</span>`;
        return `<tr>
          <td style="font-weight:800">${s.name}</td>
          <td>${fmt(s.v1_score)}</td>
          <td style="font-weight:800;color:${scoreColor(s.v3_score)}">${fmt(s.v3_score)}</td>
          <td class="${s.gain===null?'gain-zero':s.gain>0?'gain-pos':s.gain<0?'gain-neg':'gain-zero'}">${s.gain===null?'–':(s.gain>0?'+':'')+s.gain}</td>
          <td>${pillFor(s.dom_v3.origins)}</td>
          <td>${pillFor(s.dom_v3.roles)}</td>
          <td>${pillFor(s.dom_v3.organization)}</td>
          <td>${pillFor(s.dom_v3.policies)}</td>
          <td><span style="background:${tc2}22;color:${tc2};padding:2px 8px;border-radius:20px;font-size:.66rem;font-weight:900">T${t}</span></td>
        </tr>`;
      }).join('')}</tbody>
    </table>
  </div>`;
}

