function showHRData(room) {
  const rs = S.filter(s => s.classp === room).sort((a,b) => (b.v3_score || 0) - (a.v3_score || 0));
  const c = CCOL[room] || '#64748b';
  const withV3 = rs.filter(x => x.v3_score !== null);
  const withBoth = rs.filter(x => x.v1_score !== null && x.v3_score !== null);

  const avgV1 = avg(rs.filter(x=>x.v1_score!==null), 'v1_score');
  const avgV3 = avg(withV3, 'v3_score');
  const avgG = avg(withBoth, 'gain');
  const passing = withV3.filter(x => x.v3_score >= 70).length;

  // Mastery distribution
  const mastBuckets = [
    {l:'Mastery (80+)',min:80,max:100,c:'#15803d'},
    {l:'Proficient (70-79)',min:70,max:79.99,c:'#0284c7'},
    {l:'Approaching (60-69)',min:60,max:69.99,c:'#d97706'},
    {l:'Below (<60)',min:0,max:59.99,c:'#be123c'},
  ];

  // Domain averages for this class
  const domAvgs = DOMAINS.map(d => {
    const v1s = rs.map(s => s.dom_v1[d.key]).filter(x => x !== null);
    const v3s = rs.map(s => s.dom_v3[d.key]).filter(x => x !== null);
    return {
      ...d,
      v1: v1s.length ? Math.round(v1s.reduce((a,b)=>a+b,0)/v1s.length*10)/10 : null,
      v3: v3s.length ? Math.round(v3s.reduce((a,b)=>a+b,0)/v3s.length*10)/10 : null
    };
  });

  document.getElementById('hr-body').innerHTML = `
  <div style="background:${CBCOL[room] || '#f1f5f9'};border-left:4px solid ${c};padding:12px 16px;border-radius:8px;margin-bottom:18px;display:flex;align-items:center;gap:12px;flex-wrap:wrap">
    <div style="flex:1;min-width:0">
      <div style="font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;color:${c}">${room}</div>
      <div style="font-size:.72rem;color:#64748b;margin-top:2px">${isAdv(room) ? '🎓 Advanced (CP Adv) section' : '📘 Standard (CP) section'} · ${rs.length} students enrolled</div>
    </div>
  </div>
  <div class="stat-grid">
    ${[
      {l:'Students',v:rs.length,d:'in class'},
      {l:'V1 Avg',v:avgV1,d:'Practice Test 1'},
      {l:'V3 Avg',v:avgV3,d:'Practice Test 3'},
      {l:'Avg Gain',v:(avgG>=0?'+':'')+avgG,d:'V1 → V3 growth'},
      {l:'Projected Passing',v:passing+'/'+withV3.length,d:pct(passing,withV3.length)+'% at 70+'}
    ].map(x => `<div class="stat-card" style="--acc:${c}"><div class="stat-lbl">${x.l}</div><div class="stat-val">${x.v}</div><div class="stat-det">${x.d}</div></div>`).join('')}
  </div>

  <div class="two-col">
    <div class="card"><div class="card-title"><div class="cicon" style="background:${CBCOL[room] || '#f1f5f9'}">📊</div>Mastery Distribution</div>
      ${mastBuckets.map(b => {
        const n = withV3.filter(x => x.v3_score >= b.min && x.v3_score <= b.max).length;
        return pBar(b.l + ` (${n})`, pct(n, withV3.length), b.c);
      }).join('')}
    </div>
    <div class="card"><div class="card-title"><div class="cicon" style="background:#fef3c7">🎯</div>Tier Breakdown</div>
      ${[3,2,1].map(t => {
        const n = rs.filter(s => getTier(s) === t).length;
        const pv = pct(n, rs.length);
        const lbl = {3:'Tier 3 – Intensive',2:'Tier 2 – Strategic',1:'Tier 1 – On Track'}[t];
        const tc = {3:'#be123c',2:'#d97706',1:'#15803d'}[t];
        return pBar(lbl + ` (${n})`, pv, tc);
      }).join('')}
    </div>
  </div>

  <div class="card" style="margin-bottom:18px">
    <div class="card-title"><div class="cicon" style="background:${CBCOL[room] || '#f1f5f9'}">📈</div>Reporting Category Performance for ${room}</div>
    <div class="dbar-wrap">${domAvgs.map(d => {
      const v3 = d.v3 || 0;
      const lvlc = v3 >= 70 ? '#15803d' : v3 >= 60 ? '#d97706' : '#be123c';
      const gain = d.v3 !== null && d.v1 !== null ? (Math.round((d.v3 - d.v1)*10)/10) : null;
