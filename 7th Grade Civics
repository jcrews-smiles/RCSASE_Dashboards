function masteryLevel(score) {
  if (score === null || score === undefined || isNaN(score)) return 'na';
  if (score >= 80) return 'mast';
  if (score >= 70) return 'prof';
  if (score >= 60) return 'app';
  if (score >= 50) return 'bel';
  return 'far';
}
function masteryLabel(lvl) {
  return {mast:'Mastery',prof:'Proficient',app:'Approaching',bel:'Below',far:'Far Below',na:'N/A'}[lvl];
}
function scoreColor(s) {
  if (s === null || s === undefined || isNaN(s)) return '#94a3b8';
  if (s >= 80) return '#15803d';
  if (s >= 70) return '#0284c7';
  if (s >= 60) return '#d97706';
  if (s >= 50) return '#be123c';
  return '#9f1239';
}
function gainColor(g) {
  if (g === null || g === undefined) return '#64748b';
  if (g >= 10) return '#15803d';
  if (g >= 5) return '#0284c7';
  if (g >= 0) return '#64748b';
  if (g >= -10) return '#d97706';
  return '#be123c';
}

function getTier(s) {
  const v3 = s.v3_score;
  const gain = s.gain;
  if (v3 === null) return 2;
  if (v3 < 60) return 3;
  if (gain !== null && gain <= -10) return 3;
  if (v3 < 70) return 2;
  if (gain !== null && gain < 0 && gain > -10) return 2;
  return 1;
}

function avg(arr,k) {
  const v = arr.map(s=>s[k]).filter(x=>x!==null&&x!==undefined&&!isNaN(x));
  return v.length ? Math.round(v.reduce((a,b)=>a+b,0)/v.length*10)/10 : 0;
}
function pct(n,d) { return d ? Math.round(n/d*100) : 0; }
function getInits(n) {
  const parts = n.trim().split(' ').filter(p=>p);
  return parts.map(w=>w[0]).join('').slice(0,2).toUpperCase();
}
function hColor(s) {
  const p = ['#0f766e','#6d28d9','#0284c7','#b45309','#be123c','#1d4ed8','#065f46','#9333ea'];
  let h = 0;
  for (let c of s) h = (h*31 + c.charCodeAt(0)) % p.length;
  return p[h];
}
function pBar(lbl,pv,col) {
  return `<div class="pbar-wrap"><div class="pbar-top"><span>${lbl}</span><span style="color:${col}">${pv}%</span></div><div class="pbar-bg"><div class="pbar-fill" style="width:${pv}%;background:${col}"></div></div></div>`;
}
function tcol(t) { return {1:'#15803d',2:'#d97706',3:'#be123c'}[t]; }

// COUNTDOWN — Civics EOC: May 15, 2026
function updateCd() {
  const target = new Date('2026-05-15T08:00:00');
  const now = new Date();
  const diff = target - now;
  if (diff <= 0) {
    ['cd-days','cd-hrs','cd-min','cd-sec'].forEach(id=>{const e=document.getElementById(id);if(e)e.textContent='0';});
    return;
  }
  const days = Math.floor(diff/86400000);
  const hrs = Math.floor((diff%86400000)/3600000);
  const min = Math.floor((diff%3600000)/60000);
  const sec = Math.floor((diff%60000)/1000);
  const pad = n => String(n).padStart(2,'0');
  const set = (id,val) => {const e=document.getElementById(id);if(e)e.textContent=val;};
  set('cd-days',days);
  set('cd-hrs',pad(hrs));
  set('cd-min',pad(min));
  set('cd-sec',pad(sec));
}
updateCd();
setInterval(updateCd,1000);

function showTab(id,btn) {
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  if (btn) btn.classList.add('active');
  if (!document.getElementById('tab-'+id).dataset.rendered) {
    renders[id] && renders[id]();
    document.getElementById('tab-'+id).dataset.rendered = '1';
  }
}

