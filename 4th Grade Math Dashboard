function showHomeroomData(room) {
  const students = STUDENTS.filter(s=>s.homeroom===room).sort((a,b)=>b.overall_score-a.overall_score);
  if (students.length === 0) {
    document.getElementById('hr-content').innerHTML = '<div style="padding:40px;text-align:center;color:var(--slate)">No students found in this homeroom.</div>';
    return;
  }
  const avgScore = avg(students,'overall_score');
  const avgGain = avg(students,'gain');
  const avgTyp = Math.round(avg(students.filter(x=>x.pct_typical>0),'pct_typical'));
  const color = ROOM_COLORS[room]||'#64748b';

  const placements = ['Grade 8','Grade 7','Grade 6','Grade 5','Max Score','Late 4','Mid 4','Early 4','Grade 3','Grade 2','Grade 1'];
  const placeCounts = {};
  students.forEach(s=>{placeCounts[s.placement]=(placeCounts[s.placement]||0)+1;});

  // Math teacher breakdown within this period
  const mathTeachers = {};
  students.forEach(s=>{mathTeachers[s.teacher]=(mathTeachers[s.teacher]||0)+1;});
  const teacherLabel = Object.entries(mathTeachers).sort((a,b)=>b[1]-a[1]).map(([t,n])=>`${t} (${n})`).join(' · ');
  const advCount = students.filter(s=>s.class_type==='Advanced').length;
  const eseCount = students.filter(s=>s.class_type==='Math ESE').length;
  const tagsLabel = (advCount>0 ? `${advCount} Advanced` : '') + (advCount>0 && eseCount>0 ? ' · ' : '') + (eseCount>0 ? `${eseCount} Math ESE` : '');

  const html = `
    <div style="background:${ROOM_BG[room]||'#f1f5f9'};border-radius:12px;padding:12px 16px;margin-bottom:16px;border-left:4px solid ${color}">
      <div style="font-size:.72rem;color:var(--slate);text-transform:uppercase;letter-spacing:.6px;font-weight:700;margin-bottom:3px">Homeroom Details</div>
      <div style="font-size:.82rem"><strong>Math Instruction:</strong> ${teacherLabel}${tagsLabel?` · <strong>${tagsLabel}</strong>`:''}</div>
    </div>
    <div class="stat-grid">
      ${[{l:'Students',v:students.length,d:'in homeroom'},{l:'Avg Score',v:avgScore,d:'scale score'},{l:'Avg Gain',v:'+'+avgGain,d:'pts growth'},{l:'Avg % Typical',v:avgTyp+'%',d:'growth progress'}]
        .map(({l,v,d})=>`<div class="stat-card" style="--accent:${color}"><div class="stat-label">${l}</div><div class="stat-value" style="color:${color}">${v}</div><div class="stat-detail">${d}</div></div>`).join('')}
    </div>
    <div class="two-col">
      <div class="card">
        <div class="card-title"><div class="icon" style="background:${ROOM_BG[room]||'#f1f5f9'}">📊</div> Placement Distribution</div>
        ${placements.filter(p=>placeCounts[p]).map(p=>{
          const n=placeCounts[p]||0, pv=pct(n,students.length);
          return placementBar(p+` (${n})`,pv,PLACEMENT_COLORS[p]||'#64748b');
        }).join('')}
      </div>
      <div class="card">
        <div class="card-title"><div class="icon" style="background:#fef3c7">⚡</div> Tier Breakdown</div>
        ${[3,2,1].map(t=>{
          const n=students.filter(s=>getTier(s)===t).length;
          const pv=pct(n,students.length);
          const labels={3:'Tier 3 – Below Grade',2:'Tier 2 – Borderline/Watch',1:'Tier 1 – On Track'};
          const colors={3:'var(--rose)',2:'var(--amber)',1:'var(--green)'};
          return placementBar(labels[t]+` (${n})`,pv,colors[t]);
        }).join('')}
      </div>
    </div>
    <div class="card" style="margin-top:18px">
      <div class="card-title"><div class="icon" style="background:${ROOM_BG[room]||'#f1f5f9'}">🎯</div> Domain Performance (% On or Above Grade Level)</div>
      ${[
        {name:'Number & Operations',key:'no_rel'},
        {name:'Algebra & Algebraic Thinking',key:'ar_rel'},
        {name:'Measurement & Data',key:'md_rel'},
        {name:'Geometry',key:'geo_rel'}
      ].map(d=>{
        const onGL = students.filter(x=>x[d.key]==='Mid or Above Grade Level'||x[d.key]==='Early On Grade Level').length;
        const pv = pct(onGL, students.length);
        const c = pv>=75?'var(--green)':pv>=60?'var(--teal)':pv>=45?'var(--amber)':'var(--rose)';
        return `<div class="domain-row" style="margin-bottom:8px">
          <div class="domain-name"><span>${d.name}</span><span style="font-weight:700;color:${c}">${pv}% (${onGL}/${students.length})</span></div>
          <div class="domain-bar-bg"><div class="domain-bar-fill" style="width:${pv}%;background:${c}">${pv}%</div><div class="domain-bar-benchmark" style="left:70%"></div></div>
        </div>`;
      }).join('')}
    </div>
    <div class="card" style="margin-top:18px;padding:0">
      <div style="padding:18px 22px 12px"><div class="card-title" style="margin-bottom:0"><div class="icon" style="background:${ROOM_BG[room]||'#f1f5f9'}">📋</div> Full Class Roster</div></div>
      <div class="student-table-wrap">
        <table class="student-table">
          <thead><tr>
            <th>Student</th>
            <th>Math Tch.</th>
            <th>Placement</th>
            <th>Scale</th>
            <th>%ile</th>
            <th>Gain</th>
            <th>% Typical</th>
            <th>Number/Ops</th>
            <th>Algebra</th>
            <th>Meas/Data</th>
            <th>Geometry</th>
            <th>Tier</th>
          </tr></thead>
          <tbody>
            ${students.map(s=>{
              const t=getTier(s);
              const tc={1:'#10b981',2:'#f59e0b',3:'#e11d48'}[t];
              const tag = s.class_type==='Advanced'?' ⭐':s.class_type==='Math ESE'?' 🛟':'';
              return `<tr>
                <td><span style="font-weight:700;cursor:pointer;color:var(--teal)" onclick="openStudent('${s.name.replace(/'/g,"&#39;")}')">${s.name}</span>${tag}</td>
                <td style="font-size:.7rem;color:var(--slate)">${s.teacher}</td>
                <td><span class="placement-tag ${PLACEMENT_CSS[s.placement]||''}">${s.placement}</span></td>
                <td style="font-weight:700">${s.overall_score}</td>
                <td>${s.percentile}</td>
                <td style="font-weight:700;color:${s.gain>=25?'var(--green)':s.gain>=10?'var(--amber)':'var(--rose)'}">${s.gain>0?'+':''}${s.gain}</td>
                <td>${s.pct_typical>0?Math.round(s.pct_typical)+'%':'–'}</td>
                <td><span class="placement-tag ${PLACEMENT_CSS[s.no_placement]||''}">${s.no_placement}</span></td>
                <td><span class="placement-tag ${PLACEMENT_CSS[s.ar_placement]||''}">${s.ar_placement}</span></td>
                <td><span class="placement-tag ${PLACEMENT_CSS[s.md_placement]||''}">${s.md_placement}</span></td>
                <td><span class="placement-tag ${PLACEMENT_CSS[s.geo_placement]||''}">${s.geo_placement}</span></td>
                <td><span style="background:${tc}22;color:${tc};padding:2px 9px;border-radius:20px;font-size:.68rem;font-weight:800">T${t}</span></td>
              </tr>`;
            }).join('')}
          </tbody>
        </table>
      </div>
    </div>`;
  document.getElementById('hr-content').innerHTML = html;
}

