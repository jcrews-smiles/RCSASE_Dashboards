  </div>
  <div class="card-title" style="margin-bottom:12px"><div class="icon" style="background:#dbeafe">📊</div> Domain Performance (B2)</div><div class="domain-profile">${domCards}</div>
  <div style="margin-top:14px;padding:10px 12px;background:${t<=2?'#f0fdf4':t<=3?'#fef3c7':'#fef2f2'};border-radius:8px;border-left:4px solid ${tc};font-size:.74rem;line-height:1.5;margin-bottom:20px"><strong>State Test Projection:</strong> ${projection}.</div>
  <div class="card-title" style="margin-bottom:10px"><div class="icon" style="background:#fef3c7">📋</div> Per-Standard Mastery (sorted by B2 ascending — weakest first)</div>
  <div style="max-height:600px;overflow-y:auto;padding:0 4px">${stdsHtml}</div></div>`;
  document.getElementById('student-profile-wrap').innerHTML=html;
}

// TIERS
function renderTiers(){
  const t1=STUDENTS.filter(s=>getTier(s)===1);const t2=STUDENTS.filter(s=>getTier(s)===2);const t3=STUDENTS.filter(s=>getTier(s)===3);const t4=STUDENTS.filter(s=>getTier(s)===4);
  function rl(stu){return stu.map(s=>{const c=hashColor(s.n);return `<li class="tier-student" onclick="openStudent('${s.n.replace(/'/g,"&#39;")}')"><div class="tier-avatar" style="background:${c}">${getInitials(s.n)}</div><div class="tier-info"><div class="tier-sname">${s.n}${s.a?' ⭐':''}</div><div class="tier-room">B2 ${s.b2!=null?Math.round(s.b2)+'%':'—'} · ${s.p}${s.g!=null?' · Δ '+(s.g>=0?'+':'')+Math.round(s.g):''}</div></div></li>`;}).join('');}
  document.getElementById('tier-grid').innerHTML=`<div class="tier-card t1"><div class="tier-head"><div class="tier-num">1</div><div><div class="tier-title">At/Above Benchmark</div><div class="tier-count">${t1.length} students · B2 ≥ 65%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t1)}</ul></div><div class="tier-card t2"><div class="tier-head"><div class="tier-num">2</div><div><div class="tier-title">Approaching</div><div class="tier-count">${t2.length} students · B2 50–64%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t2)}</ul></div><div class="tier-card t3"><div class="tier-head"><div class="tier-num">3</div><div><div class="tier-title">On Watch</div><div class="tier-count">${t3.length} students · B2 35–49%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t3)}</ul></div><div class="tier-card t4"><div class="tier-head"><div class="tier-num">4</div><div><div class="tier-title">Intervention</div><div class="tier-count">${t4.length} students · B2 &lt; 35%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t4)}</ul></div>`;
}

// ACTION PLAN
function renderActionPlan(){
  const t1=STUDENTS.filter(s=>getTier(s)===1);const t2=STUDENTS.filter(s=>getTier(s)===2);const t3=STUDENTS.filter(s=>getTier(s)===3);const t4=STUDENTS.filter(s=>getTier(s)===4);
  const plans=[
    {tier:4,title:'Tier 4 — Intensive Intervention',students:t4,
      focus:['SC.4.E.6.5 — Using Technology (B2: 10%) — first exposure','SC.4.P.8.3 — Law of Conservation of Mass (B2: 15%) — first exposure','SC.4.L.17.1 — Seasonal Changes (B2: 23%) — first exposure','SC.4.N.1.6 — Record Keeping (regressed 80% → 24%) — TOP PRIORITY','SC.4.P.11.1 — Movement of Heat Energy (regressed 74% → 27%)','SC.4.P.10.3 — Sound as a Vibration (regressed 68% → 35%)','SC.4.E.6.4 — Weathering and Erosion (regressed 59% → 31%)','SC.4.L.17.4 — Plants and Animals Impact the Environment (B2: 29%)'],
      strategies:['Daily 30-min small group (3–4 students) with classroom teacher during WIN/flex','Record Keeping reteach: explicit modeling of data tables, observation logs, and lab notebooks with daily practice','Heat Energy: hands-on demos with hot/cold water, conduction through metals (spoon test), insulation activities','Sound as Vibration: tuning fork demos, rubber band experiments, vocal cord exploration','Weathering vs Erosion vs Deposition: stream table with sand/rocks; photo card sorts','Conservation of Mass: balance scale demos with sealed containers (e.g., dissolving sugar)','Vocabulary cards (Frayer model) for high-leverage terms: "vibration," "conduction," "weathering," "evaporation"','Daily exit ticket: 2 questions on focus standard with immediate feedback','Test-taking strategies: read the question first, eliminate clearly wrong answers'],
      resources:['Mystery Science 4th grade','PhET simulations (heat transfer, sound, weathering)','BrainPOP NGSSS-aligned videos','Stemscopes Florida 4th Grade','Progress Learning targeted reteach assignments','Florida NGSSS item specs (Grade 4)','Hands-on lab kits / science notebooks','Florida 5th grade SSA prep materials']},
    {tier:3,title:'Tier 3 — Strategic Support',students:t3,
      focus:['SC.4.N.1.6 — Record Keeping (regression — top priority)','SC.4.P.11.1 — Movement of Heat Energy (regression)','SC.4.P.10.3 — Sound as a Vibration (regression)','SC.4.E.6.4 — Weathering and Erosion (regression)','SC.4.E.6.1 — Rock Categories (B2: 41%)','SC.4.P.9.1 — Chemical Changes (B2: 40%)','SC.4.L.16.1 — Sexual Reproduction in Flowering Plants (B2: 46%)','SC.4.P.8.2 — Properties and Uses of Water (regression 50% → 34%)'],
      strategies:['Small group (4–6) 3x/week pull-out during flex','Re-administer regressed standards in low-stakes practice setting — diagnose what changed since B1','Spiral review warm-ups: rotate through regressed standards 5 min/day','Hands-on rock and mineral kits for SC.4.E.6.1 / SC.4.E.6.2 (Rock Cycle, Mineral Properties)','Chemical Changes lab: baking soda + vinegar, ice melting (physical vs chemical)','Plant reproduction reteach: dissect flower, label parts, follow pollination cycle','Scientific notebooks: students keep daily observation logs to rebuild Record Keeping fluency','Error-analysis: students explain why distractor answers are wrong'],
      resources:['Stemscopes Florida 4th','PhET simulations','BrainPOP Jr.','Mystery Science 4th','Progress Learning skill practice','Generation Genius 4th science','Foldables / interactive science notebooks']},
    {tier:2,title:'Tier 2 — Targeted Review',students:t2,
      focus:['Refine weakest 3–5 standards per student (use Individual tab)','Cohort regression standards: SC.4.N.1.6 (Record Keeping), SC.4.P.11.1 (Heat Energy), SC.4.P.10.3 (Sound)','SC.4.L.17.4 — Plants and Animals Impact Environment (B2: 29%)','SC.4.L.17.2 — Animals, Food, and Energy (B2: 46%)','SC.4.L.17.3 — Energy Moves Through Food Chains (B2: 63%)','Test-format familiarity on Progress Learning interface'],
      strategies:['Push-in support during Tier 1 instruction — pull 4–6 students for targeted reteach','Spiral review warm-ups: 5 mixed questions covering regressed standards each week','Structured error analysis: students explain reasoning verbally and in writing','Peer tutoring: pair Tier 2 with Tier 1 partners for collaborative problem-solving','Spaced retrieval: weekly cumulative quiz across all 4 NGSSS strands','Hands-on labs: ecosystems (food chains/webs), heat transfer, weathering — connect to NGSSS standards','Daily science notebook practice to address Record Keeping regression'],
      resources:['Progress Learning released items','Stemscopes Florida 4th','BrainPOP Jr.','Mystery Science 4th','Florida NGSSS Grade 4 test prep workbook','Generation Genius 4th science','Hands-on lab kits']},
    {tier:1,title:'Tier 1 — Maintenance + Stretch',students:t1,
      focus:['Maintain mastery on standards already at 70%+','Address individual regressions where students dropped from B1 to B2','Push toward 90%+ on 1–2 weakest individual standards','Stretch: cross-domain connections (energy → motion → forces; weathering → rock cycle → minerals)','5th grade preview — atomic structure, energy transfer, ecosystems, scientific method extension','Build science-test stamina with full-length mixed-standards practice in preparation for Grade 5 SSA'],
      strategies:['Whole-class rigorous Tier 1 instruction with rich phenomena-based prompts','Science discourse: "How do you know?" with evidence-based reasoning','Full-length B2-style practice 1x in final weeks — review missed items','3-Act science tasks and open-ended phenomenon investigations','Peer tutoring leadership — pair with Tier 2 partners','Stretch tasks: research projects, science fair extensions, cross-curricular STEAM','Self-assessment: students identify their own 1–2 weakest standards and design a study plan'],
      resources:['Mystery Science 4th extension activities','PhET simulations (intermediate)','Florida 5th grade preview standards','Khan Academy 4th–5th science','Generation Genius 5th science','3-Act science tasks (elementary)','Phenomenon-based investigations']}
  ];
  document.getElementById('action-plan').innerHTML=plans.map(p=>{const tc={1:'var(--green)',2:'var(--sky)',3:'var(--amber)',4:'var(--rose)'}[p.tier];return `<div class="action-card t${p.tier}"><div class="action-header"><span class="action-tier-badge">Tier ${p.tier}</span><div class="action-title">${p.title}</div></div><div style="margin-bottom:14px"><div class="action-section-title">📌 Priority Students (${p.students.length})</div><div class="action-students">${p.students.map(s=>`<span class="student-chip" style="background:${hashColor(s.n)};cursor:pointer" onclick="openStudent('${s.n.replace(/'/g,"&#39;")}')">${s.n}</span>`).join('')}</div></div><div class="action-body"><div><div class="action-section-title">🎯 Priority Standards Focus</div><ul class="action-list">${p.focus.map(f=>`<li>${f}</li>`).join('')}</ul></div><div><div class="action-section-title">🛠 Intervention Strategies</div><ul class="action-list">${p.strategies.map(s=>`<li>${s}</li>`).join('')}</ul></div></div><div style="margin-top:14px;padding-top:12px;border-top:1px solid ${tc}33"><div class="action-section-title">📚 Recommended Resources</div><div style="display:flex;flex-wrap:wrap;gap:6px">${p.resources.map(r=>`<span style="background:${tc}15;color:${tc};padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:600">${r}</span>`).join('')}</div></div></div>`;}).join('');
}

renderOverview();renderClassView();renderDomainView();renderStandards();filterStudentList();renderTiers();renderActionPlan();
</script>
