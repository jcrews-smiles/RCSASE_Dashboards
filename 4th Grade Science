// HELPERS
const avg=(a,k)=>{const v=a.map(x=>x[k]).filter(x=>x!=null&&!isNaN(x));return v.length?Math.round(v.reduce((a,b)=>a+b,0)/v.length):0;};
const pct=(n,d)=>d===0?0:Math.round(n/d*100);
const getInitials=n=>n.replace('#','').split(' ').map(w=>w[0]).filter(Boolean).join('').slice(0,2).toUpperCase();
const PALETTE=['#0d9488','#7c3aed','#0369a1','#b45309','#be123c','#065f46','#1d4ed8','#6b21a8'];
function hashColor(s){let h=0;for(let c of s)h=(h*31+c.charCodeAt(0))%PALETTE.length;return PALETTE[h];}
function getTier(s){if(s.b2==null)return 'P';if(s.b2>=65)return 1;if(s.b2>=50)return 2;if(s.b2>=35)return 3;return 4;}
function tierLabel(t){return{1:'Tier 1 – At/Above Benchmark',2:'Tier 2 – Approaching',3:'Tier 3 – On Watch',4:'Tier 4 – Intervention','P':'No B2'}[t];}
function tierColor(t){return{1:'var(--green)',2:'var(--sky)',3:'var(--amber)',4:'var(--rose)','P':'var(--slate)'}[t];}
function scorePillClass(score,has){if(!has||score==null)return 'sp-pend';if(score>=65)return 'sp-bench';if(score>=50)return 'sp-approach';if(score>=35)return 'sp-watch';return 'sp-int';}
function placementBar(label,p,c){return `<div class="placement-bar-wrap"><div class="placement-label"><span>${label}</span><span style="color:${c};font-weight:700">${p}%</span></div><div class="placement-bar-bg"><div class="placement-bar-fill" style="width:${p}%;background:${c}"></div></div></div>`;}
function studentStandards(stu){return STANDARDS.map((std,i)=>({c:std.c,desc:std.d,domain:std.dom,b1:stu.s[i][0],b2:stu.s[i][1],delta:(stu.s[i][1]!=null&&stu.s[i][0]!=null)?stu.s[i][1]-stu.s[i][0]:null}));}

// TABS
function showTab(id,evt){document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));document.getElementById('tab-'+id).classList.add('active');if(evt)evt.currentTarget.classList.add('active');}

// OVERVIEW
function renderOverview(){
  const s=STUDENTS;const withB1B2=s.filter(x=>x.b1!=null&&x.b2!=null);
  const b1Avg=avg(s,'b1');const b2Avg=avg(s,'b2');const meanGain=b2Avg-b1Avg;
  const benchmark=s.filter(x=>x.b2!=null&&x.b2>=65).length;const intervention=s.filter(x=>x.b2!=null&&x.b2<35).length;
  const advCount=s.filter(x=>x.a).length;
  const stats=[
    {label:'Total Students',value:s.length,detail:'B2 takers · 6 periods',color:'var(--teal)'},
    {label:'Mean B1',value:b1Avg+'%',detail:'September 2025',color:'var(--slate)'},
    {label:'Mean B2',value:b2Avg+'%',detail:'April 2026',color:'var(--sky)'},
    {label:'B1 → B2 Gain',value:'+'+meanGain+'%',detail:'Cohort growth',color:'var(--green)'},
    {label:'At/Above Benchmark',value:benchmark,detail:pct(benchmark,s.length)+'% of students',color:'var(--green)'},
    {label:'Need Intervention',value:intervention,detail:'B2 below 35%',color:'var(--rose)'},
    {label:'Advanced Sections',value:advCount,detail:'M/J Comp Sci 1 Adv',color:'var(--violet)'},
    {label:'Standards Tested',value:STANDARDS.length,detail:'NGSSS strands',color:'var(--amber)'}
  ].map(({label,value,detail,color})=>`<div class="stat-card" style="--accent:${color}"><div class="stat-label">${label}</div><div class="stat-value" style="color:${color}">${value}</div><div class="stat-detail">${detail}</div></div>`).join('');
  document.getElementById('overview-stats').innerHTML=stats;
  
  const buckets=[{label:'At/Above Benchmark (≥65%)',f:x=>x.b2!=null&&x.b2>=65,c:'#10b981'},
    {label:'Approaching (50–64%)',f:x=>x.b2!=null&&x.b2>=50&&x.b2<65,c:'#0ea5e9'},
    {label:'On Watch (35–49%)',f:x=>x.b2!=null&&x.b2>=35&&x.b2<50,c:'#f59e0b'},
    {label:'Intervention (<35%)',f:x=>x.b2!=null&&x.b2<35,c:'#e11d48'}];
  document.getElementById('mastery-dist').innerHTML=buckets.map(b=>{const n=s.filter(b.f).length;return placementBar(b.label+` (${n})`,pct(n,s.length),b.c);}).join('');
  
  const domains=[...new Set(STANDARDS.map(x=>x.dom))];
  document.getElementById('domain-overview').innerHTML=domains.map(d=>{
    const stds=STANDARDS.filter(x=>x.dom===d);
    const b1v=stds.filter(x=>x.b1!=null);const b2v=stds.filter(x=>x.b2!=null);
    const b1A=b1v.length?Math.round(b1v.reduce((a,b)=>a+b.b1,0)/b1v.length):0;
    const b2A=b2v.length?Math.round(b2v.reduce((a,b)=>a+b.b2,0)/b2v.length):0;
    const c=b2A>=70?'var(--green)':b2A>=55?'var(--sky)':b2A>=40?'var(--amber)':'var(--rose)';
    return `<div><div class="domain-name"><span>${d} (${stds.length} stds)</span><span style="font-weight:700;color:${c}">B1 ${b1A}% → B2 ${b2A}%</span></div><div class="domain-bar-bg"><div class="domain-bar-fill" style="width:${b2A}%;background:${c}">${b2A}%</div><div class="domain-bar-benchmark" style="left:65%"></div></div></div>`;
  }).join('');
  
  const improvers=[...withB1B2].filter(x=>x.g!=null).sort((a,b)=>b.g-a.g).slice(0,8);
