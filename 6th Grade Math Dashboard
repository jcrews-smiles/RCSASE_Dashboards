  {domain:'Geometry',iready:'Surface area using nets',standard:'MA.6.GR.2.6',desc:'Use nets to find the surface area of right rectangular prisms and triangular prisms.',priority:'Med',note:'Visual-spatial skill. Students struggle to "unfold" 3D shapes. Use physical net cutouts and online interactives.'},
