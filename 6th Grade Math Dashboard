  document.getElementById('action-plan').innerHTML = plans.map(p=>{
    const tc = {1:'var(--green)',2:'var(--amber)',3:'var(--rose)'}[p.tier];
    return `<div class="action-card t${p.tier}">
      <div class="action-header">
