  {domain:'Geometry',iready:'Volume of right rectangular prisms with fractional edges',standard:'MA.6.GR.2.5',desc:'Find the volume of right rectangular prisms with fractional edge lengths; apply V = l×w×h or V = B×h.',priority:'High',note:'Builds on 5th grade volume but adds fractional dimensions. Common error: forgetting to multiply fractions correctly.'},
