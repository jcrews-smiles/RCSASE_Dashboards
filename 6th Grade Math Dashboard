const STANDARDS = [
  {domain:'Number & Operations',iready:'Multi-digit operations with whole numbers, fractions, decimals (5th-grade carryover)',standard:'MA.6.NSO.2.1-2.3',desc:'Multiply and divide multi-digit positive numbers with fluency, including decimals; apply standard algorithms.',priority:'High',note:'Foundational for 6th grade. Students placing Grade 5 or below need decimal-operation review BEFORE ratio work.'},
  {domain:'Number & Operations',iready:'Greatest common factor, least common multiple',standard:'MA.6.NSO.3.1-3.5',desc:'Apply factors, multiples, prime factorization, GCF, LCM; rewrite expressions using the distributive property and GCF.',priority:'Med',note:'GCF/LCM is heavily tested on PM3. Practice factor rainbows and Venn-diagram methods.'},
  {domain:'Number & Operations',iready:'Integers, opposites, and absolute value',standard:'MA.6.NSO.4.1-4.2',desc:'Locate, compare, and order integers on the number line; understand opposites and absolute value as distance from zero.',priority:'Crit',note:'⚠️ MAJOR PM3 GAP: First time students see negative numbers. iReady\'s NO domain blends integers with whole-number ops, masking weakness. A standalone integers pre-assessment is essential before 5/12.'},
  {domain:'Algebra & Algebraic Thinking',iready:'Ratios, rates, and unit rates',standard:'MA.6.AR.1.1-1.3',desc:'Use ratio language to describe relationships; understand the concept of unit rate; solve real-world problems with ratios, rates, and percentages.',priority:'Crit',note:'⚠️ TOP PM3 PRIORITY: Ratios and unit rates are the single highest-tested 6th grade strand. iReady reports them under Algebra (mixed with expressions/equations) — students may have AR placement on grade level but ratio gaps. Use a standalone ratio pre-assessment.'},
  {domain:'Algebra & Algebraic Thinking',iready:'Equivalent expressions, evaluating expressions',standard:'MA.6.AR.2.1-2.4',desc:'Write, read, and evaluate expressions with variables; identify equivalent expressions; apply order of operations to expressions with exponents.',priority:'High',note:'PM3 frequently tests "which expression is equivalent." Students confuse 3x with x+3. Use algebra tiles and area models.'},
