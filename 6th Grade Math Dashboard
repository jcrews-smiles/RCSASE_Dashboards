    },
    {
      tier: 2,
      title: 'Tier 2 — Strategic Support (3x/week, 20–30 min)',
      students: tier2,
      focus: [
        'MA.6.AR.1.1–1.3 — Ratios, unit rates, percent (ALL Tier 2 students — PM3 priority)',
        'MA.6.NSO.4.1–4.2 — Integer operations, absolute value, ordering on number line',
        'MA.6.AR.2.1–2.4 — Equivalent expressions; distributive property; combining like terms',
        'MA.6.AR.3.1–3.5 — One-step equations & inequalities; graphing solutions',
        'MA.6.GR.2.1–2.5 — Area of triangles/quadrilaterals; volume with fractional edges',
