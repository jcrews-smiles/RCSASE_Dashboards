const STANDARDS = [
  {domain:'Number & Operations',iready:'Place value, reading/writing decimals to thousandths',standard:'MA.5.NSO.1.1-1.5',desc:'Read, write, compose, decompose, round, and compare multi-digit numbers including decimals to the thousandths.',priority:'High',note:'Foundational. Students below Mid 5 in NO need scaffolded place-value review with decimal extension.'},
  {domain:'Number & Operations',iready:'Multi-digit multiplication and division',standard:'MA.5.NSO.2.1',desc:'Multiply multi-digit whole numbers (up to 5 digits × 2 digits) using the standard algorithm.',priority:'High',note:'Strong fluency predicts pacing on PM3. Many Grade 4 students still struggle with the standard algorithm.'},
  {domain:'Number & Operations',iready:'Multi-digit decimal operations (+, –, ×, ÷)',standard:'MA.5.NSO.2.2-2.5',desc:'Add, subtract, multiply, and divide multi-digit numbers with decimals to thousandths using strategies and the standard algorithm.',priority:'Crit',note:'⚠️ FAST PM3 weights MA.5.NSO.2 heavily. iReady folds decimals into Number & Operations rather than reporting separately — a decimal-specific check is needed.'},
  {domain:'Fractions (iReady blind spot)',iready:'NOT reported as a separate iReady domain',standard:'MA.5.FR.1.1-2.4',desc:'Add and subtract fractions with unlike denominators; multiply a fraction by a whole number or another fraction; divide whole numbers by unit fractions and unit fractions by whole numbers.',priority:'Crit',note:'⚠️ MAJOR GAP: FAST Math PM3 tests MA.5.FR as its own reporting category with significant weight. iReady does NOT report fractions as a separate domain. A fractions pre-assessment is essential before 5/11.'},
  {domain:'Algebra & Algebraic Thinking',iready:'Order of operations, numerical expressions',standard:'MA.5.AR.1.1-1.3',desc:'Solve real-world problems using order of operations; evaluate numerical expressions with parentheses, brackets, and braces; translate verbal phrases into expressions.',priority:'High',note:'Heavy on PM3. Students confuse order with left-to-right reading. Explicit GEMDAS/PEMDAS practice with parentheses needed.'},
  {domain:'Algebra & Algebraic Thinking',iready:'Multi-step real-world problems with all four operations',standard:'MA.5.AR.2.1-2.4',desc:'Translate written real-world and mathematical descriptions into numerical expressions; solve multi-step real-world problems with whole numbers and decimals.',priority:'High',note:'Word problems with decimals are the #1 trap on PM3. Practice with money, measurement, and quantity contexts.'},
  {domain:'Algebra & Algebraic Thinking',iready:'Patterns and rules in tables; ordered pairs on the coordinate plane',standard:'MA.5.AR.3.1-3.2',desc:'Determine and explain the rule of a numerical pattern; plot ordered pairs in the first quadrant.',priority:'Med',note:'Coordinate plane work overlaps with Geometry. Practice plotting and identifying patterns in tables.'},
