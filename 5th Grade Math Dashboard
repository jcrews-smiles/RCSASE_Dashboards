  {domain:'Measurement & Data → MA.5.DP',iready:'Line plots, bar graphs with fractions/decimals',standard:'MA.5.DP.1.1-1.2',desc:'Collect and represent numerical data; create and interpret line plots using fractions and decimals.',priority:'Med',note:'Line plots with fractional measurements (e.g., ¼-inch increments) are tested. Practice scaled intervals with fractions.'},
  {domain:'Geometry',iready:'Classify two-dimensional figures by attributes',standard:'MA.5.GR.1.1-1.2',desc:'Classify triangles and quadrilaterals into hierarchies based on attributes (side lengths, angle measures, parallel sides).',priority:'Med',note:'Hierarchical classification (e.g., square ⊂ rectangle ⊂ parallelogram) is a common trap. Use Venn/hierarchy organizers.'},
