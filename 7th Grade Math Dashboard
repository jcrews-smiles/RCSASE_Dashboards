              const tc={1:'#10b981',2:'#f59e0b',3:'#e11d48'}[t];
              const tag = s.class_type==='ACCEL'?' ⭐':s.class_type==='Math Support'?' 🛟':'';
              return `<tr>
                <td><span style="font-weight:700;cursor:pointer;color:var(--teal)" onclick="mathOpenStudent('${s.name.replace(/'/g,"&#39;")}')">${s.name}</span>${tag}</td>
                <td style="font-size:.7rem;color:var(--slate)">${s.teacher}</td>
                <td><span class="placement-tag ${PLACEMENT_CSS[s.placement]||''}">${s.placement}</span></td>
                <td style="font-weight:700">${s.overall_score}</td>
                <td>${s.percentile}</td>
                <td style="font-weight:700;color:${s.gain>=25?'var(--green)':s.gain>=10?'var(--amber)':'var(--rose)'}">${s.gain>0?'+':''}${s.gain}</td>
                <td>${s.pct_typical>0?Math.round(s.pct_typical)+'%':'–'}</td>
                <td><span class="placement-tag ${PLACEMENT_CSS[s.no_placement]||''}">${s.no_placement}</span></td>
                <td><span class="placement-tag ${PLACEMENT_CSS[s.ar_placement]||''}">${s.ar_placement}</span></td>
                <td><span class="placement-tag ${PLACEMENT_CSS[s.md_placement]||''}">${s.md_placement}</span></td>
                <td><span class="placement-tag ${PLACEMENT_CSS[s.geo_placement]||''}">${s.geo_placement}</span></td>
                <td><span style="background:${tc}22;color:${tc};padding:2px 9px;border-radius:20px;font-size:.68rem;font-weight:800">T${t}</span></td>
              </tr>`;
            }).join('')}
          </tbody>
        </table>
      </div>
    </div>`;
  document.getElementById('hr-content').innerHTML = html;
}

