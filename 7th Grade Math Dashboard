      resources:['FLDOE Released EOC','Algebra Nation Test-Yourself','Khan Academy SAT prep math','Open Middle Algebra problems','AMC 8 / AMC 10 Algebra problems']}
  ];
  document.getElementById('alg-action-plan').innerHTML=plans.map(p=>{const tc={1:'var(--green)',2:'var(--sky)',3:'var(--amber)',4:'var(--rose)'}[p.tier];return `<div class="action-card t${p.tier}"><div class="action-header"><span class="action-tier-badge">Tier ${p.tier}</span><div class="action-title">${p.title}</div></div><div style="margin-bottom:14px"><div class="action-section-title">📌 Priority Students (${p.students.length})</div><div class="action-students">${p.students.map(s=>`<span class="student-chip" style="background:${hashColor(s.n)};cursor:pointer" onclick="algOpenStudent('${s.n.replace(/'/g,"&#39;")}')">${s.n}</span>`).join('')}</div></div><div class="action-body"><div><div class="action-section-title">🎯 Priority Standards Focus</div><ul class="action-list">${p.focus.map(f=>`<li>${f}</li>`).join('')}</ul></div><div><div class="action-section-title">🛠 Intervention Strategies</div><ul class="action-list">${p.strategies.map(s=>`<li>${s}</li>`).join('')}</ul></div></div><div style="margin-top:14px;padding-top:12px;border-top:1px solid ${tc}33"><div class="action-section-title">📚 Recommended Resources</div><div style="display:flex;flex-wrap:wrap;gap:6px">${p.resources.map(r=>`<span style="background:${tc}15;color:${tc};padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:600">${r}</span>`).join('')}</div></div></div>`;}).join('');
}

renderOverview();renderDomainView();renderStandards();filterStudentList();renderTiers();renderActionPlan();

// Expose to global scope for inline onclick handlers
window.algShowTab = showTab;
window.algOpenStudent = openStudent;
window.algShowDomain = showDomain;
window.algFilterStudentList = filterStudentList;
})();
