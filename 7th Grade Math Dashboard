// INDIVIDUAL
let filteredStudents = [...STUDENTS].sort((a,b)=>a.name.localeCompare(b.name));
let selectedStudent = null;

function filterStudentList() {
  const q = document.getElementById('student-search').value.toLowerCase();
  const room = document.getElementById('room-filter').value;
  const tier = document.getElementById('tier-filter').value;
  const classType = document.getElementById('class-filter').value;
  filteredStudents = STUDENTS.filter(s=>{
    const matchQ = s.name.toLowerCase().includes(q)||s.first.toLowerCase().includes(q);
    const matchR = !room||s.homeroom===room;
    const matchT = !tier||getTier(s)===parseInt(tier);
    const matchC = !classType||s.class_type===classType;
    return matchQ&&matchR&&matchT&&matchC;
  }).sort((a,b)=>a.name.localeCompare(b.name));
  renderStudentList();
}

function renderStudentList() {
  const el = document.getElementById('student-list');
  document.getElementById('student-count').textContent = `(${filteredStudents.length})`;
  if (filteredStudents.length === 0) {
    el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--slate);font-size:.75rem">No students match filters</div>';
    return;
  }
  el.innerHTML = filteredStudents.map(s=>{
    const t = getTier(s);
    const tc = {1:'var(--green)',2:'var(--amber)',3:'var(--rose)'}[t];
    const active = selectedStudent===s.name ? 'background:#f0fdfa;border-color:var(--teal);' : '';
    const tag = s.class_type==='ACCEL'?' ⭐':s.class_type==='Math Support'?' 🛟':'';
    return `<div onclick="openStudent('${s.name.replace(/'/g,"&#39;")}')" style="padding:9px 12px;border-radius:8px;cursor:pointer;border:1px solid #e2e8f0;display:flex;align-items:center;gap:8px;transition:all .15s;${active}" onmouseover="this.style.background='#f0f9ff'" onmouseout="this.style.background='${selectedStudent===s.name?'#f0fdfa':'white'}'">
      <div style="width:28px;height:28px;border-radius:50%;background:${hashColor(s.name)};display:flex;align-items:center;justify-content:center;color:white;font-size:.65rem;font-weight:700;flex-shrink:0">${getInitials(s.name)}</div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:700;font-size:.78rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${s.name}${tag}</div>
        <div style="font-size:.65rem;color:var(--slate)">${s.homeroom} · ${s.placement}</div>
      </div>
      <span style="background:${tc}22;color:${tc};padding:1px 7px;border-radius:12px;font-size:.65rem;font-weight:800;flex-shrink:0">T${t}</span>
    </div>`;
  }).join('');
}

function openStudent(name) {
  const indTab = document.getElementById('tab-individual');
  if (!indTab.classList.contains('active')) {
    document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    indTab.classList.add('active');
    const btns = document.querySelectorAll('.tab-btn');
    btns.forEach(b=>{ if (b.textContent.includes('Individual')) b.classList.add('active'); });
  }
  showStudentProfile(name);
}

function showStudentProfile(name) {
  const s = STUDENTS.find(x=>x.name===name);
  if(!s) return;
  selectedStudent = name;
  renderStudentList();

  const t = getTier(s);
  const tc = {1:'var(--green)',2:'var(--amber)',3:'var(--rose)'}[t];
  const tLabel = {1:'Tier 1 – On Track',2:'Tier 2 – Strategic Support',3:'Tier 3 – Intensive Support'}[t];
  const color = hashColor(s.name);
  const gainColor = s.gain>=25?'var(--green)':s.gain>=10?'var(--sky)':'var(--rose)';

  const domCards = [
    {title:'Number & Operations',placement:s.no_placement,score:s.no_score,rel:s.no_rel,std:'MA.7.NSO.1–2',color:'#7c3aed'},
    {title:'Algebra & Algebraic Thinking',placement:s.ar_placement,score:s.ar_score,rel:s.ar_rel,std:'MA.7.AR.1–4',color:'#0369a1'},
    {title:'Measurement & Data',placement:s.md_placement,score:s.md_score,rel:s.md_rel,std:'MA.7.GR.2 / MA.7.DP',color:'#0d9488'},
    {title:'Geometry',placement:s.geo_placement,score:s.geo_score,rel:s.geo_rel,std:'MA.7.GR.1–2',color:'#b45309'}
  ].map(d=>{
    const borderColor = d.rel==='Mid or Above Grade Level'?'var(--green)':d.rel==='Early On Grade Level'?'var(--amber)':'var(--rose)';
    return `<div class="domain-pcard" style="border-color:${borderColor}">
      <div class="dp-title">${d.title}</div>
      <div class="dp-placement" style="color:${d.color}">${d.placement}</div>
      <div class="dp-score">Scale: ${d.score} · ${d.rel}</div>
      <div class="dp-std">${d.std}</div>
    </div>`;
  }).join('');

  const belowOrEarly = (p) => isBelowGrade(p) || p === 'Early 7';
  const studentStds = STANDARDS.filter(std=>{
    const dom = std.domain.toLowerCase();
    if (std.priority === 'Crit') return true;
    if (dom.includes('number')&&belowOrEarly(s.no_placement)) return true;
    if (dom.includes('algebra')&&belowOrEarly(s.ar_placement)) return true;
    if (dom.includes('measurement')&&belowOrEarly(s.md_placement)) return true;
    if (dom.includes('geometry')&&belowOrEarly(s.geo_placement)) return true;
    return false;
  }).slice(0,6);

  const stdsHTML = studentStds.length ? studentStds.map(std=>`
    <div class="std-match-item">
      <span class="std-code" style="${std.priority==='Crit'?'background:#fee2e2;color:#7f1d1d;':''}">${std.standard}</span>
      <span style="font-size:.68rem;color:var(--slate);max-width:60%;text-align:right">${std.desc.slice(0,55)}…</span>
    </div>`).join('') : '<div style="font-size:.75rem;color:var(--slate);padding:8px 0">No critical standards gaps identified — enrichment focus</div>';

  const needsToMidGL = Math.max(0, s.mid_grade_score - s.overall_score);
  const trajectoryNote = needsToMidGL > 0 ? `Needs +${needsToMidGL} pts to reach Mid On Grade Level (${s.mid_grade_score})` : `At or above Mid On Grade Level benchmark ✓`;

  let fastProjection;
  if (t === 1) {
    fastProjection = ['Late 7','Max Score','Grade 8','Grade 9','Grade 10'].includes(s.placement) ? 'Projected <strong>FAST Level 4–5</strong>' : 'Projected <strong>FAST Level 3+</strong>';
  } else if (t === 2) {
    fastProjection = 'Borderline — close gap to likely achieve <strong>FAST Level 3</strong>';
  } else {
    fastProjection = 'Projected <strong>FAST Level 1–2</strong> without intensive intervention';
  }

  const classBadge = s.class_type==='ACCEL'?'<span class="profile-chip" style="background:#fef9c3;color:#854d0e">⭐ ACCEL</span>':s.class_type==='Math Support'?'<span class="profile-chip" style="background:#dbeafe;color:#1e40af">🛟 Math Support</span>':'';

  const html = `<div class="student-profile" style="display:block">
    <div class="profile-header">
      <div class="profile-avatar" style="background:${color}">${getInitials(s.name)}</div>
      <div style="flex:1">
        <div class="profile-name">${s.name}${s.class_type==='ACCEL'?' ⭐':''}${s.class_type==='Math Support'?' 🛟':''}</div>
        <div class="profile-meta">Period: ${s.homeroom} · Math Teacher: ${s.teacher} · Grade 7 Math · Quantile: ${s.quantile||'—'}</div>
        <div class="profile-chips">
          <span class="profile-chip" style="background:${tc}22;color:${tc}">${tLabel}</span>
          <span class="profile-chip" style="background:#f0f9ff;color:#0369a1">${s.placement}</span>
          <span class="profile-chip" style="background:#f5f3ff;color:#6d28d9">${s.percentile}th percentile</span>
          <span class="profile-chip" style="background:#f1f5f9;color:#475569">Grouping ${s.grouping||'—'} / 5</span>
          ${classBadge}
          ${s.read_aloud==='On'?'<span class="profile-chip" style="background:#e0f2fe;color:#0369a1">🔊 Read Aloud</span>':''}
        </div>
      </div>
    </div>

    <div class="profile-grid">
      <div class="profile-metric"><div class="pm-label">Scale Score</div><div class="pm-value" style="color:var(--navy)">${s.overall_score}</div><div class="pm-sub">Spring YTD</div></div>
      <div class="profile-metric"><div class="pm-label">Baseline</div><div class="pm-value" style="color:var(--slate)">${s.baseline_score}</div><div class="pm-sub">${s.baseline_placement}</div></div>
      <div class="profile-metric"><div class="pm-label">Gain</div><div class="pm-value" style="color:${gainColor}">${s.gain>0?'+':''}${s.gain}</div><div class="pm-sub">pts growth</div></div>
      <div class="profile-metric"><div class="pm-label">% Typical</div><div class="pm-value" style="color:${s.pct_typical>=100?'var(--green)':s.pct_typical>=50?'var(--amber)':'var(--rose)'}">${s.pct_typical>0?Math.round(s.pct_typical):0}%</div><div class="pm-sub">of ${s.typical_target} pt target</div></div>
      <div class="profile-metric"><div class="pm-label">% Stretch</div><div class="pm-value" style="color:${s.pct_stretch>=100?'var(--violet)':'var(--slate)'}">${s.pct_stretch>0?Math.round(s.pct_stretch):0}%</div><div class="pm-sub">of ${s.stretch_target} pt target</div></div>
      <div class="profile-metric"><div class="pm-label">Duration</div><div class="pm-value" style="color:var(--slate);font-size:1.2rem">${s.duration||'—'} min</div><div class="pm-sub">Diagnostic time</div></div>
    </div>

    <div class="card-title" style="margin-bottom:12px"><div class="icon" style="background:#dbeafe">📊</div> Domain Performance &amp; FL B.E.S.T. Mapping</div>
    <div class="domain-profile">${domCards}</div>

    <div class="two-col">
      <div>
        <div class="card-title" style="margin-bottom:10px"><div class="icon" style="background:#fef3c7">📋</div> Priority Standards to Target</div>
        <div class="standards-match">${stdsHTML}</div>
      </div>
      <div>
        <div class="card-title" style="margin-bottom:10px"><div class="icon" style="background:#dcfce7">🎯</div> Growth Toward Targets</div>
        <div class="growth-bar-row">
          <div class="gbr-label">Typical Growth</div>
          <div class="gbr-bar-wrap">
            <div class="gbr-bg">
              <div class="gbr-fill" style="width:${Math.min(s.pct_typical||0,100)}%;background:var(--teal)">${Math.round(s.pct_typical||0)}%</div>
              <div class="gbr-target" style="left:50%"></div>
            </div>
          </div>
        </div>
        <div class="growth-bar-row">
          <div class="gbr-label">Stretch Growth</div>
          <div class="gbr-bar-wrap">
            <div class="gbr-bg">
              <div class="gbr-fill" style="width:${Math.min(s.pct_stretch||0,100)}%;background:var(--violet)">${Math.round(s.pct_stretch||0)}%</div>
              <div class="gbr-target" style="left:50%"></div>
            </div>
          </div>
        </div>
        <div style="font-size:.7rem;color:var(--slate);margin-top:8px">📌 Typical target: +${s.typical_target} pts · Stretch target: +${s.stretch_target} pts · Dark line marks 50% progress</div>
        <div style="margin-top:14px; padding:10px 12px; background:${s.overall_score >= s.mid_grade_score ? '#f0fdf4' : '#fef3c7'}; border-radius:8px; border-left:4px solid ${s.overall_score >= s.mid_grade_score ? 'var(--green)' : 'var(--amber)'}; font-size:.74rem; line-height:1.5;">
          <strong>FAST Math PM3 Projection:</strong> ${fastProjection}.<br><strong>Progress:</strong> ${trajectoryNote}.
        </div>
      </div>
    </div>
  </div>`;

  document.getElementById('student-profile-wrap').innerHTML = html;
}

function renderIndividual() {
  renderStudentList();
}

// TIERS
function renderTiers() {
  const tier3 = STUDENTS.filter(s=>getTier(s)===3);
  const tier2 = STUDENTS.filter(s=>getTier(s)===2);
  const tier1 = STUDENTS.filter(s=>getTier(s)===1);

  function getGaps(s) {
    const gaps = [];
    if (isBelowGrade(s.no_placement)) gaps.push('Number/Ops');
    if (isBelowGrade(s.ar_placement)) gaps.push('Algebra');
    if (isBelowGrade(s.md_placement)) gaps.push('Meas/Data');
    if (isBelowGrade(s.geo_placement)) gaps.push('Geometry');
    if (s.pct_typical<50&&s.pct_typical>0) gaps.push('Low Growth');
    if (s.gain < 10) gaps.push('Low Gain');
    return gaps;
  }

  function renderTierList(students) {
    return students.map(s=>{
      const gaps = getGaps(s);
      const color = hashColor(s.name);
      const tag = s.class_type==='ACCEL'?' ⭐':s.class_type==='Math Support'?' 🛟':'';
      return `<li class="tier-student" style="cursor:pointer" onclick="openStudent('${s.name.replace(/'/g,"&#39;")}')">
        <div class="tier-avatar" style="background:${color}">${getInitials(s.name)}</div>
        <div class="tier-info">
          <div class="tier-sname">${s.name}${tag}</div>
          <div class="tier-room">${s.homeroom} · ${s.placement} · Score: ${s.overall_score}</div>
          ${gaps.length?`<div class="tier-gaps">${gaps.map(g=>`<span class="gap-tag" style="background:#fee2e2;color:#9f1239">${g}</span>`).join('')}</div>`:''}
        </div>
        <div style="text-align:right;flex-shrink:0">
          <div style="font-weight:700;font-size:.75rem;color:${s.gain>=25?'var(--green)':s.gain>=10?'var(--amber)':'var(--rose)'}">${s.gain>0?'+':''}${s.gain}</div>
          <div style="font-size:.62rem;color:var(--slate)">pts</div>
        </div>
      </li>`;
    }).join('');
  }

  document.getElementById('tier-grid').innerHTML = `
    <div class="tier-card t3">
      <div class="tier-head"><div class="tier-num">3</div><div><div class="tier-title">Intensive Support</div><div class="tier-count">${tier3.length} students · Below grade level</div></div></div>
      <ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${renderTierList(tier3)}</ul>
    </div>
    <div class="tier-card t2">
      <div class="tier-head"><div class="tier-num">2</div><div><div class="tier-title">Strategic Support</div><div class="tier-count">${tier2.length} students · Borderline / watch</div></div></div>
      <ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${renderTierList(tier2)}</ul>
    </div>
    <div class="tier-card t1">
      <div class="tier-head"><div class="tier-num">1</div><div><div class="tier-title">On Track / Enrichment</div><div class="tier-count">${tier1.length} students · Meeting/exceeding targets</div></div></div>
      <ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${renderTierList(tier1)}</ul>
    </div>`;

  const periods = ['P3-Seker','P6-Seker','P2-ACCEL-Rutledge','P6-ACCEL-Rutledge'];
  let roomHTML = `<table class="student-table" style="font-size:.78rem"><thead><tr><th>Period</th><th>Total</th><th>Tier 1</th><th>Tier 2</th><th>Tier 3</th><th>Avg Score</th><th>Avg Gain</th></tr></thead><tbody>`;
  periods.forEach(r=>{
    const rs = STUDENTS.filter(s=>s.homeroom===r);
    if (rs.length === 0) return;
    const t1c=rs.filter(s=>getTier(s)===1).length, t2c=rs.filter(s=>getTier(s)===2).length, t3c=rs.filter(s=>getTier(s)===3).length;
    roomHTML += `<tr>
      <td style="font-weight:700"><span style="display:inline-block;width:12px;height:12px;border-radius:50%;background:${ROOM_COLORS[r]};margin-right:6px;vertical-align:middle"></span>${r}</td>
      <td>${rs.length}</td>
      <td style="color:var(--green);font-weight:700">${t1c} (${pct(t1c,rs.length)}%)</td>
      <td style="color:var(--amber);font-weight:700">${t2c} (${pct(t2c,rs.length)}%)</td>
      <td style="color:var(--rose);font-weight:700">${t3c} (${pct(t3c,rs.length)}%)</td>
      <td style="font-weight:700">${avg(rs,'overall_score')}</td>
      <td style="font-weight:700;color:${avg(rs,'gain')>=25?'var(--green)':'var(--amber)'}">+${avg(rs,'gain')}</td>
    </tr>`;
  });
  roomHTML += '</tbody></table>';
  document.getElementById('tier-by-room').innerHTML = roomHTML;
}

// ACTION PLAN
function renderActionPlan() {
  const tier3 = STUDENTS.filter(s=>getTier(s)===3);
  const tier2 = STUDENTS.filter(s=>getTier(s)===2);
  const tier1 = STUDENTS.filter(s=>getTier(s)===1);

  const plans = [
    {
      tier: 3,
      title: 'Tier 3 — Intensive Intervention (Daily, 30–45 min)',
      students: tier3,
      focus: [
        'MA.7.NSO.1–2 — Rational number operations: integers, fractions, decimals (5th–6th-grade prerequisite repair)',
        'MA.7.AR.4.1–4.5 — Proportional relationships and constant of proportionality (TOP PM3 priority — iReady masks this)',
        'MA.7.AR.3.1–3.3 — Percent applications: tax, tip, discount, simple interest',
        'MA.7.AR.1.1–1.2 — Combining like terms; distributive property',
        'MA.7.AR.2.1–2.2 — Two-step equations and one-step inequalities',
        'MA.7.GR.1.5–1.6 — Circumference and area of circles',
        'MA.7.DP.1–2 — Sampling and basic probability'
      ],
      strategies: [
        'Daily 30-min small group (3–4 students) with classroom teacher or push-in support during WIN/flex',
        'Rational-number operations review using two-color counters and number lines (CRA progression)',
        'Ratio tables and double number lines — daily 5-minute warm-ups with real contexts (recipes, mileage, currency)',
        'Algebra tiles for combining like terms and modeling two-step equations',
        'Percent applications using 1% benchmark strategy: 15% tip = 10% + 5% = 10%-of + half-of-that',
        'Circle formula anchor chart and practice — distinguish C = πd from A = πr²',
        'FAST-formatted item-type exposure 2x/week: multi-select, drag-and-drop, equation editor, coordinate plotting',
        'Tree diagrams and probability spinners for compound events',
        'iReady: verify 45+ min/week of assigned lessons (Groupings 1–2)',
        'Conference with low-gain or rush-flagged students — verify engagement and diagnostic validity'
      ],
      resources: ['iReady assigned lessons (Groupings 1–2)', 'Ready Math Grade 7 toolkit', 'Two-color counters / number lines', 'Algebra tiles (physical or virtual)', 'Number Talks: Fractions/Decimals/Percents', 'FAST item specs (FLDOE)', 'Open Up Resources Grade 7 OER', 'Ratio tables and tape diagrams (printables)']
    },
    {
      tier: 2,
      title: 'Tier 2 — Strategic Support (3x/week, 20–30 min)',
      students: tier2,
      focus: [
        'MA.7.AR.4.1–4.5 — Proportional relationships (ALL Tier 2 students — PM3 priority)',
        'MA.7.NSO.1–2 — Rational number operations with negative numbers',
        'MA.7.AR.3.1–3.3 — Percent applications (markups, markdowns, simple interest)',
        'MA.7.AR.1.1–1.2 — Equivalent expressions; distributive property',
        'MA.7.AR.2.1–2.2 — Two-step equations & inequalities; graphing on number line',
        'MA.7.GR.1.5–1.6 — Circumference and area of circles',
        'MA.7.GR.2.1–2.4 — Surface area and volume of prisms',
        'MA.7.DP.1–2 — Sampling methods and probability of compound events'
      ],
      strategies: [
        'Small group (4–6) 3x/week during WIN/flex or guided math rotations',
        'FAST-formatted practice problems 2x/week — focus on proportional reasoning and percent word problems',
        'Proportional reasoning daily warm-up — tape diagrams, ratio tables, double number lines',
        'Percent equation practice — convert between fraction/decimal/percent fluency',
        'Error-analysis routine: students explain WHY a wrong answer is wrong using math vocabulary',
        'Sampling scenarios discussion — "which method gives the most representative sample?"',
        'iReady: maintain 45+ min/week; use teacher dashboard to monitor lesson completion',
        'Growth goal conferences: review % progress to typical growth target weekly',
        'Flag and follow up with low-gain students — verify engagement and rush flags'
      ],
      resources: ['iReady assigned lessons (Groupings 3–4)','Ready Math Grade 7 toolkit','Math Playground / Prodigy / Desmos','FAST sample items (FLDOE)','Ratio tables and tape diagram printables','Khan Academy proportional relationships/percents/probability modules','Illustrative Mathematics Grade 7']
    },
    {
      tier: 1,
      title: 'Tier 1 — Core Instruction + ACCEL Enrichment (Daily whole class + extension)',
      students: tier1,
      focus: [
        'MA.7.NSO.1–2 — Full mastery of rational number operations',
        'MA.7.AR.1–4 — Expressions, equations, inequalities, percent, proportional relationships',
        'MA.7.GR.1–2 — Circles, scale, surface area, volume, angle relationships',
        'MA.7.DP.1–2 — Sampling, statistical inference, theoretical/experimental probability',
        'For ACCEL students: 8th-grade or Algebra I preview — linear functions, systems of equations, exponential expressions'
      ],
      strategies: [
        'Whole-class rigorous Tier 1 instruction with differentiated questioning and tiered tasks',
        'Math discourse: "Talk moves" — restate, add on, agree/disagree with evidence',
        'Weekly proportional reasoning and percent review — iReady\'s blended Algebra score may mask gaps',
        '3-Act Tasks and open-ended problem solving (Dan Meyer, Robert Kaplinsky)',
        'iReady: maintain 45+ min/week on-path or enrichment (Grouping 5)',
        'FAST sample item practice — interface familiarity (drag-drop, multi-select, equation editor)',
        'Peer tutoring: pair Tier 1 with Tier 2 partners for proportional-reasoning word problems',
        'ACCEL enrichment: linear functions (MA.8.AR.3), systems of equations (MA.8.AR.4), exponential properties (MA.912.NSO.1)',
        'Probability simulations using physical spinners, dice, cards — connect experimental to theoretical'
      ],
