function showTab(id,evt){document.querySelectorAll('#alg-view .tab-pane').forEach(p=>p.classList.remove('active'));document.querySelectorAll('#alg-view .tab-btn').forEach(b=>b.classList.remove('active'));document.getElementById('alg-tab-'+id).classList.add('active');if(evt)evt.currentTarget.classList.add('active');}

