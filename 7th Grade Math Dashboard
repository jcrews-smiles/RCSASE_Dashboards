    {label:'Pending V3',value:pending,detail:'Need retake',color:'var(--amber)'},
    {label:'Standards Tested',value:STANDARDS.length,detail:'MA.912 strands',color:'var(--violet)'}].map(({label,value,detail,color})=>`<div class="stat-card" style="--accent:${color}"><div class="stat-label">${label}</div><div class="stat-value" style="color:${color}">${value}</div><div class="stat-detail">${detail}</div></div>`).join('');
  document.getElementById('alg-overview-stats').innerHTML=stats;
  
  const buckets=[{label:'At/Above Benchmark (≥65%)',f:x=>x.hv3&&x.v3>=65,c:'#10b981'},
    {label:'Approaching (50–64%)',f:x=>x.hv3&&x.v3>=50&&x.v3<65,c:'#0ea5e9'},
    {label:'On Watch (35–49%)',f:x=>x.hv3&&x.v3>=35&&x.v3<50,c:'#f59e0b'},
    {label:'Intervention (<35%)',f:x=>x.hv3&&x.v3<35,c:'#e11d48'},
    {label:'Pending V3',f:x=>!x.hv3,c:'#94a3b8'}];
  document.getElementById('alg-mastery-dist').innerHTML=buckets.map(b=>{const n=s.filter(b.f).length;return placementBar(b.label+` (${n})`,pct(n,s.length),b.c);}).join('');
  
  const domains=[...new Set(STANDARDS.map(x=>x.dom))];
  document.getElementById('alg-domain-overview').innerHTML=domains.map(d=>{
