// OVERVIEW
function renderOverview() {
  const s = STUDENTS;
  const avgGain = avg(s,'gain');
  const avgScore = avg(s,'overall_score');
  const pctTypical = Math.round(avg(s.filter(x=>x.pct_typical>0),'pct_typical'));
  const belowGL = s.filter(x=>isBelowGrade(x.placement)).length;
  const aboveGL = s.filter(x=>['Early 7','Mid 7','Late 7','Max Score','Grade 8','Grade 9','Grade 10'].includes(x.placement)).length;
  const typMet = s.filter(x=>x.pct_typical >= 100).length;
  const stretchMet = s.filter(x=>x.pct_stretch >= 100).length;

  const statsHTML = [
    {label:'Total Students',value:s.length,detail:'Across 4 math periods',color:'var(--teal)'},
    {label:'Avg Scale Score',value:avgScore,detail:'Spring YTD',color:'var(--sky)'},
    {label:'Avg Gain',value:'+'+avgGain,detail:'pts since baseline',color:'var(--green)'},
    {label:'% Typical Growth',value:pctTypical+'%',detail:'Avg progress to goal',color:'var(--violet)'},
    {label:'On/Above Grade',value:aboveGL,detail:'Early 7 or higher',color:'#059669'},
    {label:'Below Grade Level',value:belowGL,detail:'Grade 6 or below',color:'var(--rose)'},
    {label:'Met Typical Growth',value:typMet,detail:pct(typMet,s.length)+'% of students',color:'var(--teal)'},
    {label:'Met Stretch Growth',value:stretchMet,detail:pct(stretchMet,s.length)+'% of students',color:'var(--violet)'}
  ].map(({label,value,detail,color})=>`
    <div class="stat-card" style="--accent:${color}">
      <div class="stat-label">${label}</div>
      <div class="stat-value" style="color:${color}">${value}</div>
      <div class="stat-detail">${detail}</div>
    </div>`).join('');
