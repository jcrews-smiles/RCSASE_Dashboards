    return `<div><div class="domain-name"><span>${d} (${stds.length} stds)</span><span style="font-weight:700;color:${c}">${dAvg}%</span></div><div class="domain-bar-bg"><div class="domain-bar-fill" style="width:${dAvg}%;background:${c}">${dAvg}%</div><div class="domain-bar-benchmark" style="left:65%"></div></div></div>`;
