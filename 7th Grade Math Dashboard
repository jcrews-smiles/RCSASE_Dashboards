// HELPERS
const avg=(a,k)=>{const v=a.map(x=>x[k]).filter(x=>x!=null&&!isNaN(x));return v.length?Math.round(v.reduce((a,b)=>a+b,0)/v.length):0;};
const pct=(n,d)=>d===0?0:Math.round(n/d*100);
const getInitials=n=>n.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
const PALETTE=['#0d9488','#7c3aed','#0369a1','#b45309','#be123c','#065f46','#1d4ed8','#6b21a8'];
function hashColor(s){let h=0;for(let c of s)h=(h*31+c.charCodeAt(0))%PALETTE.length;return PALETTE[h];}
function getTier(s){if(!s.hv3)return 'P';if(s.v3>=65)return 1;if(s.v3>=50)return 2;if(s.v3>=35)return 3;return 4;}
function tierLabel(t){return{1:'Tier 1 – At/Above Benchmark',2:'Tier 2 – Approaching',3:'Tier 3 – On Watch',4:'Tier 4 – Intervention','P':'Pending V3'}[t];}
function tierColor(t){return{1:'var(--green)',2:'var(--sky)',3:'var(--amber)',4:'var(--rose)','P':'var(--slate)'}[t];}
function scorePillClass(score,has){if(!has)return 'sp-pend';if(score>=65)return 'sp-bench';if(score>=50)return 'sp-approach';if(score>=35)return 'sp-watch';return 'sp-int';}
function placementBar(label,p,c){return `<div class="placement-bar-wrap"><div class="placement-label"><span>${label}</span><span style="color:${c};font-weight:700">${p}%</span></div><div class="placement-bar-bg"><div class="placement-bar-fill" style="width:${p}%;background:${c}"></div></div></div>`;}

// COUNTDOWN
const TEST_DATE=new Date('2026-05-12T08:00:00');
function updateCountdown(){const now=new Date();const diff=TEST_DATE-now;if(diff<=0){['cd-days','cd-hours','cd-mins','cd-secs'].forEach(id=>document.getElementById(id).textContent='0');return;}
const d=Math.floor(diff/(1000*60*60*24)),h=Math.floor((diff%(1000*60*60*24))/(1000*60*60)),m=Math.floor((diff%(1000*60*60))/(1000*60)),s=Math.floor((diff%(1000*60))/1000);
document.getElementById('alg-cd-days').textContent=d;document.getElementById('alg-cd-hours').textContent=h;document.getElementById('alg-cd-mins').textContent=m;document.getElementById('alg-cd-secs').textContent=s;}
updateCountdown();setInterval(updateCountdown,1000);

