// OVERVIEW
function renderOverview() {
  const s = STUDENTS;
  const withV3 = s.filter(x=>x.has_v3);
  const v1Avg = avg(s, 'v1_avg');
  const v3Avg = avg(withV3, 'v3_avg');
  const meanGain = v3Avg - v1Avg;
  const benchmark = withV3.filter(x=>x.v3_avg >= 65).length;
  const intervention = withV3.filter(x=>x.v3_avg < 35).length;
  const pending = s.filter(x=>!x.has_v3).length;

  const stats = [
    {label:'Total Students',value:s.length,detail:'Algebra I (Seker)',color:'var(--teal)'},
    {label:'Mean V1',value:v1Avg+'%',detail:'Earlier practice',color:'var(--slate)'},
    {label:'Mean V3',value:v3Avg+'%',detail:'Most recent practice',color:'var(--sky)'},
    {label:'V1 → V3 Gain',value:'+'+meanGain+'%',detail:'Cohort growth',color:'var(--green)'},
    {label:'At/Above Benchmark',value:benchmark,detail:pct(benchmark,withV3.length)+'% of tested',color:'var(--green)'},
    {label:'Intervention Needed',value:intervention,detail:'V3 below 35%',color:'var(--rose)'},
    {label:'Pending V3',value:pending,detail:'Need retake',color:'var(--amber)'},
    {label:'Standards Tested',value:STANDARDS.length,detail:'MA.912 strands',color:'var(--violet)'}
  ].map(({label,value,detail,color})=>`
    <div class="stat-card" style="--accent:${color}">
      <div class="stat-label">${label}</div>
      <div class="stat-value" style="color:${color}">${value}</div>
      <div class="stat-detail">${detail}</div>
    </div>`).join('');
  document.getElementById('overview-stats').innerHTML = stats;

  // Mastery distribution
  const buckets = [
    {label:'At/Above Benchmark (≥65%)', filter:x=>x.has_v3 && x.v3_avg>=65, color:'#10b981'},
    {label:'Approaching (50–64%)',       filter:x=>x.has_v3 && x.v3_avg>=50 && x.v3_avg<65, color:'#0ea5e9'},
    {label:'On Watch (35–49%)',           filter:x=>x.has_v3 && x.v3_avg>=35 && x.v3_avg<50, color:'#f59e0b'},
    {label:'Intervention (<35%)',         filter:x=>x.has_v3 && x.v3_avg<35, color:'#e11d48'},
    {label:'Pending V3',                  filter:x=>!x.has_v3, color:'#94a3b8'}
  ];
  document.getElementById('mastery-dist').innerHTML = buckets.map(b=>{
    const n = s.filter(b.filter).length;
    const pv = pct(n, s.length);
    return placementBar(b.label+` (${n})`, pv, b.color);
  }).join('');

  // Domain bars
  const domains = [...new Set(STANDARDS.map(x=>x.domain))];
  document.getElementById('domain-overview').innerHTML = domains.map(d=>{
    const stds = STANDARDS.filter(x=>x.domain===d);
    const v3 = stds.filter(x=>x.v3_avg!=null);
    const dAvg = v3.length ? Math.round(v3.reduce((a,b)=>a+b.v3_avg,0)/v3.length) : 0;
    const c = dAvg>=70?'var(--green)':dAvg>=55?'var(--sky)':dAvg>=40?'var(--amber)':'var(--rose)';
    return `<div class="domain-row">
      <div class="domain-name"><span>${d} (${stds.length} stds)</span><span style="font-weight:700;color:${c}">${dAvg}%</span></div>
      <div class="domain-bar-bg"><div class="domain-bar-fill" style="width:${dAvg}%;background:${c}">${dAvg}%</div><div class="domain-bar-benchmark" style="left:65%"></div></div>
    </div>`;
  }).join('');

  // Top improvers
  const improvers = [...withV3].filter(x=>x.gain!=null).sort((a,b)=>b.gain-a.gain).slice(0,8);
  document.getElementById('top-improvers').innerHTML = improvers.map(st=>`
    <div style="display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid #f1f5f9;cursor:pointer" onclick="openStudent('${st.name.replace(/'/g,"&#39;")}')">
      <div style="width:32px;height:32px;border-radius:50%;background:${hashColor(st.name)};display:flex;align-items:center;justify-content:center;color:white;font-size:.7rem;font-weight:700;flex-shrink:0">${getInitials(st.name)}</div>
      <div style="flex:1">
        <div style="font-weight:700;font-size:.8rem">${st.name}</div>
        <div style="font-size:.68rem;color:var(--slate)">${st.v1_avg}% → ${st.v3_avg}%</div>
      </div>
      <div style="text-align:right">
        <div style="font-weight:800;color:var(--green);font-family:'DM Serif Display',serif;font-size:1.1rem">+${Math.round(st.gain)}</div>
        <div style="font-size:.62rem;color:var(--slate)">pts</div>
      </div>
    </div>`).join('');

  // Pending V3
  const pendingList = s.filter(x=>!x.has_v3);
  document.getElementById('pending-v3').innerHTML = pendingList.length ? pendingList.map(st=>`
    <div style="display:flex;align-items:center;gap:10px;padding:6px 0;border-bottom:1px solid #f1f5f9;cursor:pointer" onclick="openStudent('${st.name.replace(/'/g,"&#39;")}')">
      <div style="width:32px;height:32px;border-radius:50%;background:${hashColor(st.name)};display:flex;align-items:center;justify-content:center;color:white;font-size:.7rem;font-weight:700;flex-shrink:0">${getInitials(st.name)}</div>
      <div style="flex:1">
        <div style="font-weight:700;font-size:.8rem">${st.name}</div>
        <div style="font-size:.68rem;color:var(--slate)">V1: ${st.v1_avg}% · No V3 yet</div>
      </div>
      <span class="score-pill sp-pend">PENDING</span>
    </div>`).join('') : '<div style="font-size:.78rem;color:var(--slate);padding:8px 0">All students have completed V3 ✓</div>';
}

// DOMAIN VIEW
function renderDomainView() {
  const domains = [...new Set(STANDARDS.map(x=>x.domain))];
  const tabs = document.getElementById('dom-tabs');
  tabs.innerHTML = domains.map((d,i)=>`<button class="dom-tab ${i===0?'active':''}" onclick="showDomain('${d.replace(/'/g,"&#39;")}',this)">${d}</button>`).join('');
  showDomainData(domains[0]);
}
function showDomain(dom, btn) {
  document.querySelectorAll('.dom-tab').forEach(b=>b.classList.remove('active'));
  if(btn) btn.classList.add('active');
  showDomainData(dom);
}
function showDomainData(dom) {
  const stds = STANDARDS.filter(x=>x.domain===dom);
  const v3vals = stds.filter(x=>x.v3_avg!=null);
  const v1Avg = stds.length ? Math.round(stds.reduce((a,b)=>a+(b.v1_avg||0),0)/stds.length) : 0;
  const v3Avg = v3vals.length ? Math.round(v3vals.reduce((a,b)=>a+b.v3_avg,0)/v3vals.length) : 0;
  const delta = v3Avg - v1Avg;

  // Per-student averages within this domain
  const studAvgs = STUDENTS.map(s=>{
    const dom_data = s.domains[dom];
    return {
      name: s.name,
      v1: dom_data ? dom_data.v1 : null,
      v3: dom_data ? dom_data.v3 : null,
    };
  }).filter(x=>x.v3!=null).sort((a,b)=>(b.v3||0)-(a.v3||0));

  let html = `
    <div class="stat-grid">
      <div class="stat-card" style="--accent:var(--teal)">
        <div class="stat-label">Standards in Domain</div>
        <div class="stat-value" style="color:var(--teal)">${stds.length}</div>
        <div class="stat-detail">MA.912 strand</div>
      </div>
      <div class="stat-card" style="--accent:var(--slate)">
        <div class="stat-label">Mean V1</div>
        <div class="stat-value" style="color:var(--slate)">${v1Avg}%</div>
      </div>
      <div class="stat-card" style="--accent:var(--sky)">
        <div class="stat-label">Mean V3</div>
        <div class="stat-value" style="color:var(--sky)">${v3Avg}%</div>
      </div>
      <div class="stat-card" style="--accent:var(--green)">
        <div class="stat-label">Domain Gain</div>
        <div class="stat-value" style="color:${delta>=0?'var(--green)':'var(--rose)'}">${delta>=0?'+':''}${delta}%</div>
      </div>
    </div>
    
    <div class="card" style="margin-bottom:18px">
      <div class="card-title"><div class="icon" style="background:#dbeafe">📋</div> Standards in ${dom}</div>
      <div class="student-table-wrap">
        <table class="standards-table">
          <thead><tr>
            <th>Standard</th>
            <th>Description</th>
            <th>V1 Avg</th>
            <th>V3 Avg</th>
            <th>Δ</th>
            <th>Priority</th>
          </tr></thead>
          <tbody>
            ${stds.sort((a,b)=>(a.v3_avg||0)-(b.v3_avg||0)).map(s=>{
              const cls = s.priority==='Crit'?'gap-crit':s.priority==='High'?'gap-high':s.priority==='Med'?'gap-med':'gap-low';
              const v3 = s.v3_avg!=null?Math.round(s.v3_avg)+'%':'—';
              const dlt = s.delta>=0?'+'+Math.round(s.delta):Math.round(s.delta);
              const dCls = s.delta>0?'delta-pos':s.delta<0?'delta-neg':'delta-zero';
              return `<tr>
                <td><span class="std-code">${s.code}</span></td>
                <td style="font-size:.74rem">${s.desc}</td>
                <td>${Math.round(s.v1_avg)}%</td>
                <td style="font-weight:700">${v3}</td>
                <td class="${dCls}">${dlt}</td>
                <td><span class="gap-pill ${cls}">${s.priority}</span></td>
              </tr>`;
            }).join('')}
          </tbody>
        </table>
      </div>
    </div>
    
    <div class="card">
      <div class="card-title"><div class="icon" style="background:#d1fae5">👥 </div> Student Performance in ${dom} (V3)</div>
      <div class="student-table-wrap">
        <table class="student-table">
          <thead><tr><th>Student</th><th>V1 %</th><th>V3 %</th><th>Δ</th></tr></thead>
          <tbody>
            ${studAvgs.map(s=>{
              const dlt = s.v1!=null?Math.round(s.v3-s.v1):0;
              const dCls = dlt>0?'delta-pos':dlt<0?'delta-neg':'delta-zero';
              const pillCls = scorePillClass(s.v3, true);
              return `<tr style="cursor:pointer" onclick="openStudent('${s.name.replace(/'/g,"&#39;")}')">
                <td style="font-weight:700"><span style="color:var(--teal)">${s.name}</span></td>
                <td>${s.v1!=null?Math.round(s.v1)+'%':'—'}</td>
                <td><span class="score-pill ${pillCls}">${Math.round(s.v3)}%</span></td>
                <td class="${dCls}">${dlt>=0?'+':''}${dlt}</td>
              </tr>`;
            }).join('')}
          </tbody>
        </table>
      </div>
    </div>`;
  document.getElementById('dom-content').innerHTML = html;
}

