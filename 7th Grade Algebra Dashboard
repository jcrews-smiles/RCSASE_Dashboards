    <th>Priority</th>
  </tr></thead><tbody>${sorted.map(s=>{
    const cls = s.priority==='Crit'?'gap-crit':s.priority==='High'?'gap-high':s.priority==='Med'?'gap-med':'gap-low';
    const dlt = s.delta>=0?'+'+Math.round(s.delta):Math.round(s.delta);
    const dCls = s.delta>0?'delta-pos':s.delta<0?'delta-neg':'delta-zero';
    return `<tr>
      <td style="font-weight:600;color:var(--slate);font-size:.72rem">${s.domain}</td>
      <td><span class="std-code">${s.code}</span></td>
      <td style="font-size:.74rem">${s.desc}</td>
      <td>${Math.round(s.v1_avg)}%</td>
      <td style="font-weight:700">${s.v3_avg!=null?Math.round(s.v3_avg)+'%':'—'}</td>
      <td class="${dCls}">${dlt}</td>
      <td><span class="gap-pill ${cls}">${s.priority}</span></td>
    </tr>`;
  }).join('')}</tbody>`;
}

// INDIVIDUAL
let filteredStudents = [...STUDENTS].sort((a,b)=>a.name.localeCompare(b.name));
let selectedStudent = null;

function filterStudentList() {
  const q = document.getElementById('student-search').value.toLowerCase();
  const tier = document.getElementById('tier-filter').value;
  filteredStudents = STUDENTS.filter(s=>{
    const matchQ = s.name.toLowerCase().includes(q);
    const t = String(getTier(s));
    const matchT = !tier || t === tier;
    return matchQ && matchT;
  }).sort((a,b)=>a.name.localeCompare(b.name));
  renderStudentList();
}

function renderStudentList() {
  const el = document.getElementById('student-list');
  document.getElementById('student-count').textContent = `(${filteredStudents.length})`;
  if (filteredStudents.length === 0) {
    el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--slate);font-size:.75rem">No students match filters</div>';
    return;
  }
  el.innerHTML = filteredStudents.map(s=>{
    const t = getTier(s);
    const tc = tierColor(t);
    const active = selectedStudent===s.name ? 'background:#f0fdfa;border-color:var(--teal);' : '';
    const tLabel = {1:'T1',2:'T2',3:'T3',4:'T4','P':'P'}[t];
    return `<div onclick="openStudent('${s.name.replace(/'/g,"&#39;")}')" style="padding:9px 12px;border-radius:8px;cursor:pointer;border:1px solid #e2e8f0;display:flex;align-items:center;gap:8px;transition:all .15s;${active}" onmouseover="this.style.background='#f0f9ff'" onmouseout="this.style.background='${selectedStudent===s.name?'#f0fdfa':'white'}'">
      <div style="width:28px;height:28px;border-radius:50%;background:${hashColor(s.name)};display:flex;align-items:center;justify-content:center;color:white;font-size:.65rem;font-weight:700;flex-shrink:0">${getInitials(s.name)}</div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:700;font-size:.78rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${s.name}</div>
        <div style="font-size:.65rem;color:var(--slate)">${s.has_v3 ? `V3: ${Math.round(s.v3_avg)}%` : 'Pending V3'}</div>
      </div>
      <span style="background:${tc}22;color:${tc};padding:1px 7px;border-radius:12px;font-size:.65rem;font-weight:800;flex-shrink:0">${tLabel}</span>
    </div>`;
  }).join('');
}

function openStudent(name) {
  const indTab = document.getElementById('tab-individual');
  if (!indTab.classList.contains('active')) {
    document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
    indTab.classList.add('active');
    const btns = document.querySelectorAll('.tab-btn');
    btns.forEach(b=>{ if (b.textContent.includes('Individual')) b.classList.add('active'); });
  }
  showStudentProfile(name);
}

function showStudentProfile(name) {
  const s = STUDENTS.find(x=>x.name===name);
  if(!s) return;
  selectedStudent = name;
  renderStudentList();

  const t = getTier(s);
  const tc = tierColor(t);
  const tLabel = tierLabel(t);
  const color = hashColor(s.name);
  const gain = s.gain != null ? Math.round(s.gain) : null;
  const gainColor = gain != null ? (gain >= 15 ? 'var(--green)' : gain >= 0 ? 'var(--sky)' : 'var(--rose)') : 'var(--slate)';

  // Per-domain cards
  const domCards = Object.entries(s.domains).map(([domName, d])=>{
    const v3 = d.v3 != null ? Math.round(d.v3) : null;
    const v1 = Math.round(d.v1);
    const dCls = v3 != null ? scorePillClass(v3, true) : 'sp-pend';
    const borderColor = v3 == null ? 'var(--slate)' : v3>=65?'var(--green)':v3>=50?'var(--sky)':v3>=35?'var(--amber)':'var(--rose)';
    return `<div class="domain-pcard" style="border-color:${borderColor}">
      <div class="dp-title">${domName}</div>
      <div class="dp-placement" style="color:${borderColor}">${v3!=null?v3+'%':'Pending'}</div>
      <div class="dp-score">V1: ${v1}% · ${d.n_standards} standards</div>
    </div>`;
  }).join('');

  // Standards table — sorted by V3 ascending (weakest first)
  const stdsHtml = `
    <div class="std-row-header">
      <div>Standard</div>
      <div>Description</div>
      <div>V1</div>
      <div>V3</div>
      <div>Δ</div>
    </div>
    ${[...s.standards].sort((a,b)=>(a.v3==null?-1:a.v3)-(b.v3==null?-1:b.v3)).map(st=>{
      const v3 = st.v3 != null ? Math.round(st.v3) : null;
      const v1 = st.v1 != null ? Math.round(st.v1) : 0;
      const dlt = st.delta != null ? Math.round(st.delta) : null;
      const v3Cls = scorePillClass(v3 || 0, st.v3 != null);
      const v1Cls = scorePillClass(v1, true);
      const dCls = dlt > 0 ? 'delta-pos' : dlt < 0 ? 'delta-neg' : 'delta-zero';
      return `<div class="std-row">
        <span class="std-code">${st.code}</span>
        <div style="font-size:.72rem">${st.desc}</div>
        <span class="score-mini ${v1Cls}">${v1}</span>
        <span class="score-mini ${v3Cls}">${v3 != null ? v3 : '—'}</span>
        <span class="${dCls}" style="font-weight:700">${dlt != null ? (dlt>=0?'+':'')+dlt : '—'}</span>
      </div>`;
    }).join('')}`;

  // Projection
  let projection;
  if (t === 1) projection = 'Projected <strong>Pass with confidence</strong> on Algebra I EOC';
  else if (t === 2) projection = 'Borderline pass — <strong>focus on weakest 5–8 standards</strong> in final week';
  else if (t === 3) projection = '<strong>At risk</strong> — intensive intervention required to reach passing threshold';
  else if (t === 4) projection = '<strong>High risk</strong> — significant gaps; consider STAR/diagnostic for placement reconsideration';
  else projection = 'V3 not yet administered — administer ASAP to identify support needs';

  const html = `<div style="background:white;border-radius:16px;padding:28px;box-shadow:var(--card-shadow)">
    <div class="profile-header">
      <div class="profile-avatar" style="background:${color}">${getInitials(s.name)}</div>
      <div style="flex:1">
        <div class="profile-name">${s.name}</div>
        <div class="profile-meta">Math Class: Algebra I · Teacher: Seker · Florida B.E.S.T. MA.912 Standards</div>
        <div class="profile-chips">
          <span class="profile-chip" style="background:${tc}22;color:${tc}">${tLabel}</span>
          ${s.has_v3 ? `<span class="profile-chip" style="background:#f0f9ff;color:#0369a1">V3: ${Math.round(s.v3_avg)}%</span>` : '<span class="profile-chip" style="background:#fef3c7;color:#854d0e">⚠ Pending V3</span>'}
          <span class="profile-chip" style="background:#f5f3ff;color:#6d28d9">${s.weak_count} weak / ${s.strong_count} strong</span>
        </div>
      </div>
    </div>

    <div class="profile-grid">
      <div class="profile-metric"><div class="pm-label">V1 Average</div><div class="pm-value" style="color:var(--slate)">${Math.round(s.v1_avg)}%</div><div class="pm-sub">Earlier practice</div></div>
      <div class="profile-metric"><div class="pm-label">V3 Average</div><div class="pm-value" style="color:${tc}">${s.has_v3?Math.round(s.v3_avg)+'%':'—'}</div><div class="pm-sub">Most recent</div></div>
      <div class="profile-metric"><div class="pm-label">V1 → V3 Gain</div><div class="pm-value" style="color:${gainColor}">${gain != null ? (gain>=0?'+':'')+gain : '—'}</div><div class="pm-sub">% mastery growth</div></div>
      <div class="profile-metric"><div class="pm-label">Standards Tested</div><div class="pm-value" style="color:var(--slate);font-size:1.4rem">${s.n_standards_total}</div><div class="pm-sub">MA.912 strands</div></div>
      <div class="profile-metric"><div class="pm-label">Standards ≥ 65%</div><div class="pm-value" style="color:var(--green)">${s.strong_count}</div><div class="pm-sub">At benchmark</div></div>
      <div class="profile-metric"><div class="pm-label">Standards &lt; 50%</div><div class="pm-value" style="color:var(--rose)">${s.weak_count}</div><div class="pm-sub">Need work</div></div>
    </div>

    <div class="card-title" style="margin-bottom:12px"><div class="icon" style="background:#dbeafe">📊</div> Domain Performance</div>
    <div class="domain-profile">${domCards}</div>

    <div style="margin-top:14px; padding:10px 12px; background:${t<=2 ? '#f0fdf4' : t<=3 ? '#fef3c7' : '#fef2f2'}; border-radius:8px; border-left:4px solid ${tc}; font-size:.74rem; line-height:1.5; margin-bottom:20px;">
      <strong>EOC Projection:</strong> ${projection}.
    </div>

    <div class="card-title" style="margin-bottom:10px"><div class="icon" style="background:#fef3c7">📋</div> Per-Standard Mastery (sorted by V3 ascending — weakest first)</div>
    <div style="max-height:600px;overflow-y:auto;padding:0 4px">
      ${stdsHtml}
    </div>
  </div>`;

  document.getElementById('student-profile-wrap').innerHTML = html;
}

// TIERS
function renderTiers() {
  const t1 = STUDENTS.filter(s=>getTier(s)===1);
  const t2 = STUDENTS.filter(s=>getTier(s)===2);
  const t3 = STUDENTS.filter(s=>getTier(s)===3);
  const t4 = STUDENTS.filter(s=>getTier(s)===4 || getTier(s)==='P');

  function renderTierList(students) {
    return students.map(s=>{
      const color = hashColor(s.name);
      const v3Display = s.has_v3 ? Math.round(s.v3_avg)+'%' : 'Pending V3';
      return `<li class="tier-student" onclick="openStudent('${s.name.replace(/'/g,"&#39;")}')">
        <div class="tier-avatar" style="background:${color}">${getInitials(s.name)}</div>
        <div class="tier-info">
          <div class="tier-sname">${s.name}</div>
          <div class="tier-room">${v3Display} · V1 ${Math.round(s.v1_avg)}%${s.gain != null ? ' · Δ '+(s.gain>=0?'+':'')+Math.round(s.gain) : ''}</div>
        </div>
      </li>`;
    }).join('');
  }

  document.getElementById('tier-grid').innerHTML = `
    <div class="tier-card t1">
      <div class="tier-head"><div class="tier-num">1</div><div><div class="tier-title">At/Above Benchmark</div><div class="tier-count">${t1.length} students · V3 ≥ 65%</div></div></div>
      <ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${renderTierList(t1)}</ul>
    </div>
    <div class="tier-card t2">
      <div class="tier-head"><div class="tier-num">2</div><div><div class="tier-title">Approaching</div><div class="tier-count">${t2.length} students · V3 50–64%</div></div></div>
      <ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${renderTierList(t2)}</ul>
    </div>
    <div class="tier-card t3">
      <div class="tier-head"><div class="tier-num">3</div><div><div class="tier-title">On Watch</div><div class="tier-count">${t3.length} students · V3 35–49%</div></div></div>
      <ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${renderTierList(t3)}</ul>
    </div>
    <div class="tier-card t4">
      <div class="tier-head"><div class="tier-num">4</div><div><div class="tier-title">Intervention</div><div class="tier-count">${t4.length} students · V3 &lt; 35% or pending</div></div></div>
      <ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${renderTierList(t4)}</ul>
    </div>`;
}

