function showStudentProfile(name){
  const s=STUDENTS.find(x=>x.n===name);if(!s)return;
  selectedStudent=name;renderStudentList();
  const t=getTier(s);const tc=tierColor(t);const tLabel=tierLabel(t);
  const color=hashColor(s.n);const gain=s.g!=null?Math.round(s.g):null;
  const gainColor=gain!=null?(gain>=15?'var(--green)':gain>=0?'var(--sky)':'var(--rose)'):'var(--slate)';
  const domCards=Object.entries(s.d).map(([domName,d])=>{const v3=d.v3!=null?Math.round(d.v3):null;const v1=Math.round(d.v1);const borderColor=v3==null?'var(--slate)':v3>=65?'var(--green)':v3>=50?'var(--sky)':v3>=35?'var(--amber)':'var(--rose)';return `<div class="domain-pcard" style="border-color:${borderColor}"><div class="dp-title">${domName}</div><div class="dp-placement" style="color:${borderColor}">${v3!=null?v3+'%':'Pending'}</div><div class="dp-score">V1: ${v1}% · ${d.n_standards} standards</div></div>`;}).join('');
  const stdRows=studentStandards(s);
  const stdsHtml=`<div class="std-row-header"><div>Standard</div><div>Description</div><div>V1</div><div>V3</div><div>Δ</div></div>${[...stdRows].sort((a,b)=>(a.v3==null?-1:a.v3)-(b.v3==null?-1:b.v3)).map(st=>{const v3=st.v3!=null?Math.round(st.v3):null;const v1=st.v1!=null?Math.round(st.v1):0;const dlt=st.delta!=null?Math.round(st.delta):null;const v3Cls=scorePillClass(v3||0,st.v3!=null);const v1Cls=scorePillClass(v1,true);const dCls=dlt>0?'delta-pos':dlt<0?'delta-neg':'delta-zero';return `<div class="std-row"><span class="std-code">${st.c}</span><div style="font-size:.72rem">${st.desc}</div><span class="score-mini ${v1Cls}">${v1}</span><span class="score-mini ${v3Cls}">${v3!=null?v3:'—'}</span><span class="${dCls}" style="font-weight:700">${dlt!=null?(dlt>=0?'+':'')+dlt:'—'}</span></div>`;}).join('')}`;
  let projection;
  if(t===1)projection='Projected <strong>Pass with confidence</strong> on Algebra I EOC';
  else if(t===2)projection='Borderline pass — <strong>focus on weakest 5–8 standards</strong> in final week';
  else if(t===3)projection='<strong>At risk</strong> — intensive intervention required to reach passing threshold';
  else if(t===4)projection='<strong>High risk</strong> — significant gaps; consider STAR/diagnostic for placement reconsideration';
  else projection='V3 not yet administered — administer ASAP to identify support needs';
  const html=`<div style="background:#fff;border-radius:16px;padding:28px;box-shadow:var(--card-shadow)"><div class="profile-header"><div class="profile-avatar" style="background:${color}">${getInitials(s.n)}</div><div style="flex:1"><div class="profile-name">${s.n}</div><div class="profile-meta">Math Class: Algebra I · Teacher: Seker · Florida B.E.S.T. MA.912 Standards</div><div class="profile-chips"><span class="profile-chip" style="background:${tc}22;color:${tc}">${tLabel}</span>${s.hv3?`<span class="profile-chip" style="background:#f0f9ff;color:#0369a1">V3: ${Math.round(s.v3)}%</span>`:'<span class="profile-chip" style="background:#fef3c7;color:#854d0e">⚠ Pending V3</span>'}<span class="profile-chip" style="background:#f5f3ff;color:#6d28d9">${s.wc} weak / ${s.sc} strong</span></div></div></div><div class="profile-grid"><div class="profile-metric"><div class="pm-label">V1 Average</div><div class="pm-value" style="color:var(--slate)">${Math.round(s.v1)}%</div><div class="pm-sub">Earlier practice</div></div><div class="profile-metric"><div class="pm-label">V3 Average</div><div class="pm-value" style="color:${tc}">${s.hv3?Math.round(s.v3)+'%':'—'}</div><div class="pm-sub">Most recent</div></div><div class="profile-metric"><div class="pm-label">V1 → V3 Gain</div><div class="pm-value" style="color:${gainColor}">${gain!=null?(gain>=0?'+':'')+gain:'—'}</div><div class="pm-sub">% mastery growth</div></div><div class="profile-metric"><div class="pm-label">Standards Tested</div><div class="pm-value" style="color:var(--slate);font-size:1.4rem">44</div><div class="pm-sub">MA.912 strands</div></div><div class="profile-metric"><div class="pm-label">Standards ≥ 65%</div><div class="pm-value" style="color:var(--green)">${s.sc}</div><div class="pm-sub">At benchmark</div></div><div class="profile-metric"><div class="pm-label">Standards &lt; 50%</div><div class="pm-value" style="color:var(--rose)">${s.wc}</div><div class="pm-sub">Need work</div></div></div><div class="card-title" style="margin-bottom:12px"><div class="icon" style="background:#dbeafe">📊</div> Domain Performance</div><div class="domain-profile">${domCards}</div><div style="margin-top:14px;padding:10px 12px;background:${t<=2?'#f0fdf4':t<=3?'#fef3c7':'#fef2f2'};border-radius:8px;border-left:4px solid ${tc};font-size:.74rem;line-height:1.5;margin-bottom:20px"><strong>EOC Projection:</strong> ${projection}.</div><div class="card-title" style="margin-bottom:10px"><div class="icon" style="background:#fef3c7">📋</div> Per-Standard Mastery (sorted by V3 ascending — weakest first)</div><div style="max-height:600px;overflow-y:auto;padding:0 4px">${stdsHtml}</div></div>`;
  document.getElementById('student-profile-wrap').innerHTML=html;
}

// TIERS
function renderTiers(){
  const t1=STUDENTS.filter(s=>getTier(s)===1),t2=STUDENTS.filter(s=>getTier(s)===2),t3=STUDENTS.filter(s=>getTier(s)===3),t4=STUDENTS.filter(s=>getTier(s)===4||getTier(s)==='P');
  function rl(stu){return stu.map(s=>{const c=hashColor(s.n);const v3D=s.hv3?Math.round(s.v3)+'%':'Pending V3';return `<li class="tier-student" onclick="openStudent('${s.n.replace(/'/g,"&#39;")}')"><div class="tier-avatar" style="background:${c}">${getInitials(s.n)}</div><div class="tier-info"><div class="tier-sname">${s.n}</div><div class="tier-room">${v3D} · V1 ${Math.round(s.v1)}%${s.g!=null?' · Δ '+(s.g>=0?'+':'')+Math.round(s.g):''}</div></div></li>`;}).join('');}
  document.getElementById('tier-grid').innerHTML=`<div class="tier-card t1"><div class="tier-head"><div class="tier-num">1</div><div><div class="tier-title">At/Above Benchmark</div><div class="tier-count">${t1.length} students · V3 ≥ 65%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t1)}</ul></div><div class="tier-card t2"><div class="tier-head"><div class="tier-num">2</div><div><div class="tier-title">Approaching</div><div class="tier-count">${t2.length} students · V3 50–64%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t2)}</ul></div><div class="tier-card t3"><div class="tier-head"><div class="tier-num">3</div><div><div class="tier-title">On Watch</div><div class="tier-count">${t3.length} students · V3 35–49%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t3)}</ul></div><div class="tier-card t4"><div class="tier-head"><div class="tier-num">4</div><div><div class="tier-title">Intervention</div><div class="tier-count">${t4.length} students · V3 &lt; 35% or pending</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t4)}</ul></div>`;
}

// ACTION PLAN
function renderActionPlan(){
  const t1=STUDENTS.filter(s=>getTier(s)===1),t2=STUDENTS.filter(s=>getTier(s)===2),t3=STUDENTS.filter(s=>getTier(s)===3),t4=STUDENTS.filter(s=>getTier(s)===4||getTier(s)==='P');
  const plans=[
    {tier:4,title:'Tier 4 — Intensive Intervention (Daily, before EOC)',students:t4,
      focus:['MA.912.AR.5.4 — Write an Exponential Function (V3 cohort: 3.5% — CRITICAL)','MA.912.AR.3.7 — Graph & Analyze Quadratic Functions (V3: 15.8%)','MA.912.AR.2.6 — Linear Inequalities (V3: 19.3%)','MA.912.AR.9.6 — Represent Constraints as Systems (V3: 22.8%)','MA.912.DP.3.1 — Two-Way Frequency Tables (V3: 24.6%)','MA.912.F.1.8 — Identify Function Type that Models a Scenario (V3: 26.3%)','For Pending V3: Administer V3 immediately'],
      strategies:['Daily 30-min 1-on-1 or small group (2–3 students) with Seker during WIN/lunch/after school','Re-administer V3 ASAP for any student missing it','Foundation review: linear vs quadratic vs exponential function recognition (Desmos)','Inequality practice: number-line graphing, "flip the sign" rule for negative coefficients','Quadratic graphing: vertex, axis of symmetry, x-intercepts using vertex & factored forms','Exponential function building from table → equation y = a · b^x','Test-taking strategies: process of elimination, work backward, plug-in','Calculator fluency drill: TI-30XS / Desmos calculator on test interface','Daily exit ticket: 3 problems on focus standard'],
      resources:['Algebra Nation','Khan Academy Algebra I','FLDOE Algebra I EOC item specs','Desmos calculator','IXL Algebra I diagnostic','EdgeNuity targeted lessons']},
    {tier:3,title:'Tier 3 — Strategic Support (3x/week, 30 min)',students:t3,
      focus:['MA.912.AR.3 — All Quadratic Function standards','MA.912.AR.4 — Absolute Value Equations & Functions','MA.912.AR.5 — Exponential Functions','MA.912.AR.9 — Systems of Equations & Inequalities','MA.912.AR.2.3 — Parallel & Perpendicular Lines (V3: 33.3%)','MA.912.DP.1.2 — Interpreting Data Distributions','MA.912.F.1.5 — Compare Key Features of Linear Functions'],
      strategies:['Small group (4–6) 3x/week pull-out with Seker during flex/WIN','EOC-format practice 2x/week: multi-select, drag-and-drop, equation editor items','Quadratic deep dive: connect standard, vertex, factored forms (Desmos sliders)','Systems: graphing → substitution → elimination','Absolute value: parent function and transformations','Error-analysis: students explain why distractors are wrong','Daily warm-up: 1 problem from each weak standard rotating','Weekly 5-question quiz on focus standards'],
      resources:['Algebra Nation','Khan Academy Algebra I','FLDOE sample items','Desmos / GeoGebra','Illustrative Mathematics','EOC Practice Test (full release)']},
    {tier:2,title:'Tier 2 — Targeted Review (2x/week, 20–30 min)',students:t2,
      focus:['Refine weakest 3–5 standards per student (Individual tab)','MA.912.F.1.5 — Compare Key Features of Linear Functions','MA.912.AR.4.1 / 4.3 — Absolute Value (cohort regression)','MA.912.DP.3.1 — Two-Way Frequency Tables','MA.912.AR.2.4 — Graph a Linear Function','Test-format familiarity: equation editor, multi-select, drag-and-drop'],
      strategies:['Push-in support during Tier 1 — Grubb or Seker pulls 4–6 for targeted reteach','EOC-format practice 2x/week using FLDOE released items','Structured error analysis: explain reasoning verbally and in writing','Daily fluency: 5 mixed Algebra I problems across all 5 domains','Peer tutoring: pair Tier 2 with Tier 1 for collaborative problem-solving','Spaced retrieval: weekly cumulative quiz','Calculator strategies: when to use, when to compute by hand'],
      resources:['FLDOE released items','Algebra Nation review videos','Khan Academy targeted skills','Khan Academy course challenge','Desmos online calculator practice']},
    {tier:1,title:'Tier 1 — Maintenance + Stretch (Daily core + extension)',students:t1,
      focus:['Maintain mastery on standards already at 80%+','Push toward 100% on 1–2 weakest individual standards','Build EOC pacing and stamina with full-length practice tests','Test-day strategies: elimination, time management, calculator use','Stretch: connections across domains'],
      strategies:['Whole-class rigorous Tier 1 instruction with rich problems','Math discourse: justify, critique, extend reasoning','Full-length EOC practice test 1x in final week — review missed items','3-Act Tasks and open-ended modeling','Peer tutoring leadership','Stretch tasks: ACT/SAT-style algebra problems','Self-assessment: identify 1–2 weakest standards and design a study plan','Test-day logistics: calculator, pencils, scratch paper, water/snack'],
      resources:['FLDOE Released EOC','Algebra Nation Test-Yourself','Khan Academy SAT prep math','Open Middle Algebra problems','AMC 8 / AMC 10 Algebra problems']}
  ];
  document.getElementById('action-plan').innerHTML=plans.map(p=>{const tc={1:'var(--green)',2:'var(--sky)',3:'var(--amber)',4:'var(--rose)'}[p.tier];return `<div class="action-card t${p.tier}"><div class="action-header"><span class="action-tier-badge">Tier ${p.tier}</span><div class="action-title">${p.title}</div></div><div style="margin-bottom:14px"><div class="action-section-title">📌 Priority Students (${p.students.length})</div><div class="action-students">${p.students.map(s=>`<span class="student-chip" style="background:${hashColor(s.n)};cursor:pointer" onclick="openStudent('${s.n.replace(/'/g,"&#39;")}')">${s.n}</span>`).join('')}</div></div><div class="action-body"><div><div class="action-section-title">🎯 Priority Standards Focus</div><ul class="action-list">${p.focus.map(f=>`<li>${f}</li>`).join('')}</ul></div><div><div class="action-section-title">🛠 Intervention Strategies</div><ul class="action-list">${p.strategies.map(s=>`<li>${s}</li>`).join('')}</ul></div></div><div style="margin-top:14px;padding-top:12px;border-top:1px solid ${tc}33"><div class="action-section-title">📚 Recommended Resources</div><div style="display:flex;flex-wrap:wrap;gap:6px">${p.resources.map(r=>`<span style="background:${tc}15;color:${tc};padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:600">${r}</span>`).join('')}</div></div></div>`;}).join('');
}

renderOverview();renderDomainView();renderStandards();filterStudentList();renderTiers();renderActionPlan();
</script>
