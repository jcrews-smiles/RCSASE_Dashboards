<script>
// ============================================================
// COUNTDOWN
// ============================================================
const TEST_DATE = new Date('2026-05-12T08:00:00');
function updateCountdown() {
  const now = new Date();
  const diff = TEST_DATE - now;
  if (diff <= 0) {
    ['cd-days','cd-hours','cd-mins','cd-secs'].forEach(id => document.getElementById(id).textContent = '0');
    return;
  }
  const d = Math.floor(diff/86400000);
  const h = Math.floor((diff%86400000)/3600000);
  const m = Math.floor((diff%3600000)/60000);
  const s = Math.floor((diff%60000)/1000);
  document.getElementById('cd-days').textContent = d;
  document.getElementById('cd-hours').textContent = h;
  document.getElementById('cd-mins').textContent = m;
  document.getElementById('cd-secs').textContent = s;
}
updateCountdown();
setInterval(updateCountdown, 1000);

// ============================================================
// SHARED HELPERS
// ============================================================
const PALETTE = ['#0d9488','#7c3aed','#0369a1','#b45309','#be123c','#065f46','#1d4ed8','#6b21a8'];
function hashColor(s) {
  let h = 0;
  for (let c of s) h = (h * 31 + c.charCodeAt(0)) % PALETTE.length;
  return PALETTE[h];
}
function getInitials(n) {
  return n.replace('#','').split(' ').map(w => w[0]).filter(Boolean).slice(0,2).join('').toUpperCase();
}
function pct(n, d) { return d === 0 ? 0 : Math.round(n / d * 100); }
function avgList(arr) {
  const v = arr.filter(x => x != null && !isNaN(x));
  return v.length ? Math.round(v.reduce((a,b) => a+b, 0) / v.length) : 0;
}
function placementBar(label, p, c) {
  return `<div class="placement-bar-wrap"><div class="placement-label"><span>${label}</span><span style="color:${c};font-weight:700">${p}%</span></div><div class="placement-bar-bg"><div class="placement-bar-fill" style="width:${p}%;background:${c}"></div></div></div>`;
}
function scorePillClass(score, has) {
  if (!has || score == null) return 'sp-pend';
  if (score >= 65) return 'sp-bench';
  if (score >= 50) return 'sp-approach';
  if (score >= 35) return 'sp-watch';
  return 'sp-int';
}

// ============================================================
// MASTER VIEW SWITCHER + TAB DELEGATION
// ============================================================
document.addEventListener('click', function(e) {
  // Master view switch
  const viewBtn = e.target.closest('.view-btn[data-view]');
  if (viewBtn) {
    const view = viewBtn.dataset.view;
    document.querySelectorAll('.view-btn').forEach(b => b.classList.toggle('active', b === viewBtn));
    document.querySelectorAll('.view-container').forEach(c => c.classList.toggle('active', c.id === 'view-' + view));
    window.scrollTo(0, 0);
    return;
  }
  // Per-view tab switch
  const tabBtn = e.target.closest('.tab-btn[data-tab]');
  if (tabBtn) {
    const tab = tabBtn.dataset.tab;
    const nav = tabBtn.closest('[data-view-nav]');
    if (!nav) return;
    const view = nav.dataset.viewNav;
    nav.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b === tabBtn));
    const container = document.getElementById('view-' + view);
    container.querySelectorAll(':scope > [data-pane]').forEach(p => {
      p.classList.toggle('active', p.dataset.pane === tab);
    });
    return;
  }
  // Domain sub-tab
  const domTab = e.target.closest('.dom-tab[data-domain]');
  if (domTab) {
    const tabContainer = domTab.closest('.dom-tabs');
    tabContainer.querySelectorAll('.dom-tab').forEach(b => b.classList.toggle('active', b === domTab));
    const view = domTab.dataset.domainView;
    const dom = domTab.dataset.domain;
    if (view === 'alg') Views.alg.showDomain(dom);
    else if (view === 'geo') Views.geo.showDomain(dom);
    else if (view === 'prealg') Views.prealg.showDomain(dom);
    return;
  }
  // Class sub-tab
  const classTab = e.target.closest('.class-tab[data-class-view]');
  if (classTab) {
    const tabContainer = classTab.closest('.dom-tabs');
    tabContainer.querySelectorAll('.class-tab').forEach(b => b.classList.toggle('active', b === classTab));
    const view = classTab.dataset.classView;
    const period = classTab.dataset.period;
    if (view === 'alg') Views.alg.showClass(period);
    else if (view === 'geo') Views.geo.showClass(period);
    else if (view === 'prealg') Views.prealg.showHomeroom(period);
    return;
  }
  // Open student profile
  const stuLink = e.target.closest('[data-open-student]');
  if (stuLink) {
    const view = stuLink.dataset.viewNs;
    const name = stuLink.dataset.openStudent;
    if (Views[view]) Views[view].openStudent(name);
    return;
  }
});

// Search input delegation
document.addEventListener('input', function(e) {
  if (e.target.matches('input[data-search]')) {
    const view = e.target.dataset.search;
    if (Views[view]) Views[view].filter();
  }
});
document.addEventListener('change', function(e) {
  if (e.target.matches('select[data-filter]')) {
    const view = e.target.dataset.filter;
    if (Views[view]) Views[view].filter();
  }
});

// Namespace for view modules
const Views = {};
</script>

