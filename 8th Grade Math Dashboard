    }).join('');
  }
  function openStudent(name) {
    const ind = document.getElementById('view-' + VIEW_ID).querySelector('[data-pane="individual"]');
    if (!ind.classList.contains('active')) {
      document.querySelectorAll('#view-' + VIEW_ID + ' [data-pane]').forEach(p => p.classList.toggle('active', p.dataset.pane === 'individual'));
