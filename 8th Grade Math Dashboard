  }
  
  // ---- STANDARDS ----
  function renderStandards() {
    const crit = STANDARDS.filter(s => s.p === 'Crit');
    const high = STANDARDS.filter(s => s.p === 'High');
    const strong = STANDARDS.filter(s => s.p === 'Low');
    const gapHtml = [...crit, ...high].slice(0, 10).map(s => {
      const cls = s.p === 'Crit' ? 'gap-crit' : 'gap-high';
      return `<div style="padding:10px 0;border-bottom:1px solid ${s.p==='Crit'?'#fecaca':'#fecdd3'};display:flex;gap:10px;align-items:flex-start">
        <span class="std-code" style="${s.p==='Crit'?'background:#fee2e2;color:#7f1d1d;':''}">${s.c}</span>
        <div style="flex:1"><div style="font-weight:700;font-size:.78rem">${s.d}</div>
        <div style="font-size:.7rem;color:var(--slate);margin-top:2px">${s.dom} · ${LABEL_B1}: ${s.b1!=null?Math.round(s.b1)+'%':'—'} → ${LABEL_B3}: ${s.b3!=null?Math.round(s.b3)+'%':'—'}${s.delta!=null?` (Δ ${s.delta>=0?'+':''}${Math.round(s.delta)})`:''}</div></div>
      </div>`;
    }).join('') || '<div style="font-size:.78rem;color:var(--slate);padding:8px 0">No high-need standards ✓</div>';
    
    const strongHtml = strong.slice(0, 10).map(s => `<div style="padding:10px 0;border-bottom:1px solid #bbf7d0;display:flex;gap:10px;align-items:flex-start">
      <span class="std-code" style="background:#dcfce7;color:#166534">${s.c}</span>
      <div style="flex:1"><div style="font-weight:700;font-size:.78rem">${s.d}</div>
      <div style="font-size:.7rem;color:var(--slate);margin-top:2px">${s.dom} · ${LABEL_B3}: ${Math.round(s.b3)}%${s.delta!=null?` (Δ ${s.delta>=0?'+':''}${Math.round(s.delta)})`:''}</div></div>
    </div>`).join('');
    
    const order = {'Crit':0, 'High':1, 'Med':2, 'B1Only':3, 'B2Only':3, 'Low':4};
    const sorted = [...STANDARDS].sort((a,b) => order[a.p] !== order[b.p] ? order[a.p] - order[b.p] : (a.b3||0) - (b.b3||0));
    const tblRows = sorted.map(s => {
      const cls = s.p === 'Crit' ? 'gap-crit' : s.p === 'High' ? 'gap-high' : s.p === 'Med' ? 'gap-med' : (s.p === 'B1Only' || s.p === 'B2Only') ? 'gap-new' : 'gap-low';
      const dlt = s.delta;
      const dCls = dlt == null ? 'delta-zero' : dlt > 0 ? 'delta-pos' : dlt < 0 ? 'delta-neg' : 'delta-zero';
      return `<tr><td style="font-weight:600;color:var(--slate);font-size:.72rem">${s.dom}</td>
        <td><span class="std-code">${s.c}</span></td>
        <td style="font-size:.74rem">${s.d}</td>
        <td>${s.b1!=null?Math.round(s.b1)+'%':'—'}</td>
        <td style="font-weight:700">${s.b3!=null?Math.round(s.b3)+'%':'—'}</td>
        <td class="${dCls}">${dlt!=null?(dlt>=0?'+':'')+Math.round(dlt):'—'}</td>
        <td><span class="gap-pill ${cls}">${s.p}</span></td></tr>`;
    }).join('');
    
    document.getElementById(VIEW_ID + '-standards').innerHTML = `
      <div class="two-col" style="margin-bottom:20px">
        <div class="card"><div class="card-title"><div class="icon" style="background:#ffe4e6">⚠️</div> Highest-Need Standards</div>${gapHtml}</div>
        <div class="card"><div class="card-title"><div class="icon" style="background:#dcfce7">✅</div> Strength Standards</div>${strongHtml}</div>
      </div>
      <div class="card"><div class="card-title"><div class="icon" style="background:#dbeafe">📋</div> Full Standards Mastery Table</div>
      <div class="student-table-wrap"><table class="standards-table"><thead><tr><th>Domain</th><th>Standard</th><th>Description</th><th>${LABEL_B1} Avg</th><th>${LABEL_B3} Avg</th><th>Δ</th><th>Priority</th></tr></thead><tbody>${tblRows}</tbody></table></div></div>
    `;
  }
  
  // ---- INDIVIDUAL ----
  let filteredStudents = [...STUDENTS].sort((a,b) => a.n.localeCompare(b.n));
  let selectedStudent = null;
  
  function renderIndividual() {
    const periods = [...new Set(STUDENTS.map(s => s.p))].sort();
    const periodOpts = periods.map(p => `<option>${p}</option>`).join('');
    document.getElementById(VIEW_ID + '-individual').innerHTML = `
      <div class="student-search-wrap">
        <input type="text" class="search-input" id="${VIEW_ID}-search" data-search="${VIEW_ID}" placeholder="🔍  Search student name...">
        <select class="filter-select" id="${VIEW_ID}-period-filter" data-filter="${VIEW_ID}"><option value="">All Periods</option>${periodOpts}</select>
        <select class="filter-select" id="${VIEW_ID}-tier-filter" data-filter="${VIEW_ID}">
          <option value="">All Tiers</option>
          <option value="1">Tier 1 — At/Above</option>
          <option value="2">Tier 2 — Approaching</option>
          <option value="3">Tier 3 — On Watch</option>
          <option value="4">Tier 4 — Intervention</option>
          <option value="P">Pending ${LABEL_B3}</option>
        </select>
      </div>
      <div style="display:flex;gap:16px;flex-wrap:wrap">
        <div style="width:260px;flex-shrink:0">
          <div class="card" style="padding:14px">
            <div style="font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--slate);margin-bottom:10px">Students <span id="${VIEW_ID}-student-count" style="color:var(--teal)"></span></div>
            <div id="${VIEW_ID}-student-list" style="max-height:560px;overflow-y:auto;display:flex;flex-direction:column;gap:4px"></div>
          </div>
        </div>
        <div style="flex:1;min-width:0"><div id="${VIEW_ID}-profile-wrap"><div class="no-selection"><div class="big">👤</div>Select a student to view their full profile</div></div></div>
      </div>
    `;
    filterList();
  }
  function filterList() {
    const q = (document.getElementById(VIEW_ID + '-search')?.value || '').toLowerCase();
    const period = document.getElementById(VIEW_ID + '-period-filter')?.value || '';
    const tier = document.getElementById(VIEW_ID + '-tier-filter')?.value || '';
    filteredStudents = STUDENTS.filter(s => {
      const matchQ = s.n.toLowerCase().includes(q);
      const matchP = !period || s.p === period;
      const matchT = !tier || String(getTier(s)) === tier;
      return matchQ && matchP && matchT;
    }).sort((a,b) => a.n.localeCompare(b.n));
    renderList();
  }
  function renderList() {
    const el = document.getElementById(VIEW_ID + '-student-list');
    document.getElementById(VIEW_ID + '-student-count').textContent = `(${filteredStudents.length})`;
    if (!filteredStudents.length) {
      el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--slate);font-size:.75rem">No students match filters</div>';
      return;
    }
    el.innerHTML = filteredStudents.map(s => {
      const t = getTier(s);
      const tc = tierColor(t);
      const active = selectedStudent === s.n ? 'background:#f0fdfa;border-color:var(--teal);' : '';
      const tLabel = {1:'T1',2:'T2',3:'T3',4:'T4','P':'P'}[t];
      return `<div data-open-student="${s.n.replace(/"/g,'&quot;')}" data-view-ns="${VIEW_ID}" style="padding:9px 12px;border-radius:8px;cursor:pointer;border:1px solid #e2e8f0;display:flex;align-items:center;gap:8px;${active}">
        <div style="width:28px;height:28px;border-radius:50%;background:${hashColor(s.n)};display:flex;align-items:center;justify-content:center;color:#fff;font-size:.65rem;font-weight:700;flex-shrink:0">${getInitials(s.n)}</div>
        <div style="flex:1;min-width:0"><div style="font-weight:700;font-size:.78rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${s.n}</div>
        <div style="font-size:.65rem;color:var(--slate)">${s.b3!=null?LABEL_B3+': '+Math.round(s.b3)+'%':'No '+LABEL_B3} · ${s.p}</div></div>
        <span style="background:${tc}22;color:${tc};padding:1px 7px;border-radius:12px;font-size:.65rem;font-weight:800;flex-shrink:0">${tLabel}</span>
      </div>`;
    }).join('');
  }
  function openStudent(name) {
    const ind = document.getElementById('view-' + VIEW_ID).querySelector('[data-pane="individual"]');
    if (!ind.classList.contains('active')) {
      document.querySelectorAll('#view-' + VIEW_ID + ' [data-pane]').forEach(p => p.classList.toggle('active', p.dataset.pane === 'individual'));
      document.querySelectorAll('[data-view-nav="' + VIEW_ID + '"] .tab-btn').forEach(b => b.classList.toggle('active', b.dataset.tab === 'individual'));
    }
    showProfile(name);
  }
  function showProfile(name) {
    const s = STUDENTS.find(x => x.n === name);
    if (!s) return;
    selectedStudent = name;
    renderList();
    
    const t = getTier(s);
    const tc = tierColor(t);
    const color = hashColor(s.n);
    const gain = s.g != null ? Math.round(s.g) : null;
    const gainColor = gain == null ? 'var(--slate)' : gain >= 15 ? 'var(--green)' : gain >= 0 ? 'var(--sky)' : 'var(--rose)';
    
    const domCards = Object.entries(s.d).map(([domName, d]) => {
      const b3 = d.b3 != null ? Math.round(d.b3) : null;
      const b1 = d.b1 != null ? Math.round(d.b1) : null;
      const borderColor = b3 == null ? 'var(--slate)' : b3 >= 65 ? 'var(--green)' : b3 >= 50 ? 'var(--sky)' : b3 >= 35 ? 'var(--amber)' : 'var(--rose)';
      return `<div class="domain-pcard" style="border-color:${borderColor}"><div class="dp-title">${domName}</div><div class="dp-placement" style="color:${borderColor}">${b3!=null?b3+'%':'Pending'}</div><div class="dp-score">${LABEL_B1}: ${b1!=null?b1+'%':'—'} · ${d.n} standards</div></div>`;
    }).join('');
    
    const stdRows = studentStandards(s);
    const stdsHtml = `<div class="std-row-header"><div>Standard</div><div>Description</div><div>${LABEL_B1}</div><div>${LABEL_B3}</div><div>Δ</div></div>` +
      [...stdRows].sort((a,b) => (a.b3==null?-1:a.b3) - (b.b3==null?-1:b.b3)).map(st => {
        const b3 = st.b3 != null ? Math.round(st.b3) : null;
        const b1 = st.b1 != null ? Math.round(st.b1) : 0;
        const dlt = st.delta != null ? Math.round(st.delta) : null;
        const b3Cls = scorePillClass(b3, st.b3 != null);
        const b1Cls = st.b1 != null ? scorePillClass(b1, true) : 'sp-pend';
        const dCls = dlt == null ? 'delta-zero' : dlt > 0 ? 'delta-pos' : dlt < 0 ? 'delta-neg' : 'delta-zero';
        return `<div class="std-row"><span class="std-code">${st.c}</span>
          <div style="font-size:.72rem">${st.desc}</div>
          <span class="score-mini ${b1Cls}">${st.b1!=null?b1:'—'}</span>
          <span class="score-mini ${b3Cls}">${b3!=null?b3:'—'}</span>
          <span class="${dCls}" style="font-weight:700">${dlt!=null?(dlt>=0?'+':'')+dlt:'—'}</span></div>`;
      }).join('');
    
    let projection;
    if (t === 1) projection = 'Projected <strong>Pass with confidence</strong> on ' + TEST_NAME;
    else if (t === 2) projection = 'Borderline pass — <strong>focus on weakest standards</strong> in final week';
    else if (t === 3) projection = '<strong>At risk</strong> — intensive intervention needed';
    else if (t === 4) projection = '<strong>High risk</strong> — significant gaps; targeted reteach urgent';
    else projection = LABEL_B3 + ' not yet administered — administer ASAP to identify support needs';
    
    document.getElementById(VIEW_ID + '-profile-wrap').innerHTML = `
      <div style="background:#fff;border-radius:16px;padding:28px;box-shadow:var(--card-shadow)">
        <div class="profile-header">
          <div class="profile-avatar" style="background:${color}">${getInitials(s.n)}</div>
          <div style="flex:1">
            <div class="profile-name">${s.n}</div>
            <div class="profile-meta">Class: ${s.p} · Teacher: ${s.t} · 8th Grade · ${VIEW_ID==='alg'?'Algebra I Honors':'Geometry Honors'}</div>
            <div class="profile-chips">
              <span class="profile-chip" style="background:${tc}22;color:${tc}">${tierLabel(t)}</span>
              ${s.b3!=null?`<span class="profile-chip" style="background:#f0f9ff;color:#0369a1">${LABEL_B3}: ${Math.round(s.b3)}%</span>`:'<span class="profile-chip" style="background:#fef3c7;color:#854d0e">⚠ Pending '+LABEL_B3+'</span>'}
              <span class="profile-chip" style="background:#f5f3ff;color:#6d28d9">${s.wc} weak / ${s.sc} strong</span>
            </div>
          </div>
        </div>
        <div class="profile-grid">
          <div class="profile-metric"><div class="pm-label">${LABEL_B1}</div><div class="pm-value" style="color:var(--slate)">${s.b1!=null?Math.round(s.b1)+'%':'—'}</div><div class="pm-sub">Earlier benchmark</div></div>
          <div class="profile-metric"><div class="pm-label">${LABEL_B3}</div><div class="pm-value" style="color:${tc}">${s.b3!=null?Math.round(s.b3)+'%':'—'}</div><div class="pm-sub">Most recent</div></div>
          <div class="profile-metric"><div class="pm-label">Gain</div><div class="pm-value" style="color:${gainColor}">${gain!=null?(gain>=0?'+':'')+gain:'—'}</div><div class="pm-sub">% mastery growth</div></div>
          <div class="profile-metric"><div class="pm-label">Standards</div><div class="pm-value" style="color:var(--slate);font-size:1.4rem">${STANDARDS.length}</div><div class="pm-sub">MA.912 strands</div></div>
