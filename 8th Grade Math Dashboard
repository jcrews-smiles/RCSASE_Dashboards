    }
    showProfile(name);
  }
  function showProfile(name) {
    const s = STUDENTS.find(x => x.n === name);
    if (!s) return;
    selectedStudent = name;
    renderList();
    
    const t = getTier(s);
    const tc = tierColor(t);
    const color = hashColor(s.n);
    const gain = s.g != null ? Math.round(s.g) : null;
    const gainColor = gain == null ? 'var(--slate)' : gain >= 15 ? 'var(--green)' : gain >= 0 ? 'var(--sky)' : 'var(--rose)';
    
    const domCards = Object.entries(s.d).map(([domName, d]) => {
      const b3 = d.b3 != null ? Math.round(d.b3) : null;
      const b1 = d.b1 != null ? Math.round(d.b1) : null;
      const borderColor = b3 == null ? 'var(--slate)' : b3 >= 65 ? 'var(--green)' : b3 >= 50 ? 'var(--sky)' : b3 >= 35 ? 'var(--amber)' : 'var(--rose)';
      return `<div class="domain-pcard" style="border-color:${borderColor}"><div class="dp-title">${domName}</div><div class="dp-placement" style="color:${borderColor}">${b3!=null?b3+'%':'Pending'}</div><div class="dp-score">${LABEL_B1}: ${b1!=null?b1+'%':'—'} · ${d.n} standards</div></div>`;
    }).join('');
    
    const stdRows = studentStandards(s);
    const stdsHtml = `<div class="std-row-header"><div>Standard</div><div>Description</div><div>${LABEL_B1}</div><div>${LABEL_B3}</div><div>Δ</div></div>` +
      [...stdRows].sort((a,b) => (a.b3==null?-1:a.b3) - (b.b3==null?-1:b.b3)).map(st => {
        const b3 = st.b3 != null ? Math.round(st.b3) : null;
        const b1 = st.b1 != null ? Math.round(st.b1) : 0;
        const dlt = st.delta != null ? Math.round(st.delta) : null;
        const b3Cls = scorePillClass(b3, st.b3 != null);
        const b1Cls = st.b1 != null ? scorePillClass(b1, true) : 'sp-pend';
        const dCls = dlt == null ? 'delta-zero' : dlt > 0 ? 'delta-pos' : dlt < 0 ? 'delta-neg' : 'delta-zero';
        return `<div class="std-row"><span class="std-code">${st.c}</span>
          <div style="font-size:.72rem">${st.desc}</div>
          <span class="score-mini ${b1Cls}">${st.b1!=null?b1:'—'}</span>
          <span class="score-mini ${b3Cls}">${b3!=null?b3:'—'}</span>
          <span class="${dCls}" style="font-weight:700">${dlt!=null?(dlt>=0?'+':'')+dlt:'—'}</span></div>`;
      }).join('');
    
    let projection;
    if (t === 1) projection = 'Projected <strong>Pass with confidence</strong> on ' + TEST_NAME;
    else if (t === 2) projection = 'Borderline pass — <strong>focus on weakest standards</strong> in final week';
    else if (t === 3) projection = '<strong>At risk</strong> — intensive intervention needed';
    else if (t === 4) projection = '<strong>High risk</strong> — significant gaps; targeted reteach urgent';
    else projection = LABEL_B3 + ' not yet administered — administer ASAP to identify support needs';
    
    document.getElementById(VIEW_ID + '-profile-wrap').innerHTML = `
      <div style="background:#fff;border-radius:16px;padding:28px;box-shadow:var(--card-shadow)">
        <div class="profile-header">
          <div class="profile-avatar" style="background:${color}">${getInitials(s.n)}</div>
          <div style="flex:1">
            <div class="profile-name">${s.n}</div>
            <div class="profile-meta">Class: ${s.p} · Teacher: ${s.t} · 8th Grade · ${VIEW_ID==='alg'?'Algebra I Honors':'Geometry Honors'}</div>
            <div class="profile-chips">
              <span class="profile-chip" style="background:${tc}22;color:${tc}">${tierLabel(t)}</span>
              ${s.b3!=null?`<span class="profile-chip" style="background:#f0f9ff;color:#0369a1">${LABEL_B3}: ${Math.round(s.b3)}%</span>`:'<span class="profile-chip" style="background:#fef3c7;color:#854d0e">⚠ Pending '+LABEL_B3+'</span>'}
              <span class="profile-chip" style="background:#f5f3ff;color:#6d28d9">${s.wc} weak / ${s.sc} strong</span>
            </div>
          </div>
        </div>
        <div class="profile-grid">
          <div class="profile-metric"><div class="pm-label">${LABEL_B1}</div><div class="pm-value" style="color:var(--slate)">${s.b1!=null?Math.round(s.b1)+'%':'—'}</div><div class="pm-sub">Earlier benchmark</div></div>
          <div class="profile-metric"><div class="pm-label">${LABEL_B3}</div><div class="pm-value" style="color:${tc}">${s.b3!=null?Math.round(s.b3)+'%':'—'}</div><div class="pm-sub">Most recent</div></div>
          <div class="profile-metric"><div class="pm-label">Gain</div><div class="pm-value" style="color:${gainColor}">${gain!=null?(gain>=0?'+':'')+gain:'—'}</div><div class="pm-sub">% mastery growth</div></div>
          <div class="profile-metric"><div class="pm-label">Standards</div><div class="pm-value" style="color:var(--slate);font-size:1.4rem">${STANDARDS.length}</div><div class="pm-sub">MA.912 strands</div></div>
          <div class="profile-metric"><div class="pm-label">Standards ≥ 70%</div><div class="pm-value" style="color:var(--green)">${s.sc}</div><div class="pm-sub">At benchmark</div></div>
          <div class="profile-metric"><div class="pm-label">Standards &lt; 50%</div><div class="pm-value" style="color:var(--rose)">${s.wc}</div><div class="pm-sub">Need work</div></div>
        </div>
        <div class="card-title" style="margin-bottom:12px"><div class="icon" style="background:#dbeafe">📊</div> Domain Performance</div>
        <div class="domain-profile">${domCards}</div>
        <div style="margin-top:14px;padding:10px 12px;background:${t<=2?'#f0fdf4':t===3?'#fef3c7':'#fef2f2'};border-radius:8px;border-left:4px solid ${tc};font-size:.74rem;line-height:1.5;margin-bottom:20px">
          <strong>${TEST_SHORT} Projection:</strong> ${projection}.
        </div>
        <div class="card-title" style="margin-bottom:10px"><div class="icon" style="background:#fef3c7">📋</div> Per-Standard Mastery (sorted by ${LABEL_B3} ascending — weakest first)</div>
        <div style="max-height:600px;overflow-y:auto;padding:0 4px">${stdsHtml}</div>
      </div>
    `;
  }
  
  // ---- TIERS ----
  function renderTiers() {
    const t1 = STUDENTS.filter(s => getTier(s) === 1);
    const t2 = STUDENTS.filter(s => getTier(s) === 2);
    const t3 = STUDENTS.filter(s => getTier(s) === 3);
    const t4 = STUDENTS.filter(s => getTier(s) === 4 || getTier(s) === 'P');
    function rl(stu) {
      return stu.map(s => {
        const c = hashColor(s.n);
        const b3D = s.b3 != null ? Math.round(s.b3) + '%' : 'Pending ' + LABEL_B3;
        return `<li class="tier-student" data-open-student="${s.n.replace(/"/g,'&quot;')}" data-view-ns="${VIEW_ID}">
          <div class="tier-avatar" style="background:${c}">${getInitials(s.n)}</div>
          <div class="tier-info"><div class="tier-sname">${s.n}</div>
          <div class="tier-room">${b3D} · ${LABEL_B1} ${Math.round(s.b1||0)}%${s.g!=null?' · Δ '+(s.g>=0?'+':'')+Math.round(s.g):''}</div></div>
        </li>`;
      }).join('');
    }
    document.getElementById(VIEW_ID + '-tiers').innerHTML = `
      <div class="legend-row">
        <div class="legend-item"><div class="legend-dot" style="background:var(--green)"></div><strong>Tier 1</strong> – At/Above Benchmark (${LABEL_B3} ≥ 65%)</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--sky)"></div><strong>Tier 2</strong> – Approaching (${LABEL_B3} 50–64%)</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--amber)"></div><strong>Tier 3</strong> – On Watch (${LABEL_B3} 35–49%)</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--rose)"></div><strong>Tier 4</strong> – Intervention (${LABEL_B3} &lt; 35% or pending)</div>
      </div>
      <div class="tier-grid">
        <div class="tier-card t1"><div class="tier-head"><div class="tier-num">1</div><div><div class="tier-title">At/Above Benchmark</div><div class="tier-count">${t1.length} students · ${LABEL_B3} ≥ 65%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t1)}</ul></div>
        <div class="tier-card t2"><div class="tier-head"><div class="tier-num">2</div><div><div class="tier-title">Approaching</div><div class="tier-count">${t2.length} students · ${LABEL_B3} 50–64%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t2)}</ul></div>
        <div class="tier-card t3"><div class="tier-head"><div class="tier-num">3</div><div><div class="tier-title">On Watch</div><div class="tier-count">${t3.length} students · ${LABEL_B3} 35–49%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t3)}</ul></div>
        <div class="tier-card t4"><div class="tier-head"><div class="tier-num">4</div><div><div class="tier-title">Intervention</div><div class="tier-count">${t4.length} students · ${LABEL_B3} &lt; 35% or pending</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t4)}</ul></div>
      </div>
    `;
  }
  
  // expose data + helpers for cohort-specific action plan
  Views[VIEW_ID] = { 
    openStudent, filter: filterList, showClass,
    STUDENTS, STANDARDS, getTier, tierColor, tierLabel
  };
  
  // Init
  renderOverview();
  renderClassView();
  renderStandards();
  renderIndividual();
  renderTiers();
  // (Action plan rendered separately so we can customize per cohort)
  if (typeof window['render' + VIEW_ID + 'Action'] === 'function') window['render' + VIEW_ID + 'Action']();
})();
</script>
