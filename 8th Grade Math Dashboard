          <div class="profile-metric"><div class="pm-label">Standards &lt; 50%</div><div class="pm-value" style="color:var(--rose)">${s.wc}</div><div class="pm-sub">Need work</div></div>
        </div>
        <div class="card-title" style="margin-bottom:12px"><div class="icon" style="background:#dbeafe">📊</div> Domain Performance</div>
        <div class="domain-profile">${domCards}</div>
        <div style="margin-top:14px;padding:10px 12px;background:${t<=2?'#f0fdf4':t===3?'#fef3c7':'#fef2f2'};border-radius:8px;border-left:4px solid ${tc};font-size:.74rem;line-height:1.5;margin-bottom:20px">
          <strong>${TEST_SHORT} Projection:</strong> ${projection}.
        </div>
        <div class="card-title" style="margin-bottom:10px"><div class="icon" style="background:#fef3c7">📋</div> Per-Standard Mastery (sorted by ${LABEL_B3} ascending — weakest first)</div>
        <div style="max-height:600px;overflow-y:auto;padding:0 4px">${stdsHtml}</div>
      </div>
    `;
  }
  
  // ---- TIERS ----
  function renderTiers() {
    const t1 = STUDENTS.filter(s => getTier(s) === 1);
    const t2 = STUDENTS.filter(s => getTier(s) === 2);
    const t3 = STUDENTS.filter(s => getTier(s) === 3);
    const t4 = STUDENTS.filter(s => getTier(s) === 4 || getTier(s) === 'P');
    function rl(stu) {
      return stu.map(s => {
        const c = hashColor(s.n);
        const b3D = s.b3 != null ? Math.round(s.b3) + '%' : 'Pending ' + LABEL_B3;
        return `<li class="tier-student" data-open-student="${s.n.replace(/"/g,'&quot;')}" data-view-ns="${VIEW_ID}">
          <div class="tier-avatar" style="background:${c}">${getInitials(s.n)}</div>
          <div class="tier-info"><div class="tier-sname">${s.n}</div>
          <div class="tier-room">${b3D} · ${LABEL_B1} ${Math.round(s.b1||0)}%${s.g!=null?' · Δ '+(s.g>=0?'+':'')+Math.round(s.g):''}</div></div>
        </li>`;
      }).join('');
    }
    document.getElementById(VIEW_ID + '-tiers').innerHTML = `
      <div class="legend-row">
        <div class="legend-item"><div class="legend-dot" style="background:var(--green)"></div><strong>Tier 1</strong> – At/Above Benchmark (${LABEL_B3} ≥ 65%)</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--sky)"></div><strong>Tier 2</strong> – Approaching (${LABEL_B3} 50–64%)</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--amber)"></div><strong>Tier 3</strong> – On Watch (${LABEL_B3} 35–49%)</div>
        <div class="legend-item"><div class="legend-dot" style="background:var(--rose)"></div><strong>Tier 4</strong> – Intervention (${LABEL_B3} &lt; 35% or pending)</div>
      </div>
      <div class="tier-grid">
        <div class="tier-card t1"><div class="tier-head"><div class="tier-num">1</div><div><div class="tier-title">At/Above Benchmark</div><div class="tier-count">${t1.length} students · ${LABEL_B3} ≥ 65%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t1)}</ul></div>
        <div class="tier-card t2"><div class="tier-head"><div class="tier-num">2</div><div><div class="tier-title">Approaching</div><div class="tier-count">${t2.length} students · ${LABEL_B3} 50–64%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t2)}</ul></div>
        <div class="tier-card t3"><div class="tier-head"><div class="tier-num">3</div><div><div class="tier-title">On Watch</div><div class="tier-count">${t3.length} students · ${LABEL_B3} 35–49%</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t3)}</ul></div>
        <div class="tier-card t4"><div class="tier-head"><div class="tier-num">4</div><div><div class="tier-title">Intervention</div><div class="tier-count">${t4.length} students · ${LABEL_B3} &lt; 35% or pending</div></div></div><ul class="tier-student-list" style="max-height:480px;overflow-y:auto">${rl(t4)}</ul></div>
      </div>
    `;
  }
  
  // expose data + helpers for cohort-specific action plan
  Views[VIEW_ID] = { 
    openStudent, filter: filterList, showClass,
    STUDENTS, STANDARDS, getTier, tierColor, tierLabel
  };
  
  // Init
  renderOverview();
  renderClassView();
  renderStandards();
  renderIndividual();
  renderTiers();
  // (Action plan rendered separately so we can customize per cohort)
  if (typeof window['render' + VIEW_ID + 'Action'] === 'function') window['render' + VIEW_ID + 'Action']();
})();
</script>

