    renderList();
  }
  function renderList() {
    const el = document.getElementById(VIEW_ID + '-student-list');
    document.getElementById(VIEW_ID + '-student-count').textContent = `(${filteredStudents.length})`;
    if (!filteredStudents.length) {
      el.innerHTML = '<div style="padding:20px;text-align:center;color:var(--slate);font-size:.75rem">No students match filters</div>';
      return;
    }
    el.innerHTML = filteredStudents.map(s => {
      const t = getTier(s);
      const tc = tierColor(t);
      const active = selectedStudent === s.n ? 'background:#f0fdfa;border-color:var(--teal);' : '';
