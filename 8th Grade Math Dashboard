<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>8th Grade Math — Combined Dashboard (PreAlgebra + Algebra I + Geometry)</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--navy:#0f1e3c;--navy2:#162849;--teal:#0d9488;--teal-light:#5eead4;--amber:#f59e0b;--amber-light:#fde68a;--rose:#e11d48;--rose-light:#fecdd3;--violet:#7c3aed;--violet-light:#ddd6fe;--sky:#0ea5e9;--sky-light:#bae6fd;--green:#10b981;--green-light:#a7f3d0;--slate:#64748b;--cream:#f8f5f0;--white:#fff;--card-shadow:0 4px 24px rgba(15,30,60,.12)}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--navy);min-height:100vh}
header{background:var(--navy);color:#fff;position:sticky;top:0;z-index:100;box-shadow:0 2px 20px rgba(0,0,0,.35)}
.master-bar{background:#0a1632;padding:14px 32px;display:flex;align-items:center;gap:16px;border-bottom:2px solid #1e2d52;flex-wrap:wrap}
.master-title{font-family:'DM Serif Display',serif;color:#5eead4;font-size:1.05rem;margin-right:auto}
.view-btn{background:rgba(255,255,255,.08);color:#94a3b8;border:1px solid rgba(255,255,255,.15);padding:8px 18px;border-radius:8px;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.82rem;cursor:pointer;letter-spacing:.4px;text-transform:uppercase;transition:all .2s}
.view-btn:hover{filter:brightness(1.2)}
.view-btn.active{background:var(--teal);color:#fff;border-color:var(--teal)}
.header-inner{display:flex;align-items:center;justify-content:space-between;padding:14px 32px;gap:24px;flex-wrap:wrap}
.header-title h1{font-family:'DM Serif Display',serif;font-size:1.45rem;line-height:1.2}
.header-title span{font-size:.75rem;color:var(--teal-light);font-weight:500;letter-spacing:.8px;text-transform:uppercase;margin-top:2px;display:block}
.countdown-box{display:flex;align-items:center;gap:14px;background:linear-gradient(135deg,#be123c,#7c3aed);border:1px solid rgba(255,255,255,.2);border-radius:10px;padding:10px 18px}
.cd-icon{font-size:1.7rem}.cd-body{display:flex;flex-direction:column}
.cd-top{display:flex;justify-content:space-between;align-items:baseline;gap:12px;margin-bottom:4px}
.countdown-label{font-size:.62rem;text-transform:uppercase;letter-spacing:1px;color:#fde68a;font-weight:800}
.countdown-date{font-size:.72rem;color:#fde68a;font-weight:600}
.cd-grid{display:flex;gap:8px}
.cd-unit{display:flex;flex-direction:column;align-items:center;min-width:34px}
.cd-val{font-family:'DM Serif Display',serif;font-size:1.4rem;color:#fff;line-height:1;font-weight:700}
.cd-lbl-small{font-size:.55rem;color:#e9d5ff;text-transform:uppercase;letter-spacing:.5px;font-weight:700;margin-top:2px}
.tab-nav{display:flex;background:var(--navy2);padding:0 32px;border-bottom:2px solid rgba(255,255,255,.06);overflow-x:auto}
.tab-btn{background:none;border:none;color:#94a3b8;padding:11px 22px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:600;cursor:pointer;border-bottom:3px solid transparent;transition:all .2s;white-space:nowrap;letter-spacing:.4px;text-transform:uppercase}
.tab-btn:hover{color:#fff}.tab-btn.active{color:var(--teal-light);border-bottom-color:var(--teal)}
main{padding:28px 32px;max-width:1600px;margin:0 auto}
.tab-pane{display:none;animation:fadeIn .25s ease}.tab-pane.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.section-title{font-family:'DM Serif Display',serif;font-size:1.5rem;color:var(--navy);margin-bottom:6px}
.section-sub{font-size:.82rem;color:var(--slate);margin-bottom:22px}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(168px,1fr));gap:14px;margin-bottom:28px}
.stat-card{background:#fff;border-radius:12px;padding:18px 20px;box-shadow:var(--card-shadow);position:relative;overflow:hidden}
.stat-card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:var(--accent,var(--teal));border-radius:12px 12px 0 0}
.stat-label{font-size:.7rem;text-transform:uppercase;letter-spacing:.8px;color:var(--slate);font-weight:600;margin-bottom:8px}
.stat-value{font-family:'DM Serif Display',serif;font-size:2rem;line-height:1;color:var(--navy);margin-bottom:4px}
.stat-detail{font-size:.75rem;color:var(--slate)}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
@media (max-width:960px){.two-col{grid-template-columns:1fr}}
.card{background:#fff;border-radius:14px;padding:22px 24px;box-shadow:var(--card-shadow)}
.card-title{font-family:'DM Serif Display',serif;font-size:1.05rem;margin-bottom:16px;display:flex;align-items:center;gap:10px}
.card-title .icon{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:.85rem;flex-shrink:0}
.placement-bar-wrap{margin-bottom:10px}
.placement-label{font-size:.75rem;font-weight:600;margin-bottom:4px;display:flex;justify-content:space-between}
.placement-bar-bg{background:#e2e8f0;border-radius:6px;height:10px;overflow:hidden}
.placement-bar-fill{height:100%;border-radius:6px;transition:width .8s ease}
.domain-bars{display:flex;flex-direction:column;gap:10px}
.domain-name{font-size:.75rem;font-weight:600;color:var(--slate);margin-bottom:3px;display:flex;justify-content:space-between}
.domain-bar-bg{background:#e2e8f0;border-radius:6px;height:22px;position:relative;overflow:hidden}
.domain-bar-fill{height:100%;border-radius:6px;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;font-size:.65rem;color:#fff;font-weight:700;transition:width .8s}
.domain-bar-benchmark{position:absolute;top:0;bottom:0;width:2px;background:var(--rose)}
.standards-table{width:100%;border-collapse:collapse;font-size:.78rem}
.standards-table th{background:var(--navy);color:#fff;padding:9px 12px;text-align:left;font-weight:600;font-size:.7rem;letter-spacing:.5px;text-transform:uppercase}
.standards-table td{padding:8px 12px;border-bottom:1px solid #f1f5f9;vertical-align:top}
.standards-table tr:hover td{background:#f8fafc}
.std-code{font-family:monospace;font-size:.7rem;background:#e0f2fe;color:#0369a1;padding:2px 6px;border-radius:4px;white-space:nowrap;font-weight:700}
.gap-pill{display:inline-block;padding:2px 7px;border-radius:20px;font-size:.65rem;font-weight:700}
.gap-high{background:#fecdd3;color:#be123c}
.gap-med{background:#fde68a;color:#92400e}
.gap-low{background:#bbf7d0;color:#065f46}
.gap-crit{background:#fee2e2;color:#7f1d1d;border:1px solid #fecaca}
.gap-new{background:#e9d5ff;color:#581c87}
.student-table-wrap{overflow-x:auto}
.student-table{width:100%;border-collapse:collapse;font-size:.76rem}
.student-table th{background:var(--navy);color:#fff;padding:9px 11px;text-align:left;font-size:.68rem;letter-spacing:.4px;text-transform:uppercase;font-weight:600;white-space:nowrap}
.student-table td{padding:8px 11px;border-bottom:1px solid #f1f5f9;white-space:nowrap}
.student-table tr:hover td{background:#f8fafc}
.score-pill{display:inline-block;padding:3px 10px;border-radius:20px;font-size:.68rem;font-weight:800;min-width:56px;text-align:center}
.sp-bench{background:#d1fae5;color:#065f46}.sp-approach{background:#dbeafe;color:#1e40af}
.sp-watch{background:#fef3c7;color:#854d0e}.sp-int{background:#fee2e2;color:#991b1b}
.sp-pend{background:#f1f5f9;color:#475569}
.tier-grid{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:14px;margin-bottom:24px}
@media (max-width:1100px){.tier-grid{grid-template-columns:1fr 1fr}}
@media (max-width:700px){.tier-grid{grid-template-columns:1fr}}
.tier-card{border-radius:14px;padding:20px 22px;box-shadow:var(--card-shadow);border-top:5px solid}
.tier-card.t1{background:#f0fdf4;border-color:var(--green)}
.tier-card.t2{background:#eff6ff;border-color:var(--sky)}
.tier-card.t3{background:#fffbeb;border-color:var(--amber)}
.tier-card.t4{background:#fff1f2;border-color:var(--rose)}
.tier-head{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.tier-num{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem;flex-shrink:0;color:#fff}
.t1 .tier-num{background:var(--green)}.t2 .tier-num{background:var(--sky)}
.t3 .tier-num{background:var(--amber)}.t4 .tier-num{background:var(--rose)}
.tier-title{font-family:'DM Serif Display',serif;font-size:1rem}
.tier-count{font-size:.8rem;color:var(--slate);margin-top:1px}
.tier-student-list{list-style:none;display:flex;flex-direction:column;gap:6px}
.tier-student{background:#fff;border-radius:8px;padding:8px 12px;display:flex;align-items:center;gap:8px;box-shadow:0 1px 4px rgba(0,0,0,.06);cursor:pointer}
.tier-avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.72rem;flex-shrink:0;color:#fff}
.tier-info{flex:1;min-width:0}
.tier-sname{font-weight:700;font-size:.76rem}
.tier-room{font-size:.62rem;color:var(--slate)}
.action-card{background:#fff;border-radius:14px;padding:22px 24px;box-shadow:var(--card-shadow);margin-bottom:18px;border-left:5px solid}
.action-card.t4{border-color:var(--rose)}.action-card.t3{border-color:var(--amber)}
.action-card.t2{border-color:var(--sky)}.action-card.t1{border-color:var(--green)}
.action-header{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.action-tier-badge{padding:4px 12px;border-radius:20px;font-size:.72rem;font-weight:800;letter-spacing:.4px;text-transform:uppercase;color:#fff}
.t4 .action-tier-badge{background:var(--rose)}.t3 .action-tier-badge{background:var(--amber)}
.t2 .action-tier-badge{background:var(--sky)}.t1 .action-tier-badge{background:var(--green)}
.action-title{font-family:'DM Serif Display',serif;font-size:1.08rem}
.action-body{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media (max-width:800px){.action-body{grid-template-columns:1fr}}
.action-section-title{font-size:.7rem;text-transform:uppercase;letter-spacing:.7px;font-weight:700;color:var(--slate);margin-bottom:8px}
.action-list{list-style:none;display:flex;flex-direction:column;gap:6px}
.action-list li{font-size:.78rem;display:flex;gap:8px;line-height:1.4}
.action-list li::before{content:'▸';color:var(--teal);flex-shrink:0;margin-top:1px}
.action-students{display:flex;flex-wrap:wrap;gap:6px;margin-top:10px}
.student-chip{background:var(--navy);color:#fff;border-radius:20px;padding:4px 11px;font-size:.7rem;font-weight:600;cursor:pointer}
.student-search-wrap{margin-bottom:20px;display:flex;gap:12px;flex-wrap:wrap}
.search-input{flex:1;min-width:220px;border:2px solid #e2e8f0;border-radius:10px;padding:10px 16px;font-family:'DM Sans',sans-serif;font-size:.88rem;outline:none;transition:border .2s}
.search-input:focus{border-color:var(--teal)}
.filter-select{border:2px solid #e2e8f0;border-radius:10px;padding:10px 14px;font-family:'DM Sans',sans-serif;font-size:.85rem;outline:none;background:#fff;cursor:pointer}
.profile-header{display:flex;align-items:center;gap:20px;margin-bottom:24px;padding-bottom:20px;border-bottom:2px solid #f1f5f9;flex-wrap:wrap}
.profile-avatar{width:64px;height:64px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:'DM Serif Display',serif;font-size:1.6rem;color:#fff;flex-shrink:0}
.profile-name{font-family:'DM Serif Display',serif;font-size:1.5rem}
.profile-meta{font-size:.8rem;color:var(--slate);margin-top:4px}
.profile-chips{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
.profile-chip{padding:4px 12px;border-radius:20px;font-size:.72rem;font-weight:700}
.profile-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:14px;margin-bottom:20px}
.profile-metric{background:#f8fafc;border-radius:10px;padding:14px;text-align:center}
.pm-label{font-size:.65rem;text-transform:uppercase;letter-spacing:.7px;color:var(--slate);font-weight:600;margin-bottom:6px}
.pm-value{font-family:'DM Serif Display',serif;font-size:1.6rem;line-height:1}
.pm-sub{font-size:.68rem;color:var(--slate);margin-top:3px}
.domain-profile{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
@media (max-width:700px){.domain-profile{grid-template-columns:1fr}}
.domain-pcard{background:#f8fafc;border-radius:10px;padding:14px 16px;border-left:4px solid}
.dp-title{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--slate);margin-bottom:6px}
.dp-placement{font-weight:700;font-size:1rem;margin-bottom:4px}
.dp-score{font-size:.75rem;color:var(--slate)}
.no-selection{text-align:center;padding:60px 20px;color:var(--slate);font-size:.9rem}
.no-selection .big{font-size:2.5rem;margin-bottom:10px}
::-webkit-scrollbar{width:6px;height:6px}
::-webkit-scrollbar-track{background:#f1f5f9;border-radius:3px}
::-webkit-scrollbar-thumb{background:#94a3b8;border-radius:3px}
.legend-row{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:14px}
.legend-item{display:flex;align-items:center;gap:5px;font-size:.72rem;color:var(--slate)}
.legend-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.callout{background:linear-gradient(135deg,#fef3c7 0%,#fde68a 100%);border-radius:12px;padding:14px 18px;margin-bottom:18px;border-left:5px solid var(--amber);display:flex;gap:12px;align-items:flex-start}
.callout-icon{font-size:1.5rem;flex-shrink:0}
.callout-title{font-weight:800;font-size:.82rem;color:#78350f;margin-bottom:3px}
.callout-txt{font-size:.75rem;color:#78350f;line-height:1.5}
.callout-rose{background:linear-gradient(135deg,#fecdd3 0%,#fca5a5 100%);border-color:var(--rose)}
.callout-rose .callout-title,.callout-rose .callout-txt{color:#7f1d1d}
.std-row{display:grid;grid-template-columns:130px 1fr 110px 110px 60px;gap:10px;padding:8px 0;border-bottom:1px solid #f1f5f9;align-items:center;font-size:.75rem}
.std-row-header{display:grid;grid-template-columns:130px 1fr 110px 110px 60px;gap:10px;padding:9px 0;border-bottom:2px solid var(--navy);font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:var(--slate)}
.score-mini{display:inline-block;min-width:44px;padding:3px 8px;border-radius:14px;font-size:.68rem;font-weight:800;text-align:center}
.delta-pos{color:var(--green);font-weight:700}.delta-neg{color:var(--rose);font-weight:700}.delta-zero{color:var(--slate)}
.dom-tabs{display:flex;border-bottom:2px solid #e2e8f0;margin-bottom:22px;flex-wrap:wrap}
.dom-tab{padding:9px 16px;background:none;border:none;font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:600;cursor:pointer;color:var(--slate);border-bottom:3px solid transparent;margin-bottom:-2px;transition:all .2s}
.dom-tab.active{color:var(--teal);border-bottom-color:var(--teal)}
.dom-tab:hover{color:var(--navy)}
.support-chip{background:#fef9c3;color:#854d0e;padding:2px 7px;border-radius:10px;font-size:.62rem;font-weight:700;margin-left:5px}
.view-container{display:none}
.view-container.active{display:block}
@media print{header{position:static}.tab-btn{display:none}.tab-pane{display:block!important;page-break-after:always}}
</style>
</head>
<body>

<header>
  <div class="master-bar">
    <div class="master-title">📐 8th Grade Math &mdash; Combined Dashboard</div>
    <button class="view-btn active" data-view="prealg">📊 PreAlgebra (iReady)</button>
    <button class="view-btn" data-view="alg">📐 Algebra I</button>
    <button class="view-btn" data-view="geo">🔷 Geometry</button>
    <div class="countdown-box">
      <div class="cd-icon">⏳</div>
      <div class="cd-body">
        <div class="cd-top">
          <div class="countdown-label">All 3 Tests · May 12, 2026</div>
          <div class="countdown-date">FAST PM3 · Alg I EOC · Geo EOC</div>
        </div>
        <div class="cd-grid">
          <div class="cd-unit"><div class="cd-val" id="cd-days">--</div><div class="cd-lbl-small">Days</div></div>
          <div class="cd-unit"><div class="cd-val" id="cd-hours">--</div><div class="cd-lbl-small">Hrs</div></div>
          <div class="cd-unit"><div class="cd-val" id="cd-mins">--</div><div class="cd-lbl-small">Min</div></div>
          <div class="cd-unit"><div class="cd-val" id="cd-secs">--</div><div class="cd-lbl-small">Sec</div></div>
        </div>
      </div>
    </div>
  </div>
</header>

<main>

<!-- ============== PREALGEBRA VIEW ============== -->
<div id="view-prealg" class="view-container active">
  <div class="header-title" style="margin-bottom:18px">
    <h2 style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--navy)">PreAlgebra (iReady) — M/J Pre-Alg G8 · Rutledge</h2>
    <span style="font-size:.78rem;color:var(--slate);font-weight:500;letter-spacing:.6px;text-transform:uppercase;margin-top:4px;display:block">YTD Diagnostic Analysis · 19 students · Daniell &amp; Harned homerooms · FAST PM3 May 12, 2026</span>
  </div>
  <nav class="tab-nav" data-view-nav="prealg" style="margin:-10px -32px 22px;border-radius:0">
    <button class="tab-btn active" data-tab="overview">📊 Overview</button>
    <button class="tab-btn" data-tab="class">🏫 Homeroom</button>
    <button class="tab-btn" data-tab="domains">📚 Domains</button>
    <button class="tab-btn" data-tab="individual">👤 Individual</button>
    <button class="tab-btn" data-tab="tiers">🎯 Tier Placement</button>
    <button class="tab-btn" data-tab="action">📝 Action Plan</button>
  </nav>
  <div data-pane="overview" class="tab-pane active" id="prealg-overview"></div>
  <div data-pane="class" class="tab-pane" id="prealg-class"></div>
  <div data-pane="domains" class="tab-pane" id="prealg-domains"></div>
  <div data-pane="individual" class="tab-pane" id="prealg-individual"></div>
  <div data-pane="tiers" class="tab-pane" id="prealg-tiers"></div>
  <div data-pane="action" class="tab-pane" id="prealg-action"></div>
</div>

<!-- ============== ALGEBRA I VIEW ============== -->
<div id="view-alg" class="view-container">
  <div class="header-title" style="margin-bottom:18px">
    <h2 style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--navy)">Algebra I Honors — Seker</h2>
    <span style="font-size:.78rem;color:var(--slate);font-weight:500;letter-spacing:.6px;text-transform:uppercase;margin-top:4px;display:block">B.E.S.T. EOC Practice V1 → V3 · Florida MA.912 Standards · 39 students · 2 periods · EOC May 12, 2026</span>
  </div>
  <nav class="tab-nav" data-view-nav="alg" style="margin:-10px -32px 22px;border-radius:0">
    <button class="tab-btn active" data-tab="overview">📊 Overview</button>
    <button class="tab-btn" data-tab="class">🏫 Class View</button>
    <button class="tab-btn" data-tab="standards">📋 Standards &amp; Gaps</button>
    <button class="tab-btn" data-tab="individual">👤 Individual</button>
    <button class="tab-btn" data-tab="tiers">🎯 Tier Placement</button>
    <button class="tab-btn" data-tab="action">📝 Action Plan</button>
  </nav>
  <div data-pane="overview" class="tab-pane active" id="alg-overview"></div>
  <div data-pane="class" class="tab-pane" id="alg-class"></div>
  <div data-pane="standards" class="tab-pane" id="alg-standards"></div>
  <div data-pane="individual" class="tab-pane" id="alg-individual"></div>
  <div data-pane="tiers" class="tab-pane" id="alg-tiers"></div>
  <div data-pane="action" class="tab-pane" id="alg-action"></div>
</div>

<!-- ============== GEOMETRY VIEW ============== -->
<div id="view-geo" class="view-container">
  <div class="header-title" style="margin-bottom:18px">
    <h2 style="font-family:'DM Serif Display',serif;font-size:1.6rem;color:var(--navy)">Geometry Honors — Rutledge P00</h2>
    <span style="font-size:.78rem;color:var(--slate);font-weight:500;letter-spacing:.6px;text-transform:uppercase;margin-top:4px;display:block">B.E.S.T. EOC Practice V2 → V3 · Florida MA.912 GR/T/LT Standards · 13 students · EOC May 12, 2026</span>
  </div>
  <nav class="tab-nav" data-view-nav="geo" style="margin:-10px -32px 22px;border-radius:0">
    <button class="tab-btn active" data-tab="overview">📊 Overview</button>
    <button class="tab-btn" data-tab="class">🏫 Class View</button>
    <button class="tab-btn" data-tab="standards">📋 Standards &amp; Gaps</button>
    <button class="tab-btn" data-tab="individual">👤 Individual</button>
    <button class="tab-btn" data-tab="tiers">🎯 Tier Placement</button>
    <button class="tab-btn" data-tab="action">📝 Action Plan</button>
  </nav>
  <div data-pane="overview" class="tab-pane active" id="geo-overview"></div>
