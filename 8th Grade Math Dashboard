    filterList();
  }
  function filterList() {
    const q = (document.getElementById(VIEW_ID + '-search')?.value || '').toLowerCase();
    const period = document.getElementById(VIEW_ID + '-period-filter')?.value || '';
    const tier = document.getElementById(VIEW_ID + '-tier-filter')?.value || '';
    filteredStudents = STUDENTS.filter(s => {
      const matchQ = s.n.toLowerCase().includes(q);
      const matchP = !period || s.p === period;
      const matchT = !tier || String(getTier(s)) === tier;
      return matchQ && matchP && matchT;
