  ];
  let domHTML = domains.map(d=>{
    const onGL = s.filter(x=>x[d.relKey]==='Mid or Above Grade Level'||x[d.relKey]==='Early On Grade Level').length;
    const pv = pct(onGL, s.length);
    const color = pv>=75?'var(--green)':pv>=60?'var(--teal)':pv>=45?'var(--amber)':'var(--rose)';
