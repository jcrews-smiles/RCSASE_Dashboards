// OVERVIEW
function renderOverview() {
  const s = STUDENTS;
  const avgGain = avg(s,'gain');
  const avgScore = avg(s,'overall_score');
  const pctTypical = Math.round(avg(s.filter(x=>x.pct_typical>0),'pct_typical'));
  const belowGL = s.filter(x=>isBelowGrade(x.placement)).length;
  const aboveGL = s.filter(x=>['Early 2','Mid 2','Late 2','Max Score','Grade 3','Grade 4','Grade 5'].includes(x.placement)).length;
  const typMet = s.filter(x=>x.pct_typical >= 100).length;
  const stretchMet = s.filter(x=>x.pct_stretch >= 100).length;

  const statsHTML = [
    {label:'Total Students',value:s.length,detail:'Across 5 homerooms',color:'var(--teal)'},
    {label:'Avg Scale Score',value:avgScore,detail:'Spring YTD',color:'var(--sky)'},
    {label:'Avg Gain',value:'+'+avgGain,detail:'pts since baseline',color:'var(--green)'},
    {label:'% Typical Growth',value:pctTypical+'%',detail:'Avg progress to goal',color:'var(--violet)'},
    {label:'On/Above Grade',value:aboveGL,detail:'Early 2 or higher',color:'#059669'},
    {label:'Below Grade Level',value:belowGL,detail:'Grade 1 or below',color:'var(--rose)'},
    {label:'Met Typical Growth',value:typMet,detail:pct(typMet,s.length)+'% of students',color:'var(--teal)'},
    {label:'Met Stretch Growth',value:stretchMet,detail:pct(stretchMet,s.length)+'% of students',color:'var(--violet)'}
  ].map(({label,value,detail,color})=>`
    <div class="stat-card" style="--accent:${color}">
      <div class="stat-label">${label}</div>
      <div class="stat-value" style="color:${color}">${value}</div>
      <div class="stat-detail">${detail}</div>
    </div>`).join('');
  document.getElementById('overview-stats').innerHTML = statsHTML;

  // Placement distribution
  const placements = ['Grade 5','Grade 4','Grade 3','Max Score','Late 2','Mid 2','Early 2','Grade 1','Grade K','Emerging K'];
  const placeCounts = {};
  s.forEach(x=>{placeCounts[x.placement]=(placeCounts[x.placement]||0)+1;});
  let distHTML = placements.filter(p=>placeCounts[p]>0).map(p=>{
    const n=placeCounts[p]||0, pv=pct(n,s.length);
    return placementBar(p+` (${n})`, pv, PLACEMENT_COLORS[p]||'#64748b');
  }).join('');
  document.getElementById('placement-dist').innerHTML = distHTML;

  // Growth summary
  const gainBuckets = [
    {label:'40+ pts (Outstanding)',min:40,max:999,color:'#10b981'},
    {label:'25–39 pts (Strong)',min:25,max:39,color:'#0d9488'},
    {label:'15–24 pts (Adequate)',min:15,max:24,color:'#0ea5e9'},
    {label:'1–14 pts (Minimal)',min:1,max:14,color:'#f59e0b'},
    {label:'0 or Negative (No Growth)',min:-999,max:0,color:'#e11d48'}
  ];
  let gHTML = gainBuckets.map(b=>{
    const n=s.filter(x=>x.gain>=b.min&&x.gain<=b.max).length;
    const pv=pct(n,s.length);
    return placementBar(b.label+` (${n})`,pv,b.color);
  }).join('');
  document.getElementById('growth-summary').innerHTML = gHTML;

  // Domain overview
  const domains = [
    {name:'Number & Operations', relKey:'no_rel', icon:'🔢'},
