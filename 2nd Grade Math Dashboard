function getTier(s) {
  // Tier 3: Grade K or below (2+ grade levels below for 2nd grade target)
  if (['Grade K','Emerging K'].includes(s.placement)) return 3;
  // Tier 2: Grade 1 (1 grade level below) OR Early 2 with low growth, OR low overall growth
  if (s.placement === 'Grade 1') return 2;
  if (s.placement === 'Early 2' && s.pct_typical < 50) return 2;
  if (s.pct_typical < 50 && s.gain < 15) return 2;
  return 1;
}
function avg(arr, key) {
  const v = arr.map(s=>s[key]).filter(x=>x!=null&&!isNaN(x));
  return v.length ? Math.round(v.reduce((a,b)=>a+b,0)/v.length) : 0;
}
function pct(n,d) { return d===0?0:Math.round(n/d*100); }
function isAboveGrade(p) { return ['Mid 2','Late 2','Max Score','Grade 3','Grade 4','Grade 5'].includes(p); }
function isBelowGrade(p) { return ['Emerging K','Grade K','Grade 1'].includes(p); }
function placementBar(label, pctVal, color) {
  return `<div class="placement-bar-wrap"><div class="placement-label"><span>${label}</span><span style="color:${color};font-weight:700">${pctVal}%</span></div><div class="placement-bar-bg"><div class="placement-bar-fill" style="width:${pctVal}%;background:${color}"></div></div></div>`;
}
function tierColor(t) { return t===3?'var(--rose)':t===2?'var(--amber)':'var(--green)'; }
function getInitials(name) { return name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase(); }
function hashColor(str) {
  const palette = ['#0d9488','#7c3aed','#0369a1','#b45309','#be123c','#065f46','#1d4ed8','#6b21a8'];
  let h=0; for(let c of str) h=(h*31+c.charCodeAt(0))%palette.length;
  return palette[h];
}

