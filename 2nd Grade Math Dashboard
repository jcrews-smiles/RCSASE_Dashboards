      </div>
      <div style="margin-top:14px;padding-top:12px;border-top:1px solid ${tc}33">
        <div class="action-section-title">📚 Recommended Resources</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px">
          ${p.resources.map(r=>`<span style="background:${tc}15;color:${tc};padding:3px 10px;border-radius:20px;font-size:.7rem;font-weight:600">${r}</span>`).join('')}
        </div>
      </div>
    </div>`;
  }).join('');
}

// INIT
renderOverview();
renderClassView();
renderStandards();
renderIndividual();
renderTiers();
renderActionPlan();
</script>
